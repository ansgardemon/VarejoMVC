@model Varejo.ViewModels.PrazoPagamentoViewModel

@{
    ViewData["Title"] = "Excluir Prazo de Pagamento";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-danger border-opacity-25">
            <i class="fa-solid fa-calendar-xmark fs-3 me-3 text-danger"></i>
            <h4 class="mb-0 fw-bold text-danger">@ViewData["Title"]</h4>
        </div>

        @if (ViewData["DeleteError"] != null)
        {
            <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold mb-4" role="alert">
                <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewData["DeleteError"]
            </div>
        }

        <h5 class="fw-bold mb-4 text-center">Tem certeza que deseja remover este prazo?</h5>

        <div class="p-4 rounded-4 mb-5 text-center" style="background: rgba(0, 0, 0, 0.03); border: 1px dashed var(--glass-border);">
            <p class="mb-1 opacity-75 fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Descrição do Prazo</p>
            <p class="mb-0 fs-4 fw-semibold text-primary">@Model.Descricao</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="IdPrazoPagamento" />
            
            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Cancelar
                </a>
                <button type="submit" class="btn-glass btn-danger border-0">
                    <i class="fa-solid fa-trash-can"></i> Confirmar Exclusão
                </button>
            </div>
        </form>
    </div>
</div>
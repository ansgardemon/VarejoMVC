@model Varejo.ViewModels.UsuarioViewModel

@{
    ViewData["Title"] = "Criar Novo Usuário";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 700px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-user-plus fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="nomeUsuario" class="form-label fw-bold opacity-75">Nome de Usuário (Login)</label>
                    <input asp-for="nomeUsuario" class="form-control form-control-lg" placeholder="Ex: joao.silva" />
                    <span asp-validation-for="nomeUsuario" class="text-danger small fw-semibold mt-1 d-block"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Senha" class="form-label fw-bold opacity-75">Senha</label>
                    <input asp-for="Senha" class="form-control form-control-lg" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Senha" class="text-danger small fw-semibold mt-1 d-block"></span>
                </div>
            </div>

            <div class="row g-3 mb-5">
                <div class="col-md-6">
                    <label asp-for="TipoUsuarioId" class="form-label fw-bold opacity-75">Tipo de Permissão</label>
                    <select asp-for="TipoUsuarioId" class="form-select form-control-lg" asp-items="ViewBag.TipoUsuario">
                        <option value="">-- Selecione o tipo --</option>
                    </select>
                    <span asp-validation-for="TipoUsuarioId" class="text-danger small fw-semibold mt-1 d-block"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PessoaId" class="form-label fw-bold opacity-75">Vincular a Pessoa Física/Jurídica</label>
                    <select asp-for="PessoaId" class="form-select form-control-lg" asp-items="ViewBag.Pessoas">
                        <option value="">-- Selecione a pessoa --</option>
                    </select>
                    <span asp-validation-for="PessoaId" class="text-danger small fw-semibold mt-1 d-block"></span>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left me-1"></i> Cancelar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk me-1"></i> Salvar Usuário
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
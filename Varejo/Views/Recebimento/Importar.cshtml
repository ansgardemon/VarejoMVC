@{
    ViewData["Title"] = "Importar Nota Fiscal";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="glass-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-circle mb-3" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                        <i class="fa-solid fa-upload fs-1" style="color: var(--sys-primary-light, #4facfe);"></i>
                    </div>
                    <h4 class="fw-bold">Entrada por XML (NFe)</h4>
                    <p class="opacity-75 small">Selecione o arquivo .xml para iniciar a conferência.</p>
                </div>

                @if (TempData["Erro"] != null)
                {
                    <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger small fw-bold mb-4" role="alert">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Erro"]
                    </div>
                }

                <form asp-action="Revisar" method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label for="xmlFile" class="form-label fw-bold opacity-75 small text-uppercase">Arquivo XML</label>
                        <input type="file" id="xmlFile" name="xmlFile" class="form-control form-control-lg" accept=".xml" required />
                    </div>

                    <div class="d-flex flex-column gap-2">
                        <button type="submit" class="btn-glass btn-success border-0 text-white w-100 justify-content-center py-3">
                            <i class="fa-solid fa-magnifying-glass me-2"></i> Carregar para Revisão
                        </button>
                        <a asp-action="Index" class="btn-glass text-decoration-none justify-content-center">
                            <i class="fa-solid fa-chevron-left me-2"></i> Voltar à Lista
                        </a>
                    </div>
                </form>

                <div class="mt-4 pt-4 border-top border-secondary border-opacity-10 text-center">
                    <small class="opacity-50 fw-semibold">
                        <i class="fa-solid fa-circle-info me-1"></i> O sistema buscará o fornecedor e o "De-Para" de produtos.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
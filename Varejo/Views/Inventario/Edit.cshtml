@model Varejo.ViewModels.InventarioViewModel

@{
    ViewData["Title"] = "Editar Inventário";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-warning border-opacity-25">
            <i class="fa-solid fa-pen-to-square fs-3 me-3 text-warning"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"] #@Model.Id</h4>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="mb-4">
                <label asp-for="DataCriacao" class="form-label fw-bold opacity-75">Data de Abertura</label>
                <input asp-for="DataCriacao" class="form-control form-control-lg" type="datetime-local" />
                <span asp-validation-for="DataCriacao" class="text-danger small mt-1 d-block fw-semibold"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Observacao" class="form-label fw-bold opacity-75">Observação / Título</label>
                <textarea asp-for="Observacao" class="form-control form-control-lg" rows="3"></textarea>
                <span asp-validation-for="Observacao" class="text-danger small mt-1 d-block fw-semibold"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-warning border-0 text-dark">
                    <i class="fa-solid fa-floppy-disk"></i> Atualizar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
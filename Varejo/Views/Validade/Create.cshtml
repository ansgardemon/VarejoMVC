@model Varejo.ViewModels.ValidadeViewModel

@{
    ViewData["Title"] = "Nova Validade";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 800px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-calendar-plus fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">Cadastrar Validade</h4>
        </div>

        <div asp-validation-summary="All" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

        <form asp-action="Create" method="post">
            
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="DataValidade" class="form-label fw-bold opacity-75">Data de Validade</label>
                    <input asp-for="DataValidade" type="date" class="form-control form-control-lg text-danger fw-bold" />
                    <span asp-validation-for="DataValidade" class="text-danger small fw-semibold mt-1 d-block"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="EmEstoque" class="form-label fw-bold opacity-75">Em Estoque?</label>
                    <select asp-for="EmEstoque" class="form-select form-control-lg text-success fw-bold">
                        <option value="true">Sim</option>
                        <option value="false">Não</option>
                    </select>
                </div>
            </div>

            <div class="p-4 rounded-4 mb-5 shadow-sm" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-box-open me-2 text-primary"></i>Vincular Produto</h5>
                
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--glass-border);">
                            <i class="fa-solid fa-magnifying-glass text-primary opacity-75"></i>
                        </span>
                        <input type="text" id="produtoSearch" class="form-control form-control-lg border-start-0 ps-0" placeholder="Buscar produto..." autocomplete="off" />
                    </div>
                </div>

                <div class="row g-3 mb-3" id="produtoCards"></div>

                <hr class="border-secondary border-opacity-25 my-4" />

                <h6 class="fw-bold text-success text-uppercase small mb-3">Produto Selecionado</h6>
                <div id="produtoSelecionado" class="row g-3"></div>

                <input type="hidden" asp-for="ProdutoId" id="ProdutoId" />
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left me-1"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-primary border-0 text-white">
                    <i class="fa-solid fa-floppy-disk me-1"></i> Salvar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const produtoSearch = document.getElementById('produtoSearch');
        const produtoCards = document.getElementById('produtoCards');
        const produtoSelecionado = document.getElementById('produtoSelecionado');

        let debounceTimer;

        produtoSearch.addEventListener('input', function () {
            clearTimeout(debounceTimer);

            debounceTimer = setTimeout(async () => {
                const termo = produtoSearch.value.trim();

                if (termo.length < 2) {
                    produtoCards.innerHTML = '';
                    return;
                }

                // Ajuste a rota se necessário, de acordo com o seu Controller
                const url = '@Url.Action("SearchProduto", "Validade")?query=' + encodeURIComponent(termo);
                const response = await fetch(url);
                const produtos = await response.json();

                produtoCards.innerHTML = '';

                produtos.forEach(produto => {
                    const div = document.createElement('div');
                    // Ajuste de classes do Bootstrap para grid responsivo
                    div.classList.add('col-md-4', 'col-sm-6', 'mb-3', 'produto-card');

                    const imagem = produto.UrlImagem || '/images/produto-padrao.png';

                    // HTML do Card de Resultado Injetado com Glassmorphism
                    div.innerHTML = `
                        <div class="p-3 rounded-4 h-100 text-center d-flex flex-column justify-content-between" style="background: var(--glass-bg); border: 1px solid var(--glass-border); transition: all 0.2s ease;">
                            <div>
                                <img src="${imagem}" class="img-fluid rounded-3 mb-2" style="height: 100px; object-fit: contain;" onerror="this.src='/images/produto-padrao.png'" />
                                <h6 class="fw-bold fs-6 mb-3">${produto.NomeProduto}</h6>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary w-100 rounded-pill selectProdutoBtn fw-bold">Selecionar</button>
                        </div>
                    `;

                    div.querySelector('.selectProdutoBtn').addEventListener('click', function () {
                        // HTML do Produto Selecionado Injetado com Glassmorphism
                        const selectedDiv = `
                            <div class="col-md-8 col-sm-12">
                                <div class="p-3 rounded-4 d-flex align-items-center" style="background: rgba(40,167,69,0.05); border: 1px solid rgba(40,167,69,0.3);">
                                    <img src="${imagem}" class="rounded-3 me-3 bg-white p-1" style="width: 70px; height: 70px; object-fit: contain;" onerror="this.src='/images/produto-padrao.png'" />
                                    <div>
                                        <h6 class="fw-bold text-success mb-1">${produto.NomeProduto}</h6>
                                        <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25">Pronto para salvar</span>
                                    </div>
                                    <i class="fa-solid fa-circle-check fs-3 text-success ms-auto"></i>
                                </div>
                            </div>
                        `;

                        produtoSelecionado.innerHTML = selectedDiv;

                        // Preencher hidden field
                        document.getElementById('ProdutoId').value = produto.IdProduto;

                        // Limpa a busca para focar na tela de salvar
                        produtoCards.innerHTML = '';
                        produtoSearch.value = '';
                        produtoSearch.placeholder = "Buscar outro produto...";
                    });

                    // Efeito de hover via JS simples para o card injetado
                    div.firstElementChild.addEventListener('mouseenter', function() { this.style.transform = 'translateY(-3px)'; this.style.borderColor = 'var(--sys-primary-light)'; });
                    div.firstElementChild.addEventListener('mouseleave', function() { this.style.transform = 'translateY(0)'; this.style.borderColor = 'var(--glass-border)'; });

                    produtoCards.appendChild(div);
                });

            }, 300);
        });
    </script>
}
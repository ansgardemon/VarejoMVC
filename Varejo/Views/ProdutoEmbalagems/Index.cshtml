@model IEnumerable<Varejo.Models.ProdutoEmbalagem>

@{
    ViewData["Title"] = "Embalagens e Preços";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-boxes-stacked fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Create" class="btn-glass btn-success text-white text-decoration-none border-0">
                <i class="fa-solid fa-plus"></i> <span class="d-none d-sm-inline ms-1">Novo Vínculo</span>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="string" class="ps-md-4">
                            <div class="d-flex justify-content-between align-items-center">Produto <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="string">
                            <div class="d-flex justify-content-between align-items-center">Embalagem <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" class="text-md-center">
                            <div class="d-flex justify-content-between align-items-center justify-content-md-center">Preço <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="string">
                            <div class="d-flex justify-content-between align-items-center">EAN <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th class="text-center pe-md-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Produto" class="ps-md-4 fw-bold text-primary">@item.Produto?.Complemento</td>
                            <td data-label="Tipo">
                                <span class="report-id-badge" style="background: rgba(0,0,0,0.03); border-color: var(--glass-border);">
                                    @item.TipoEmbalagem?.DescricaoTipoEmbalagem
                                </span>
                            </td>
                            <td data-label="Preço" class="text-md-center fw-bold text-success">@item.Preco.ToString("C")</td>
                            <td data-label="EAN" class="opacity-75 small">@item.Ean</td>
                            <td data-label="Ações" class="pe-md-4">
                                <div class="d-flex justify-content-end justify-content-md-center gap-2">
                                    <a asp-action="Delete" asp-route-id="@item.IdProdutoEmbalagem" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Excluir">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.IdProdutoEmbalagem" class="btn btn-sm btn-warning text-dark rounded-pill px-3" title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.IdProdutoEmbalagem" class="btn btn-sm btn-info text-white rounded-pill px-3" title="Detalhes">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
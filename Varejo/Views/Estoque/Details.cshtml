@model IEnumerable<Varejo.ViewModels.HistoricoProdutoViewModel>
@{
    var produto = ViewBag.Produto as Varejo.Models.Produto;
    ViewData["Title"] = "Extrato de Produto";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Histórico do Produto</h2>
            <p class="text-muted">@produto.IdProduto - @produto.NomeProduto (@produto.Familia?.NomeFamilia)</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Voltar
            </a>

            <a asp-action="PrintDetails"
                   asp-route-id="@produto.IdProduto"
                   target="_blank"
                   class="btn btn-primary">
                <i class="fa-solid fa-print me-1"></i> Imprimir Extrato
            </a>
     
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-light border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-uppercase small fw-bold text-secondary">Estoque Atual</h6>
                    <h3 class="mb-0 @(produto.EstoqueAtual < 0 ? "text-danger" : "text-success")">
                        @produto.EstoqueAtual.ToString("N2")
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead class="table-dark">
        <tr>
            <th>Data/Hora</th>
            <th>Operação</th> <th class="text-end">Anterior</th>
            <th class="text-center">Movimento</th>
            <th class="text-end">Posterior</th>
            <th>Observação</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="small">@item.Data.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <span class="fw-bold text-primary">@item.TipoMovimento</span>
                </td>
                <td class="text-end text-muted">@item.EstoqueAntes.ToString("N2")</td>
                <td class="text-center fw-bold">
                    @if (item.QuantidadeMovimento > 0)
                    {
                        <span class="text-success">+@item.QuantidadeMovimento.ToString("N2")</span>
                    }
                    else if (item.QuantidadeMovimento < 0)
                    {
                        <span class="text-danger">@item.QuantidadeMovimento.ToString("N2")</span>
                    }
                    else
                    {
                        <span class="text-muted">@item.QuantidadeMovimento.ToString("N2")</span>
                    }
                </td>
                <td class="text-end fw-bold">@item.EstoqueDepois.ToString("N2")</td>
                <td class="small text-muted">@item.Observacao</td>
            </tr>
        }
    </tbody>
</table>
        </div>
    </div>
</div>
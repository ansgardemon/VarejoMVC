@namespace VarejoCLIENT.Components
@using VarejoCLIENT.Services
@using VarejoCLIENT.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json

@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject AuthService AuthService

<div class="card p-4 shadow border-0" style="max-width: 400px; width: 100%; margin: auto; background: var(--ui-glass-bg); backdrop-filter: blur(var(--ui-glass-blur)); border: 1px solid var(--ui-glass-border) !important; border-radius: 20px;">
    <div class="text-center mb-4">
        <div class="mx-auto mb-3 shadow-sm" style="width: 55px; height: 55px; background: var(--sys-primary); border-radius: 14px; display: grid; place-items: center;">
            <i class="fa-solid fa-box text-white fs-3"></i>
        </div>
        <h3 class="fw-bold" style="color: var(--sys-primary);">Varejo Gestor</h3>
        <hr style="border-color: var(--ui-glass-border);" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold" style="color: var(--sys-primary);">Usuário</label>
        <InputText @bind-Value="usuarioInput" class="form-control" placeholder="Digite seu usuário" />
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold" style="color: var(--sys-primary);">Senha</label>
        <InputText @bind-Value="senhaInput" type="password" class="form-control" placeholder="******" />
    </div>

    @* BOTÃO PADRÃO *@
    <button class="btn w-100 fw-bold shadow-sm mb-3 py-2" style="background: var(--sys-primary); color: white; border-radius: 10px;" @onclick="ExecutarLogin" disabled="@carregando">
        @if (carregando && !usandoBiometria)
        {
            <span class="spinner-border spinner-border-sm"></span>
        }
        else
        {
            <span><i class="fa-solid fa-right-to-bracket me-2"></i> Entrar no Sistema</span>
        }
    </button>

    @* NOVO: BOTÃO DE BIOMETRIA (Só aparece se suportado) *@
    @if (suportaBiometria)
    {
        <button class="btn w-100 fw-bold shadow-sm py-2" style="background: transparent; color: var(--sys-primary); border: 2px solid var(--sys-primary); border-radius: 10px;" @onclick="ExecutarLoginBiometrico" disabled="@carregando">
            @if (carregando && usandoBiometria)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <span><i class="fa-solid fa-fingerprint me-2"></i> Usar Biometria</span>
            }
        </button>
    }

    @if (!string.IsNullOrEmpty(erro))
    {
        <div class="alert mt-4 border-0 text-center fw-medium" style="background: rgba(220, 53, 69, 0.15); color: #dc3545; border-radius: 12px;">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>@erro
        </div>
    }
</div>

@code {
    private string usuarioInput = "";
    private string senhaInput = "";
    private string erro = "";
    private bool carregando = false;
    private bool suportaBiometria = false;
    private bool usandoBiometria = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Verifica se o navegador/hardware suporta biometria
            suportaBiometria = await JSRuntime.InvokeAsync<bool>("biometria.isSupported");
            StateHasChanged();
        }
    }

    private async Task ExecutarLogin() { /* ... seu código original de login via senha ... */ }

    private async Task ExecutarLoginBiometrico()
    {
        carregando = true;
        usandoBiometria = true;
        erro = "";
        try
        {
            var sucesso = await JSRuntime.InvokeAsync<bool>("biometria.autenticar");
            if (sucesso)
            {
                // Busca o token que você salvou no LocalStorage na última vez que ele logou com senha
                var tokenSalvo = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
                if (!string.IsNullOrEmpty(tokenSalvo))
                {
                    var customAuthStateProvider = (CustomAuthStateProvider)AuthStateProvider;
                    customAuthStateProvider.NotificarLogin(tokenSalvo);
                    Nav.NavigateTo("/dashboard");
                }
                else { erro = "Primeiro acesso? Use senha para ativar a biometria."; }
            }
        }
        catch { erro = "Biometria falhou ou foi cancelada."; }
        finally { carregando = false; }
    }

    private class LoginResponseDTO { public bool sucesso { get; set; } public string token { get; set; } = ""; }
}
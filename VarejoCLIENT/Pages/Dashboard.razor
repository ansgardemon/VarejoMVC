@page "/dashboard"
@using VarejoCLIENT.Components.Dashboard
@using VarejoCLIENT.Services
@inject DashboardService DashboardService

<main class="container-fluid py-4">
    <h1 class="vitrino d-none d-lg-block">DASHBOARD</h1>

    <div class="d-flex align-items-center mb-4">
        <div class="me-3" style="width: 8px; height: 32px; background: var(--sys-primary); border-radius: 4px;"></div>
        <h3 class="mb-0 fw-bold" style="color: var(--sys-primary);">Painel de Gestão</h3>
    </div>

    @if (dados == null)
    {
        <div class="card p-5 text-center border-0 shadow-sm mt-5">
            <svg class="loading-progress mx-auto mb-3" style="position: relative; inset: auto; height: 6rem; width: 6rem;">
                <circle r="40%" cx="50%" cy="50%" />
                <circle r="40%" cx="50%" cy="50%" />
            </svg>
            <div class="mt-3 fw-bold" style="color: var(--sys-primary);">Carregando painel...</div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @* Passando as variáveis CSS de cor diretamente para os cards *@
            <DashboardCard Title="Produtos" Value="@dados.TotalProdutos.ToString()" Color="var(--sys-primary)" Icon="bi-box" />
            <DashboardCard Title="Categorias" Value="@dados.TotalCategorias.ToString()" Color="var(--state-success)" Icon="bi-tags" />
            <DashboardCard Title="Movimentações" Value="@dados.TotalMovimentos.ToString()" Color="var(--state-warning)" Icon="bi-arrow-left-right" />
            <DashboardCard Title="Usuários" Value="@dados.TotalUsuarios.ToString()" Color="var(--sys-primary-light)" Icon="bi-people" />
        </div>

        <div class="row mt-4 g-4">
            <div class="col-lg-6">
                <DashboardTable Title="Últimos Produtos" Items="@dados.UltimosProdutos">
                    <HeaderTemplate>
                        <th>Nome</th>
                        <th class="text-end">Preço</th>
                    </HeaderTemplate>
                    <RowTemplate Context="p">
                        <td class="fw-medium">@p.NomeProduto</td>
                        <td class="text-end fw-bold" style="color: var(--state-success);">@p.Preco.ToString("C")</td>
                    </RowTemplate>
                </DashboardTable>
            </div>

            <div class="col-lg-6">
                <DashboardTable Title="Produtos por Categoria" Items="@dados.ProdutosPorCategoria">
                    <HeaderTemplate>
                        <th>Categoria</th>
                        <th class="text-center">Qtd</th>
                    </HeaderTemplate>
                    <RowTemplate Context="c">
                        <td>@c.Descricao</td>
                        <td class="text-center">
                            <span class="badge" style="background-color: var(--sys-primary); color: white; padding: 0.5em 0.8em; border-radius: 8px;">
                                @c.QtdeProdutos
                            </span>
                        </td>
                    </RowTemplate>
                </DashboardTable>
            </div>
        </div>
    }
</main>

@code {
    private DashboardDTO? dados;

    protected override async Task OnInitializedAsync()
    {
        dados = await DashboardService.GetDashboardAsync();
    }
}
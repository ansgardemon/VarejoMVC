@model Varejo.ViewModels.InventarioViewModel

@{
    ViewData["Title"] = $"Inventário #{Model.Id}";
}

<div class="container-fluid mt-4">
    
    <div class="glass-card mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h4 class="fw-bold mb-2">Inventário #@Model.Id - @Model.Observacao</h4>
                <div class="d-flex align-items-center flex-wrap gap-2 opacity-75 fw-semibold small">
                    @if (Model.Finalizado)
                    {
                        <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25 py-1">
                            <i class="fa-solid fa-lock me-1"></i> Finalizado
                        </span>
                    }
                    else
                    {
                        <span class="report-id-badge bg-warning bg-opacity-10 text-warning border-warning border-opacity-25 py-1" style="color: #d97706 !important;">
                            <i class="fa-solid fa-lock-open me-1"></i> Em Aberto
                        </span>
                    }
                    <span>|</span>
                    <span><i class="fa-regular fa-calendar me-1"></i> @Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <a asp-action="Imprimir" asp-route-id="@Model.Id" target="_blank" class="btn-glass btn-info text-white border-0">
                    <i class="fa-solid fa-print"></i> Imprimir
                </a>
                @if (!Model.Finalizado)
                {
                    <form asp-action="Finalizar" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('ATENÇÃO: Deseja realmente finalizar? O estoque será atualizado e o inventário será bloqueado.')" class="m-0">
                        <button type="submit" class="btn-glass btn-success text-white border-0">
                            <i class="fa-solid fa-check-double"></i> Finalizar Contagem
                        </button>
                    </form>
                }
            </div>
        </div>

        @if (Model.Finalizado)
        {
            <div class="alert bg-info bg-opacity-10 border border-info border-opacity-25 text-info mt-4 mb-0 d-flex align-items-center" role="alert">
                <i class="fa-solid fa-shield-halved fs-3 me-3"></i>
                <div>
                    <strong>Inventário Finalizado.</strong><br />
                    Os itens abaixo estão bloqueados para alteração e o estoque já foi ajustado no sistema.
                </div>
            </div>
        }
    </div>

    @if (!Model.Finalizado)
    {
        <div class="glass-card mb-4" style="border-left: 4px solid var(--sys-primary-light, #4facfe);">
            <div class="d-flex align-items-center mb-3">
                <i class="fa-solid fa-barcode fs-4 me-2" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h5 class="fw-bold mb-0">Adicionar Itens à Contagem</h5>
            </div>
            <input type="text" id="produtoSearch" class="form-control form-control-lg mb-4" placeholder="Digite o nome do produto para buscar..." autocomplete="off" />
            <div id="produtoCards" class="row g-3"></div>
        </div>
    }

    <div class="glass-card overflow-hidden p-0">
        <div class="p-4 d-flex justify-content-between align-items-center border-bottom border-secondary border-opacity-25">
            <h5 class="fw-bold mb-0"><i class="fa-solid fa-list-check me-2" style="color: var(--sys-primary-light, #4facfe);"></i> Itens Lançados</h5>
            @if (!Model.Finalizado)
            {
                <span class="report-id-badge bg-primary bg-opacity-10 text-primary border-primary border-opacity-25 py-1">
                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Salva Automático
                </span>
            }
        </div>
      
        <div class="table-responsive">
            <table class="table-glass table-responsive-stack mb-0" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer;" class="ps-md-4">
                            <div class="d-flex justify-content-between align-items-center">Produto <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th>Embalagem</th>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer;" class="text-md-center">
                            <div class="d-flex justify-content-between align-items-center">Qtd. Sistema <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th class="text-md-center" style="width: 180px;">Sua Contagem</th>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer;" class="text-md-center">
                            <div class="d-flex justify-content-between align-items-center">Diferença <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        @if (!Model.Finalizado)
                        {
                            <th class="text-center pe-md-4">Ações</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Itens != null && Model.Itens.Any())
                    {
                        foreach (var item in Model.Itens)
                        {
                            <tr>
                                <td class="ps-md-4" data-label="Produto">
                                    <div class="fw-bold">@item.NomeProduto</div>
                                    <small class="opacity-50 fw-semibold">ID: @item.ProdutoId</small>
                                </td>
                                <td data-label="Embalagem">
                                    <span class="report-id-badge" style="background: rgba(0,0,0,0.05); border-color: var(--glass-border);">
                                        @(item.DescricaoEmbalagem ?? "N/A")
                                    </span>
                                </td>
                                <td class="text-md-center opacity-75 fw-bold" data-label="Qtd. Sistema">
                                    @item.QuantidadeSistema
                                </td>
                                <td class="text-md-center" data-label="Sua Contagem">
                                    <input type="number" step="0.01"
                                           class="form-control form-control-sm text-center fw-bold input-qtd-tabela shadow-none"
                                           style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text);"
                                           data-itemid="@item.Id"
                                           value="@((item.QuantidadeContada / (item.Multiplicador > 0 ? item.Multiplicador : 1)).ToString().Replace(",", "."))"
                                    @(Model.Finalizado ? "disabled" : "") />
                                </td>
                                <td class="text-md-center" data-label="Diferença">
                                    @{
                                        var diffClass = item.Diferenca < 0 ? "bg-danger bg-opacity-10 text-danger border-danger border-opacity-25" :
                                                        item.Diferenca > 0 ? "bg-success bg-opacity-10 text-success border-success border-opacity-25" :
                                                        "bg-secondary bg-opacity-10 text-secondary border-secondary border-opacity-25";
                                    }
                                    <span class="report-id-badge @diffClass" style="min-width: 60px;">
                                        @(item.Diferenca > 0 ? "+" : "")@item.Diferenca
                                    </span>
                                </td>
                                @if (!Model.Finalizado)
                                {
                                    <td class="text-md-center pe-md-4" data-label="Ações">
                                        <form asp-action="RemoveItem" method="post" class="m-0 d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="return confirm('Remover este item da contagem?')">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(Model.Finalizado ? 5 : 6)" class="text-center p-5">
                                <i class="fa-solid fa-box-open fs-1 opacity-25 d-block mb-3"></i>
                                <span class="opacity-75 fw-semibold">Nenhum item adicionado a este inventário ainda.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const produtoSearch = document.getElementById('produtoSearch');
        const produtoCards = document.getElementById('produtoCards');
        let debounceTimer;

        if(produtoSearch) {
            produtoSearch.addEventListener('input', () => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(async () => {
                    const termo = produtoSearch.value.trim();
                    if (termo.length < 2) { produtoCards.innerHTML = ''; return; }

                    const response = await fetch(`@Url.Action("SearchProduto", "Produto")?query=${termo}`);
                    const produtos = await response.json();
                    produtoCards.innerHTML = '';

                    produtos.forEach(p => {
                        const id = p.idProduto || p.IdProduto;
                        const nome = p.nomeProduto || p.NomeProduto;
                        const emb = p.embalagens || p.Embalagens || [];
                        const img = p.urlImagem || p.UrlImagem || '/img/sem-foto.png';

                        const div = document.createElement('div');
                        div.className = 'col-sm-6 col-md-4 col-lg-3';
                        // Renderiza em Glass Card customizado via JS
                        div.innerHTML = `
                            <div class="glass-card h-100 text-center p-3 d-flex flex-column">
                                <div class="d-flex justify-content-center align-items-center rounded-3 mb-2 p-1" style="height: 100px; background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border); overflow:hidden;">
                                    <img src="${img}" style="max-height:100%; max-width:100%; object-fit:contain;">
                                </div>
                                <h6 class="fw-bold mb-2 text-truncate opacity-75" style="font-size:0.8rem;" title="${nome}">${nome}</h6>
                                <select class="form-select form-select-sm mb-3 sel-emb border-0" style="background: rgba(0,0,0,0.05); color: var(--text);">
                                    ${emb.map(e => {
                                        const desc = e.tipoEmbalagemDescricao || e.TipoEmbalagemDescricao || "Unidade";
                                        return `<option value="${e.idProdutoEmbalagem || e.IdProdutoEmbalagem}">${desc}</option>`;
                                    }).join('')}
                                </select>
                                <button class="btn-glass btn-success text-white border-0 mt-auto btn-add w-100 justify-content-center py-1" data-id="${id}">
                                    <i class="fa-solid fa-plus me-1"></i> Adicionar
                                </button>
                            </div>`;
                        
                        div.querySelector('.btn-add').addEventListener('click', () => {
                            const embId = div.querySelector('.sel-emb').value;
                            enviarItem(id, embId);
                        });
                        produtoCards.appendChild(div);
                    });
                }, 400);
            });
        }

        async function enviarItem(prodId, embId) {
            const fd = new FormData();
            fd.append('InventarioId', '@Model.Id');
            fd.append('ProdutoId', prodId);
            fd.append('ProdutoEmbalagemId', embId);
            fd.append('QuantidadeContada', '0');

            const resp = await fetch('@Url.Action("AddItem", "Inventario")', { method: 'POST', body: fd });
            if (resp.ok) {
                location.reload();
            } else {
                alert("Erro ao adicionar item.");
            }
        }

        document.querySelectorAll('.input-qtd-tabela').forEach(input => {
            input.addEventListener('change', async function() {
                const itemId = this.dataset.itemid;
                const qtdDigitada = this.value.replace('.', ',');
                
                // Feedback visual de salvamento
                this.style.borderColor = 'var(--sys-primary-light, #4facfe)';

                const fd = new FormData();
                fd.append('itemId', itemId);
                fd.append('quantidade', qtdDigitada);

                try {
                    const resp = await fetch('@Url.Action("UpdateItemQuantity", "Inventario")', {
                        method: 'POST',
                        body: fd
                    });

                    if (resp.ok) {
                        location.reload();
                    } else {
                        alert('Erro ao salvar.');
                        this.style.borderColor = 'red';
                    }
                } catch (err) {
                    console.error(err);
                }
            });
        });
    </script>
}
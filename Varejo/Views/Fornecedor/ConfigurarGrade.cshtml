@model Varejo.ViewModels.VinculoGradeViewModel

@{
    ViewData["Title"] = "Mapeamento: " + Model.NomeFamilia;
}

<div class="container-fluid mt-4">
    <div class="glass-card mb-4">
        <div class="row align-items-center">
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 small fw-bold opacity-75 text-uppercase" style="letter-spacing: 0.5px;">
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-reset">Fornecedores</a></li>
                        <li class="breadcrumb-item"><a asp-action="Gerenciar" asp-route-id="@Model.PessoaId" class="text-decoration-none text-reset">@Model.NomeFornecedor</a></li>
                        <li class="breadcrumb-item active" style="color: var(--sys-primary-light, #4facfe);" aria-current="page">@Model.NomeFamilia</li>
                    </ol>
                </nav>
                <div class="d-flex align-items-center">
                    <i class="fa-solid fa-list-check fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                    <h4 class="fw-bold mb-0">Mapeamento de Produtos (De-Para)</h4>
                </div>
            </div>
            <div class="col-auto">
                <button type="button" onclick="document.getElementById('btnSalvarLote').click()" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk"></i> <span class="d-none d-md-inline ms-1">Salvar Tudo</span>
                </button>
            </div>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <form asp-action="SalvarGrade" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PessoaId" />
            <input type="hidden" asp-for="FamiliaId" />
            <input type="hidden" asp-for="NomeFornecedor" />
            <input type="hidden" asp-for="NomeFamilia" />

            <div class="table-responsive">
                <table class="table-glass table-responsive-stack mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Produto Interno (Sistema)</th>
                            <th>
                                <div class="d-flex align-items-center justify-content-between">
                                    Cód. Fornecedor
                                    <span class="report-id-badge bg-info bg-opacity-10 text-info border-info border-opacity-25 ms-2 py-0">cProd</span>
                                </div>
                            </th>
                            <th class="pe-4">
                                <div class="d-flex align-items-center justify-content-between">
                                    Desc. Fornecedor
                                    <span class="report-id-badge bg-info bg-opacity-10 text-info border-info border-opacity-25 ms-2 py-0">xProd</span>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Itens != null && Model.Itens.Any())
                        {
                            for (int i = 0; i < Model.Itens.Count; i++)
                            {
                                <tr>
                                    <td class="ps-md-4 opacity-50 fw-semibold" data-label="ID">
                                        @Model.Itens[i].ProdutoId
                                        <input type="hidden" asp-for="Itens[i].ProdutoId" />
                                    </td>
                                    <td data-label="Produto Interno">
                                        <input type="hidden" asp-for="Itens[i].NomeProduto" />
                                        <div class="fw-bold text-uppercase" style="font-size: 0.9rem;">
                                            @Model.Itens[i].NomeProduto
                                        </div>
                                    </td>
                                    <td data-label="Cód. Fornecedor">
                                        <input asp-for="Itens[i].CodigoNoFornecedor" class="form-control form-control-sm border-0" style="background: rgba(0,0,0,0.05); color: var(--text);" placeholder="Digite o código..." />
                                    </td>
                                    <td class="pe-md-4" data-label="Desc. Fornecedor">
                                        <input asp-for="Itens[i].DescricaoNoFornecedor" class="form-control form-control-sm border-0" style="background: rgba(0,0,0,0.05); color: var(--text);" placeholder="Descrição opcional..." />
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center p-4">
                                    <i class="fa-solid fa-box-open fs-1 opacity-25 d-block mb-3"></i>
                                    <span class="opacity-75 fw-semibold">Nenhum produto encontrado para mapeamento nesta família.</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <button type="submit" id="btnSalvarLote" class="d-none"></button>
            
            <div class="p-4 d-flex flex-column flex-md-row justify-content-between align-items-center border-top border-secondary border-opacity-25 gap-3" style="background: rgba(0,0,0,0.02);">
                <span class="opacity-75 small fw-semibold">
                    <i class="fa-solid fa-circle-info me-1"></i> Mostrando <strong>@Model.Itens.Count</strong> produtos da família @Model.NomeFamilia.
                </span>
                
                <div class="d-flex gap-2 w-100 w-md-auto">
                    <a asp-action="Gerenciar" asp-route-id="@Model.PessoaId" class="btn-glass text-decoration-none justify-content-center w-100 w-md-auto">
                        <i class="fa-solid fa-chevron-left"></i> Cancelar
                    </a>
                    <button type="button" onclick="document.getElementById('btnSalvarLote').click()" class="btn-glass btn-success border-0 text-white justify-content-center w-100 w-md-auto">
                        <i class="fa-solid fa-floppy-disk"></i> Salvar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
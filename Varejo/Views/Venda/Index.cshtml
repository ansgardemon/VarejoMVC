@model IEnumerable<Varejo.Models.Venda>

@{
    ViewData["Title"] = "Gestão de Vendas";
}

<div class="container-fluid mt-4">
    <div class="glass-card mb-4">
        
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25 gap-3">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-cart-shopping fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">Pedidos de Venda</h4>
            </div>
            <a asp-action="Create" class="btn-glass btn-success text-white border-0 text-decoration-none">
                <i class="fa-solid fa-plus-circle me-1"></i> <span class="d-none d-sm-inline">Novo Pedido</span>
            </a>
        </div>

        @if (TempData["Sucesso"] != null)
        {
            <div class="alert bg-success bg-opacity-10 border border-success border-opacity-25 text-success fw-semibold mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["Sucesso"]
            </div>
        }

        <div class="p-3 rounded-4 mb-4" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
            <form method="get" asp-action="Index" class="row g-2 align-items-end">
                <div class="col-md-4 col-sm-12">
                    <label class="small fw-bold opacity-75 mb-1">Período</label>
                    <div class="input-group input-group-sm">
                        <input type="date" name="dataInicio" class="form-control bg-transparent" value="@Context.Request.Query["dataInicio"]">
                        <span class="input-group-text bg-transparent border-start-0 border-end-0 opacity-50">até</span>
                        <input type="date" name="dataFim" class="form-control bg-transparent" value="@Context.Request.Query["dataFim"]">
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <label class="small fw-bold opacity-75 mb-1">Cliente</label>
                    <input type="text" name="cliente" class="form-control form-control-sm" placeholder="Nome do cliente..." value="@Context.Request.Query["cliente"]">
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="small fw-bold opacity-75 mb-1">Status</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="finalizada" selected="@(Context.Request.Query["status"] == "finalizada")">Faturada</option>
                        <option value="aberta" selected="@(Context.Request.Query["status"] == "aberta")">Aberta</option>
                    </select>
                </div>
                <div class="col-md-3 col-sm-12 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary w-100 fw-bold"><i class="fa-solid fa-filter me-1"></i> Filtrar</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100 fw-bold"><i class="fa-solid fa-eraser me-1"></i> Limpar</a>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="number" class="ps-md-4"># ID</th>
                        <th data-sortable="true" data-sort-type="string">Data / Hora</th>
                        <th data-sortable="true" data-sort-type="string">Cliente</th>
                        <th data-sortable="true" data-sort-type="number" class="text-md-end">Valor Bruto</th>
                        <th class="text-md-end">Desconto</th>
                        <th data-sortable="true" data-sort-type="number" class="text-md-end pe-3">Total Líquido</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-md-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="ID" class="ps-md-4 fw-bold opacity-50">@item.IdVenda.ToString("D5")</td>
                            <td data-label="Data">
                                <span class="fw-bold">@item.DataVenda.ToShortDateString()</span>
                                <small class="opacity-50 ms-1">@item.DataVenda.ToShortTimeString()</small>
                            </td>
                            <td data-label="Cliente" class="fw-semibold">
                                <i class="fa-solid fa-user-circle opacity-50 me-1"></i> @(item.Pessoa?.NomeRazao ?? "Consumidor Final")
                            </td>
                            <td data-label="Bruto" class="text-md-end opacity-75">@item.ValorSubtotal.ToString("C2")</td>
                            <td data-label="Desconto" class="text-md-end text-danger small fw-bold">- @item.DescontoTotal.ToString("C2")</td>
                            <td data-label="Líquido" class="text-md-end pe-3 fw-bold text-success fs-6">@item.ValorFinal.ToString("C2")</td>
                            <td data-label="Status" class="text-md-center">
                                @if (item.Finalizada)
                                {
                                    <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25 py-1 px-2"><i class="fa-solid fa-file-invoice-dollar me-1"></i>Faturada</span>
                                }
                                else
                                {
                                    <span class="report-id-badge bg-warning bg-opacity-10 text-warning border-warning border-opacity-25 py-1 px-2" style="color:#d97706!important;"><i class="fa-solid fa-hourglass-half me-1"></i>Aberta</span>
                                }
                            </td>
                            <td data-label="Ações" class="pe-md-4">
                                <div class="d-flex justify-content-end justify-content-md-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.IdVenda" class="btn btn-sm btn-info text-white rounded-pill px-3" title="Visualizar Detalhes"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="Imprimir" asp-route-id="@item.IdVenda" target="_blank" class="btn btn-sm btn-secondary text-white rounded-pill px-3" title="Imprimir"><i class="fa-solid fa-print"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 opacity-50 fw-semibold">
                                <i class="fa-solid fa-box-open fa-3x mb-3 d-block"></i>
                                Nenhuma venda encontrada para os filtros aplicados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
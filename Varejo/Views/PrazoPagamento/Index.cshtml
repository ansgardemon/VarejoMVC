@model IEnumerable<Varejo.ViewModels.PrazoPagamentoViewModel>

@{
    ViewData["Title"] = "Prazos de Pagamento";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-calendar-days fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Create" class="btn-glass btn-success text-white border-0 text-decoration-none">
                <i class="fa-solid fa-plus"></i>
                <span class="d-none d-sm-inline ms-1">Novo Prazo</span>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center">
                                Descrição <i class="fa-solid fa-sort opacity-50 ms-2"></i>
                            </div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" class="text-md-center" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center justify-content-md-center">
                                Parcelas <i class="fa-solid fa-sort opacity-50 ms-2"></i>
                            </div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" class="text-md-center" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center justify-content-md-center">
                                Intervalo (dias) <i class="fa-solid fa-sort opacity-50 ms-2"></i>
                            </div>
                        </th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Descrição" class="fw-semibold">@item.Descricao</td>
                                <td data-label="Parcelas" class="text-md-center fw-bold opacity-75">@item.NumeroParcelas</td>
                                <td data-label="Intervalo" class="text-md-center opacity-75">@item.IntervaloDias</td>
                                <td data-label="Ações">
                                    <div class="d-flex justify-content-end justify-content-md-center gap-2">
                                        <a asp-action="Delete" asp-route-id="@item.IdPrazoPagamento" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Excluir">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IdPrazoPagamento" class="btn btn-sm btn-warning text-dark rounded-pill px-3" title="Editar">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center p-5 opacity-50 fw-semibold">
                                <i class="fa-solid fa-calendar-xmark d-block fs-1 mb-3"></i>
                                Nenhum prazo de pagamento cadastrado.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
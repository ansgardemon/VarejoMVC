@typeparam TItem

<div class="input-group input-group-lg shadow-sm border rounded-pill overflow-hidden"
     @onclick="AbrirModal" @onclick:stopPropagation
     style="cursor: pointer; transition: all 0.2s; border-color: var(--sys-primary) !important; background: white;">
    
    <span class="input-group-text bg-white border-0 ps-4">
        <i class="fa-solid fa-magnifying-glass text-primary"></i>
    </span>
    
    <div class="form-control border-0 bg-white d-flex align-items-center py-3" style="min-height: 54px; pointer-events: none;">
        @if (Selecionados != null && Selecionados.Any())
        {
            <span class="badge rounded-pill bg-primary px-3 py-2">
                @Selecionados.Count item(s) selecionado(s)
            </span>
        }
        else
        {
            <span class="text-muted">@Titulo...</span>
        }
    </div>

    <span class="input-group-text bg-white border-0 pe-4">
        <i class="fa-solid fa-chevron-down small text-muted"></i>
    </span>
</div>

@if (ExibirModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); z-index: 2000;" tabindex="-1" @onclick:stopPropagation>
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold text-primary">@Titulo</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body">
                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="fa-solid fa-filter"></i></span>
                        <input type="text" class="form-control" placeholder="Digite para pesquisar na lista..." @bind="termo" @bind:event="oninput" />
                    </div>
                    <div class="list-group overflow-auto" style="max-height: 350px;">
                        @if (ItensFiltrados != null)
                        {
                            @foreach (var item in ItensFiltrados)
                            {
                                var id = GetId(item);
                                var isChecked = Selecionados != null && Selecionados.Contains(id);
                                <label class="list-group-item list-group-item-action d-flex align-items-center" style="cursor: pointer;">
                                    <input class="form-check-input me-3" type="checkbox"
                                           checked="@isChecked"
                                           @onchange="@((e) => Toggle(id, (bool)(e.Value ?? false)))" />
                                    <span class="@(isChecked ? "fw-bold text-primary" : "")">@GetNome(item)</span>
                                </label>
                            }
                        }
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-primary px-5 shadow-sm" @onclick="FecharModal">Confirmar Seleção</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Titulo { get; set; } = "Pesquisar Produtos";
    [Parameter] public List<TItem> Itens { get; set; } = new();
    [Parameter] public List<string> Selecionados { get; set; } = new();
    [Parameter] public EventCallback<List<string>> SelecionadosChanged { get; set; }
    [Parameter] public Func<TItem, string> GetId { get; set; } = default!;
    [Parameter] public Func<TItem, string> GetNome { get; set; } = default!;

    private bool ExibirModal = false;
    private string termo = "";

    private void AbrirModal() { ExibirModal = true; StateHasChanged(); }
    private void FecharModal() { ExibirModal = false; termo = ""; StateHasChanged(); }

    private IEnumerable<TItem> ItensFiltrados =>
        (Itens ?? new()).Where(i => GetNome(i)?.Contains(termo, StringComparison.OrdinalIgnoreCase) == true);

    private async Task Toggle(string id, bool check)
    {
        Selecionados ??= new();
        if (check) { if (!Selecionados.Contains(id)) Selecionados.Add(id); }
        else { Selecionados.Remove(id); }
        await SelecionadosChanged.InvokeAsync(Selecionados);
    }
}
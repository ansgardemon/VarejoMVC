@model IEnumerable<Varejo.Models.Pessoa>

@{
    ViewData["Title"] = "Vínculo de Fornecedores";
}

<div class="container-fluid mt-4">
    <div class="text-center mb-5 mt-3">
        <div class="d-inline-flex align-items-center justify-content-center mb-3 p-3 rounded-circle" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
            <i class="fa-solid fa-link fs-1" style="color: var(--sys-primary-light, #4facfe);"></i>
        </div>
        <h2 class="fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">Mapeamento de Fornecedores</h2>
        <p class="opacity-75 fw-semibold">Gerencie os códigos de integração (De-Para) para importação de XML</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <form id="searchForm" asp-action="Index" method="get">
                <div class="p-2 rounded-pill d-flex align-items-center" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.05);">
                    <i class="fa-solid fa-magnifying-glass fs-5 mx-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                    <input type="text" id="txtBusca" name="termo" class="form-control form-control-lg border-0 bg-transparent shadow-none" placeholder="Digite o nome ou CNPJ do fornecedor..." value="@ViewData["TermoBusca"]" autocomplete="off" autofocus />
                </div>
            </form>
        </div>
    </div>

    <div id="resultadoBusca" class="row justify-content-center">
        @if (Model != null && Model.Any())
        {
            <div class="col-md-10">
                <div class="d-flex flex-column gap-3">
                    @foreach (var f in Model)
                    {
                        <div class="glass-card p-3 p-md-4 cursor-pointer" style="transition: all 0.3s ease;" onmouseenter="this.style.transform='translateY(-3px)'; this.style.borderColor='var(--sys-primary-light, #4facfe)';" onmouseleave="this.style.transform='translateY(0)'; this.style.borderColor='var(--glass-border)';" onclick="window.location.href='@Url.Action("Gerenciar", "Fornecedor", new { id = f.IdPessoa })'">
                            <div class="row align-items-center text-center text-md-start">
                                <div class="col-12 col-md-auto mb-3 mb-md-0">
                                    <div class="d-inline-flex justify-content-center align-items-center rounded-circle mx-auto" style="width: 60px; height: 60px; background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                                        <i class="fa-solid fa-truck-fast fs-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                                    </div>
                                </div>
                                <div class="col">
                                    <h5 class="mb-2 fw-bold text-uppercase" style="letter-spacing: 0.5px;">@f.NomeRazao</h5>
                                    <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-2">
                                        <span class="report-id-badge" style="background: rgba(0,0,0,0.03); border-color: var(--glass-border);">
                                            <i class="fa-solid fa-id-card me-1 opacity-50"></i> @f.CpfCnpj
                                        </span>
                                        <span class="report-id-badge" style="background: rgba(0,0,0,0.03); border-color: var(--glass-border);">
                                            <i class="fa-solid fa-map-location-dot me-1 opacity-50"></i> @(f.Enderecos?.FirstOrDefault()?.Cidade ?? "Cidade não informada")
                                        </span>
                                        <span class="report-id-badge" style="background: rgba(0,0,0,0.03); border-color: var(--glass-border);">
                                            ID: @f.IdPessoa
                                        </span>
                                    </div>
                                </div>
                                <div class="col-auto d-none d-md-block opacity-25">
                                    <i class="fa-solid fa-chevron-right fs-4"></i>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(ViewData["TermoBusca"]?.ToString()))
        {
            <div class="col-12 text-center py-5">
                <div class="d-inline-flex align-items-center justify-content-center p-4 rounded-circle mb-4" style="background: rgba(0,0,0,0.02); border: 1px dashed var(--glass-border);">
                    <i class="fa-solid fa-search-minus fs-1 opacity-25"></i>
                </div>
                <h5 class="fw-bold opacity-75">Nenhum fornecedor encontrado para "@ViewData["TermoBusca"]"</h5>
                <p class="small opacity-50 fw-semibold">Verifique a ortografia ou tente um termo diferente.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        let timeout = null;
        const inputBusca = document.getElementById('txtBusca');
        const formBusca = document.getElementById('searchForm');

        inputBusca.addEventListener('input', function () {
            clearTimeout(timeout);
            timeout = setTimeout(function () {
                const valor = inputBusca.value.trim();
                if (valor.length >= 3 || valor.length === 0) {
                    formBusca.submit();
                }
            }, 600);
        });

        const val = inputBusca.value;
        inputBusca.value = '';
        inputBusca.value = val;
    </script>
}
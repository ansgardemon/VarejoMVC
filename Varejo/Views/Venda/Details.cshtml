@model Varejo.ViewModels.VendaViewModelDetails

@{
    ViewData["Title"] = $"Pedido #{Model.IdVenda}";
}

<div class="container-fluid mt-4">
    
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert bg-success bg-opacity-10 border border-success border-opacity-25 text-success fw-bold"><i class="fa-solid fa-check-circle me-2"></i> @TempData["Sucesso"]</div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Erro"]</div>
    }

    <div class="glass-card mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25 gap-3">
            <div>
                <div class="d-flex align-items-center mb-1">
                    <i class="fa-solid fa-file-invoice fs-3 me-3 text-primary"></i>
                    <h4 class="mb-0 fw-bold text-uppercase">Pedido #@Model.IdVenda.ToString("D5")</h4>
                </div>
                <small class="opacity-50 ms-5 ps-2">Visualizando detalhes do movimento</small>
            </div>
            
            <div class="d-print-none d-flex flex-wrap gap-2">
                @if (!Model.Finalizada)
                {
                    <form asp-action="Faturar" asp-route-id="@Model.IdVenda" method="post" class="m-0">
                        <button type="submit" class="btn-glass btn-success text-white border-0 fw-bold px-4">
                            <i class="fa-solid fa-file-invoice-dollar me-1"></i> Faturar Venda
                        </button>
                    </form>

                    <a asp-action="Cancelar" asp-route-id="@Model.IdVenda" class="btn-glass btn-outline-danger px-3" style="text-decoration:none;">
                        <i class="fa-solid fa-ban me-1"></i> Cancelar
                    </a>
                }

                <a asp-action="Imprimir" asp-route-id="@Model.IdVenda" target="_blank" class="btn-glass btn-secondary text-white border-0 px-3" title="Imprimir A4" style="text-decoration:none;">
                    <i class="fa-solid fa-print me-1"></i> A4
                </a>

                @if (Model.Finalizada)
                {
                    <a asp-action="ImprimirTermica" asp-route-id="@Model.IdVenda" target="_blank" class="btn-glass btn-dark text-white border-0 px-3" title="Cupom Não Fiscal" style="text-decoration:none;">
                        <i class="fa-solid fa-receipt me-1"></i> Cupom
                    </a>
                }

                <a asp-action="Index" class="btn-glass text-decoration-none px-3">
                    <i class="fa-solid fa-arrow-left me-1"></i> Voltar
                </a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-5">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="text-muted small fw-bold d-block text-uppercase mb-1">Cliente</small>
                    <span class="fs-5 fw-bold text-primary">@ViewBag.NomeCliente</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="text-muted small fw-bold d-block text-uppercase mb-1">Pagamento</small>
                    <span class="fw-bold fs-6">@ViewBag.DescricaoPagamento</span>
                </div>
            </div>
            <div class="col-md-2">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="text-muted small fw-bold d-block text-uppercase mb-1">Prazo</small>
                    <span class="fs-6">@ViewBag.DescricaoPrazo</span>
                </div>
            </div>
            <div class="col-md-2 text-md-center">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="text-muted small fw-bold d-block text-uppercase mb-2">Status</small>
                    @if (Model.Finalizada)
                    {
                        <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25 w-100 py-1">FINALIZADA</span>
                    }
                    else
                    {
                        <span class="report-id-badge bg-warning bg-opacity-10 text-warning border-warning border-opacity-25 w-100 py-1" style="color:#d97706!important;">AGUARDANDO</span>
                    }
                </div>
            </div>
        </div>

        <div class="table-responsive mb-4">
            <table class="table-glass table-responsive-stack">
                <thead>
                    <tr>
                        <th style="width: 40%" class="ps-md-4">Produto</th>
                        <th>Embalagem</th>
                        <th class="text-md-center">Qtd</th>
                        <th class="text-md-end">Vlr. Unit.</th>
                        <th class="text-md-end text-danger">Desc.</th>
                        <th class="text-md-end pe-md-4">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Itens)
                    {
                        <tr>
                            <td data-label="Produto" class="ps-md-4">
                                <div class="fw-bold">@item.NomeProduto</div>
                                <small class="opacity-50">Cód: @item.ProdutoId</small>
                            </td>
                            <td data-label="Emb."><span class="badge bg-secondary bg-opacity-10 text-dark border border-secondary border-opacity-25">@item.NomeEmbalagem</span></td>
                            <td data-label="Qtd" class="text-md-center fw-bold">@item.Quantidade.ToString("N2")</td>
                            <td data-label="Unitário" class="text-md-end opacity-75">@item.ValorUnitario.ToString("C")</td>
                            <td data-label="Desconto" class="text-md-end text-danger fw-semibold">- @item.DescontoUnitario.ToString("C")</td>
                            <td data-label="Subtotal" class="text-md-end pe-md-4 fw-bold text-primary">@item.Subtotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row justify-content-end mb-4">
            <div class="col-md-5 col-lg-4">
                <div class="glass-card p-0 overflow-hidden border-success" style="border-width: 2px;">
                    <div class="d-flex justify-content-between p-3 border-bottom border-secondary border-opacity-25">
                        <span class="opacity-75 fw-bold">Subtotal Bruto:</span>
                        <span class="fw-bold fs-5">@Model.ValorSubtotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between p-3 border-bottom border-secondary border-opacity-25 text-danger">
                        <span class="fw-bold">Total Descontos:</span>
                        <span class="fw-bold fs-5">- @Model.DescontoTotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between p-4 bg-success text-white text-shadow">
                        <span class="h5 mb-0 fw-bold">TOTAL LÍQUIDO:</span>
                        <span class="h4 mb-0 fw-bold">@Model.ValorFinal.ToString("C")</span>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Observacao))
        {
            <div class="mt-4 p-4 rounded-4" style="background: rgba(var(--sys-primary-rgb, 79, 172, 254), 0.05); border-left: 4px solid var(--sys-primary-light);">
                <h6 class="fw-bold mb-2"><i class="fa-solid fa-circle-info me-2"></i>Observações Internas</h6>
                <p class="mb-0 opacity-75 fst-italic">@Model.Observacao</p>
            </div>
        }
    </div>
</div>
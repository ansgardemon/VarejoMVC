@model Varejo.ViewModels.VendaViewModelDetails
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Imprimir Cupom #@Model.IdVenda</title>
    <script src="https://cdn.jsdelivr.net/npm/qz-tray@2.2.4/qz-tray.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <style>
        body { 
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); 
            height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            padding: 40px;
            text-align: center;
            color: white;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            max-width: 500px;
        }
        .btn-print {
            background: #28a745;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            border-radius: 50px;
            transition: 0.3s;
            width: 100%;
            margin-bottom: 15px;
            box-shadow: 0 5px 15px rgba(40,167,69,0.4);
        }
        .btn-print:hover { background: #218838; transform: translateY(-3px); }
    </style>
</head>
<body>

    <div class="glass-card">
        <i class="fa-solid fa-print fa-4x mb-4 opacity-75"></i>
        <h2 class="fw-bold mb-2">Pedido #@Model.IdVenda.ToString("D5")</h2>
        <p class="opacity-75 mb-4">Clique no botão abaixo para comunicar com a impressora térmica (QZ Tray).</p>
        
        <button onclick="imprimirQZ()" class="btn-print">
            <i class="fa-solid fa-receipt me-2"></i> IMPRIMIR CUPOM AGORA
        </button>
        
        <a href="javascript:window.close()" class="text-white opacity-50 text-decoration-none small">
            Fechar esta janela
        </a>
    </div>

    <script>
        // Função para formatar colunas (Nome Produto + Espaços + Valor)        
        function formatarLinha(col1, col2, totalChars = 42) {
            let espacos = totalChars - (col1.length + col2.length);
            if (espacos < 1) espacos = 1;
            return col1 + " ".repeat(espacos) + col2 + "\n";
        }

        async function imprimirQZ() {
            try {
                if (!qz.websocket.isActive()) {
                    await qz.websocket.connect();
                }

                // Detecta a impressora padrão do Windows (Epson)
                const printerName = await qz.printers.getDefault();
                const config = qz.configs.create(printerName, { encoding: 'CP1252' });

                // Comandos ESC/POS
                const esc = {
                    center: '\x1Ba\x01',
                    left: '\x1Ba\x00',
                    boldOn: '\x1BE\x01',
                    boldOff: '\x1BE\x00',
                    sizeDouble: '\x1D\x21\x11',
                    sizeNormal: '\x1D\x21\x00',
                    setCharsetPT: '\x1Bt\x03', // Ativa a Tabela de Caracteres PC860
                    cut: '\x1Bi'
                };

                let cupom = [
                    esc.setCharsetPT, 
                    esc.center,
                    esc.boldOn + esc.sizeDouble + "VITRIN.O VAREJO\n" + esc.sizeNormal,
                    "Comprovante de Venda\n",
                    "------------------------------------------\n",
                    esc.left,
                    "PEDIDO: #@Model.IdVenda.ToString("D5")\n",
                    "DATA:   @ViewBag.DataVenda\n",
                    "CLIENTE:@ViewBag.NomeCliente.ToUpper()\n",
                    "DOC:    @ViewBag.DocCliente\n",
                    "------------------------------------------\n",
                    esc.boldOn + "ITENS DO PEDIDO\n" + esc.boldOff,
                    "------------------------------------------\n"
                ];

                // Loop dos Itens com alinhamento de colunas
                @foreach (var item in Model.Itens)
                {
                    <text>
                    cupom.push(esc.boldOn + "@item.NomeProduto.ToUpper()".substring(0, 42) + "\n" + esc.boldOff);
                    cupom.push(formatarLinha(
                        "  @item.Quantidade.ToString("N2") @item.NomeEmbalagem x @item.ValorUnitario.ToString("N2")", 
                        "@item.Subtotal.ToString("N2")"
                    ));
                    </text>
                }

                cupom.push("------------------------------------------\n");
                cupom.push(formatarLinha("SUBTOTAL BRUTO:", "@Model.ValorSubtotal.ToString("N2")"));
                cupom.push(formatarLinha("DESCONTOS:", "-@Model.DescontoTotal.ToString("N2")"));
                cupom.push(esc.boldOn + formatarLinha("TOTAL LIQUIDO:", "R$ @Model.ValorFinal.ToString("N2")") + esc.boldOff);
                cupom.push("------------------------------------------\n");
                
                cupom.push("PAGTO: @ViewBag.FormaPagto.ToUpper()\n");
                cupom.push("PRAZO: @ViewBag.Prazo.ToUpper()\n");

                @if (!string.IsNullOrEmpty(Model.Observacao))
                {
                    <text>
                    cupom.push("\nOBS: @Model.Observacao\n");
                    </text>
                }

                cupom.push(esc.center + "\n\n__________________________\n");
                cupom.push("ASSINATURA CLIENTE\n\n");
                cupom.push("@DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")\n");
                cupom.push("Obrigado pela preferencia!\n");
                cupom.push("\n\n\n\n");
                cupom.push(esc.cut); // Comando de corte

                await qz.print(config, cupom);
                alert("Cupom enviado com sucesso!");

            } catch (e) {
                console.error(e);
                alert("Erro: " + e.message);
            }
        }
    </script>
</body>
</html>
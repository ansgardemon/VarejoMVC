@inherits LayoutComponentBase
@inject NavigationManager Nav
@using VarejoCLIENT.Services
@inject AuthService AuthService

@if (Nav.Uri.EndsWith("/login") || !AuthService.IsAutenticado)
{
    @* Fundo transparente para herdar o Glass do app.css *@
    <div class="d-flex align-items-center justify-content-center w-100" style="min-height: 100vh;">
        @Body
    </div>
}
else
{
    <div class="page">
        <div class="sidebar shadow-lg">
            <NavMenu />
        </div>

        <main>
            <article class="content px-4 py-4">
                @Body
            </article>
        </main>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        if (!AuthService.IsAutenticado && !Nav.Uri.Contains("/login"))
        {
            Nav.NavigateTo("login");
        }
    }
}
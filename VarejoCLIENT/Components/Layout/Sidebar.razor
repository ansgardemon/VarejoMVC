@inject NavigationManager Navigation

<div class="p-2">
    <input type="number" class="form-control form-control-sm"
           placeholder="Ir para código..."
           @onchange="NavegarPorCodigo" />
</div>

@code {
    private void NavegarPorCodigo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int cod))
        {
            Navigation.NavigateTo($"/relatorio/{cod}");
        }
    }
}
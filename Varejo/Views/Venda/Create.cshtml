@model Varejo.ViewModels.VendaViewModel

@{
    ViewData["Title"] = "Nova Venda Balcão";
}

<div class="container-fluid">
    <form asp-action="Create" id="formVenda">
        <div class="row">
            <div class="col-md-9">
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-dark text-white">
                        <i class="bi bi-cart-plus"></i> Dados do Pedido
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PessoaId" class="form-label">Cliente</label>
                                <select asp-for="PessoaId" class="form-select select2" asp-items="ViewBag.Clientes">
                                    <option value="">-- Selecione o Cliente --</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="FormaPagamentoId" class="form-label">Forma de Pagamento</label>
                                <select asp-for="FormaPagamentoId" class="form-select" asp-items="ViewBag.FormasPagamento"></select>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="PrazoPagamentoId" class="form-label">Prazo</label>
                                <select asp-for="PrazoPagamentoId" class="form-select" asp-items="ViewBag.PrazosPagamento"></select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-3 border-primary">
                    <div class="card-body">
                        <div class="row align-items-end">
                            <div class="col-md-5">
                                <label class="form-label fw-bold">Buscar Produto (Nome ou EAN)</label>
                                <input type="text" id="buscaProduto" class="form-control form-control-lg" placeholder="Digite para buscar..." autocomplete="off">
                                <div id="resultadosBusca" class="list-group position-absolute w-100 shadow-lg" style="z-index: 1050;"></div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Embalagem</label>
                                <select id="selectEmbalagem" class="form-select form-control-lg"></select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Qtd</label>
                                <input type="number" id="inputQtd" class="form-control form-control-lg" value="1" min="1">
                            </div>
                            <div class="col-md-2">
                                <button type="button" id="btnAdicionarItem" class="btn btn-primary btn-lg w-100">
                                    <i class="bi bi-plus-lg"></i> Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="table-responsive" style="max-height: 400px;">
                        <table class="table table-hover mb-0" id="tabelaItens">
                            <thead class="table-light">
                                <tr>
                                    <th>Produto</th>
                                    <th>Embalagem</th>
                                    <th width="100">Qtd</th>
                                    <th width="150">Unitário</th>
                                    <th width="150">Subtotal</th>
                                    <th width="50"></th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm bg-light border-0">
                    <div class="card-body">
                        <h4 class="text-center mb-4">Resumo</h4>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span id="resumoSubtotal">R$ 0,00</span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Desconto Total (R$)</label>
                            <input type="number" asp-for="DescontoTotal" class="form-control form-control-lg text-end" value="0.00" step="0.01">
                            </div>
                            <hr>
                            <div class="text-center">
                                <h2 class="text-primary fw-bold" id="resumoTotal">R$ 0,00</h2>
                            </div>
                            <button type="submit" class="btn btn-success btn-xl w-100 py-3 mt-4 fw-bold">
                                <i class="bi bi-check2-all"></i> SALVAR PEDIDO
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Cancelar</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @section Scripts {
        <script>
            let itensVenda = [];
            let produtoSelecionado = null;
            let listaProdutosCache = [];

            // 1. Busca Dinâmica de Produtos
            document.getElementById('buscaProduto').addEventListener('input', function(e) {
                let termo = e.target.value;
                if (termo.length < 2) {
                    document.getElementById('resultadosBusca').innerHTML = '';
                    return;
                }

                fetch('@Url.Action("BuscarProdutos", "Venda")' + '?termo=' + encodeURIComponent(termo))
                    .then(res => res.json())
                    .then(data => {
                        listaProdutosCache = data;
                        let html = '';
                        data.forEach((p, index) => {
                            html += `<button type="button" class="list-group-item list-group-item-action" onclick="selecionarProduto(${index})">
                                        ${p.NomeProduto}
                                     </button>`;
                        });
                        document.getElementById('resultadosBusca').innerHTML = html;
                    });
            });

            // 2. Selecionar Produto do Dropdown
            function selecionarProduto(index) {
                const produto = listaProdutosCache[index];
                produtoSelecionado = produto;

                document.getElementById('buscaProduto').value = produto.NomeProduto;
                document.getElementById('resultadosBusca').innerHTML = '';

                let select = document.getElementById('selectEmbalagem');
                select.innerHTML = '';

                if (produto.Embalagens && produto.Embalagens.length > 0) {
                    produto.Embalagens.forEach(emb => {
                        let precoFormatado = Number(emb.Preco).toFixed(2).replace('.', ',');
                        select.innerHTML += `<option value="${emb.IdProdutoEmbalagem}" data-preco="${emb.Preco}">
                                                ${emb.TipoEmbalagemDescricao ?? 'Unidade'} (R$ ${precoFormatado})
                                             </option>`;
                    });
                } else {
                    select.innerHTML = '<option value="">Sem embalagem cadastrada</option>';
                }
            }

            // 3. Adicionar na Grade
            document.getElementById('btnAdicionarItem').addEventListener('click', function() {
                if (!produtoSelecionado) {
                    alert("Busque e selecione um produto primeiro.");
                    return;
                }

                let selectEmb = document.getElementById('selectEmbalagem');
                let option = selectEmb.options[selectEmb.selectedIndex];
            
                if (!option || !option.value) return;

                let embId = option.value;
                let embDesc = option.text;
                let preco = parseFloat(option.getAttribute('data-preco'));
                let qtd = parseFloat(document.getElementById('inputQtd').value);

                let item = {
                    produtoId: produtoSelecionado.IdProduto,
                    nome: produtoSelecionado.NomeProduto,
                    produtoEmbalagemId: parseInt(embId),
                    embalagemDesc: embDesc,
                    quantidade: qtd,
                    valorUnitario: preco,
                    subtotal: qtd * preco
                };

                itensVenda.push(item);
                atualizarTabela();

                // Reset campos de busca
                document.getElementById('buscaProduto').value = '';
                document.getElementById('selectEmbalagem').innerHTML = '';
                document.getElementById('inputQtd').value = 1;
                produtoSelecionado = null;
            });

            // 4. Atualizar Grade e Totais
            function atualizarTabela() {
                let tbody = document.querySelector('#tabelaItens tbody');
                tbody.innerHTML = '';
                let totalGeral = 0;

                            itensVenda.forEach((item, index) => {
                totalGeral += item.subtotal;
                tbody.innerHTML += `
                    <tr>
                        <td>
                            <input type="hidden" name="Itens[${index}].ProdutoId" value="${item.produtoId}">
                            <input type="hidden" name="Itens[${index}].NomeProduto" value="${item.nome}">
                            ${item.nome}
                        </td>
                        <td>
                            <input type="hidden" name="Itens[${index}].ProdutoEmbalagemId" value="${item.produtoEmbalagemId}">
                            <input type="hidden" name="Itens[${index}].NomeEmbalagem" value="${item.embalagemDesc}">
                            ${item.embalagemDesc}
                        </td>
                        <td>
                            <input type="hidden" name="Itens[${index}].Quantidade" value="${item.quantidade.toString().replace('.', ',')}">
                            ${item.quantidade}
                        </td>
                        <td>
                            <input type="hidden" name="Itens[${index}].ValorUnitario" value="${item.valorUnitario.toFixed(2).replace('.', ',')}">
                            R$ ${item.valorUnitario.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}
                        </td>
                        <td>R$ ${item.subtotal.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-danger" onclick="removerItem(${index})">
                                <i class="bi bi-x"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });

                let descInput = document.getElementById('DescontoTotal');
                let desconto = parseFloat(descInput.value) || 0;

                document.getElementById('resumoSubtotal').innerText = totalGeral.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('resumoTotal').innerText = (totalGeral - desconto).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            }

            // 5. Remover Item
            function removerItem(index) {
                itensVenda.splice(index, 1);
                atualizarTabela();
            }

            // Escuta alteração no desconto
            document.getElementById('DescontoTotal').addEventListener('input', atualizarTabela);

            // Fecha dropdown se clicar fora
            document.addEventListener('click', function(e) {
                if (e.target.id !== 'buscaProduto') {
                    document.getElementById('resultadosBusca').innerHTML = '';
                }
            });
        </script>
    }
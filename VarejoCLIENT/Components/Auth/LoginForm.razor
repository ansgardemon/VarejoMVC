@namespace VarejoCLIENT.Components
@using VarejoCLIENT.Services
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="card p-4 shadow border-0" style="max-width: 400px; width: 100%; margin: auto; background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); border: 1px solid var(--glass-border) !important;">
    <div class="text-center mb-4">
        <div class="mx-auto mb-3 shadow-sm" style="width: 55px; height: 55px; background: var(--sys-primary); border-radius: 14px; display: grid; place-items: center;">
            <i class="fa-solid fa-box text-white fs-3"></i>
        </div>
        <h3 class="fw-bold" style="color: var(--sys-primary);">Varejo Gestor</h3>
        <hr style="border-color: var(--glass-border);" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold" style="color: var(--sys-primary);">Usuário</label>
        <InputText @bind-Value="usuarioInput" class="form-control" placeholder="Digite seu usuário" />
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold" style="color: var(--sys-primary);">Senha</label>
        <InputText @bind-Value="senhaInput" type="password" class="form-control" placeholder="******" />
    </div>

    <button class="btn w-100 fw-bold shadow-sm" style="background: var(--sys-primary); color: white;" @onclick="ExecutarLogin" disabled="@carregando">
        @if (carregando)
        {
            <span class="spinner-border spinner-border-sm"></span>
        }
        else
        {
            <span><i class="fa-solid fa-right-to-bracket me-2"></i> Entrar no Sistema</span>
        }
    </button>

    @if (!string.IsNullOrEmpty(erro))
    {
        <div class="alert mt-4 border-0 text-center fw-medium" style="background: rgba(220, 53, 69, 0.15); color: #dc3545; border-radius: 12px;">
            <i class="fa-solid fa-octagon-exclamation me-2"></i>@erro
        </div>
    }
</div>

@code {
    private string usuarioInput = "";
    private string senhaInput = "";
    private string erro = "";
    private bool carregando = false;

    private async Task ExecutarLogin()
    {
        carregando = true;
        erro = "";

        var sucesso = await AuthService.LoginAsync(usuarioInput, senhaInput);

        if (sucesso)
        {
            Nav.NavigateTo("/dashboard");
        }
        else
        {
            erro = "Usuário ou senha inválidos.";
        }
        carregando = false;
    }
}
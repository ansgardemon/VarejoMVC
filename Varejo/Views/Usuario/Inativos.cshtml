@model IEnumerable<Varejo.Models.Usuario>

@{
    ViewData["Title"] = "Usuários Inativos";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-danger border-opacity-25">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-user-slash fs-3 me-3 text-danger"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Index" class="btn-glass text-decoration-none">
                <i class="fa-solid fa-chevron-left me-1"></i> Voltar à lista principal
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th class="ps-md-4">ID</th>
                        <th>Nome de Usuário</th>
                        <th>Tipo de Usuário</th>
                        <th>Status</th>
                        <th class="text-center pe-md-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model)
                    {
                        <tr class="opacity-75">
                            <td data-label="ID" class="ps-md-4 fw-bold">@usuario.IdUsuario</td>
                            <td data-label="Usuário" class="fw-bold">@usuario.nomeUsuario</td>
                            <td data-label="Tipo">@((usuario.TipoUsuario?.DescricaoTipoUsuario) ?? "Não definido")</td>
                            <td data-label="Status">
                                <span class="report-id-badge bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 py-1 px-2"><i class="fa-solid fa-ban me-1"></i>Inativo</span>
                            </td>
                            <td data-label="Ações" class="pe-md-4">
                                <div class="d-flex justify-content-end justify-content-md-center gap-2">
                                    <a asp-action="Ativar" asp-route-id="@usuario.IdUsuario" class="btn btn-sm btn-success text-white rounded-pill px-3" title="Ativar Usuário"><i class="fa-solid fa-power-off me-1"></i> Ativar</a>
                                    <a asp-controller="Pessoa" asp-action="Details" asp-route-id="@usuario.PessoaId" class="btn btn-sm btn-info text-white rounded-pill px-3" title="Ver Pessoa"><i class="fa-solid fa-address-card"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center p-5 opacity-50 fw-semibold">Nenhum usuário inativo encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@model Varejo.ViewModels.VendaViewModelDetails
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Imprimir Venda #@Model.IdVenda</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { font-family: 'Courier New', Courier, monospace; color: #000; background-color: #fff; padding: 30px; }
        .ticket-header { border-bottom: 2px solid #000; margin-bottom: 15px; padding-bottom: 10px; }
        .sep { border-top: 1px dashed #000; margin: 10px 0; }
        table td, table th { font-size: 0.9rem; border: none !important; padding: 4px 0 !important; }
        @@media print {
            .no-print { display: none !important; }
            body { padding: 0; margin: 0; }
        }
    </style>
</head>
<body onload="window.print()">

    <div class="container no-print mb-4">
        <div class="alert alert-secondary d-flex justify-content-between align-items-center">
            <span>Pressione <b>Ctrl + P</b> se a impressão não abrir automaticamente.</span>
            <div class="d-flex gap-2">
                <button onclick="window.print()" class="btn btn-dark btn-sm">Imprimir</button>
                <button onclick="window.close()" class="btn btn-outline-secondary btn-sm">Fechar</button>
            </div>
        </div>
    </div>

    <div class="container" style="max-width: 800px;">
        <div class="ticket-header text-center">
            <h2 class="mb-0 fw-bold">SISTEMA VITRIN.O VAREJO</h2>
            <p class="mb-0">Comprovante de Pedido de Venda</p>
        </div>

        <div class="row mb-3">
            <div class="col-6">
                <strong>PEDIDO:</strong> #@Model.IdVenda.ToString("D5")<br />
                <strong>DATA:</strong> @ViewBag.DataVenda
            </div>
            <div class="col-6 text-end">
                <strong>STATUS:</strong> @(Model.Finalizada ? "FINALIZADA" : "ORÇAMENTO")
            </div>
        </div>

        <div class="sep"></div>

        <div class="mb-3">
            <strong>CLIENTE:</strong> @ViewBag.NomeCliente.ToUpper()<br />
            <strong>CPF/CNPJ:</strong> @ViewBag.DocCliente
        </div>

        <div class="sep"></div>

        <table class="table table-sm">
            <thead>
                <tr style="border-bottom: 1px solid #000 !important;">
                    <th style="width: 50%">PRODUTO</th>
                    <th class="text-center">QTD</th>
                    <th class="text-end">UNIT.</th>
                    <th class="text-end">DESC.</th>
                    <th class="text-end">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Itens)
                {
                    <tr>
                        <td>@item.NomeProduto.ToUpper() (@item.NomeEmbalagem)</td>
                        <td class="text-center">@item.Quantidade.ToString("N2")</td>
                        <td class="text-end">@item.ValorUnitario.ToString("N2")</td>
                        <td class="text-end">@item.DescontoUnitario.ToString("N2")</td>
                        <td class="text-end fw-bold">@item.Subtotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="sep"></div>

        <div class="row justify-content-end">
            <div class="col-6 col-md-5 text-end">
                <div>Subtotal Bruto: @Model.ValorSubtotal.ToString("C")</div>
                <div>Descontos: - @Model.DescontoTotal.ToString("C")</div>
                <div class="h5 fw-bold mt-2 pt-2" style="border-top: 2px solid #000;">
                    TOTAL: @Model.ValorFinal.ToString("C")
                </div>
            </div>
        </div>

        <div class="mt-4">
            <strong>FORMA PAGTO:</strong> @ViewBag.FormaPagto.ToUpper() <br />
            <strong>PRAZO:</strong> @ViewBag.Prazo.ToUpper()
        </div>

        @if (!string.IsNullOrEmpty(Model.Observacao))
        {
            <div class="mt-3 p-2" style="border: 1px solid #000;">
                <strong>OBS:</strong> @Model.Observacao
            </div>
        }

        <div class="text-center mt-5 pt-4">
            <p class="mb-0">___________________________________________________</p>
            <p class="small">ASSINATURA DO CLIENTE</p>
        </div>
    </div>
</body>
</html>
@using VarejoSHARED.DTO
@using VarejoSHARED.DTO.Relatorios
@using VarejoCLIENT.Services
@inject RelatorioService RelService

<RelatorioFiltro OnSearch="ExecutarBusca" OnClear="Limpar" OnExport="Exportar">
    <ChildContent>
        <div class="row g-3">
            <div class="col-md-12 col-lg-6">
                <RelatorioFiltroData DataInicio="filtro.DataInicio"
                                     DataInicioChanged="v => filtro.DataInicio = v"
                                     DataFim="filtro.DataFim"
                                     DataFimChanged="v => filtro.DataFim = v" />
            </div>
            <div class="col-md-12 col-lg-6">
                <label class="form-label">Qual operação foi usada para o ajuste?</label>
                <select class="form-select" @bind="filtro.IdTipoMovimentoAjuste">
                    <option value="">-- Todos os Tipos de Movimento --</option>
                    @if (listaTipos != null)
                    {
                        @foreach (var t in listaTipos)
                        {
                            <option value="@t.IdTipoMovimento">@t.DescricaoTipoMovimento</option>
                        }
                    }
                </select>
            </div>
        </div>
    </ChildContent>
</RelatorioFiltro>

<div class="mt-4">
    @if (loading)
    {
        <div class="text-center p-5 glass-card">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 fw-bold text-primary">Analisando divergências e ajustes...</p>
        </div>
    }
    else
    {
        @if (listaDados != null && listaDados.Any())
        {
            <div class="glass-card overflow-hidden">
                <RelatorioTabelaDinamica TItem="Relatorio208DTO" Dados="listaDados" Colunas="colunas208" />
            </div>
        }
        else if (dadosVazios)
        {
            <div class="p-5 text-center glass-card">
                <i class="fa-solid fa-clipboard-check fa-2x mb-3 text-muted opacity-50"></i>
                <h5 class="fw-bold" style="color: var(--ui-text-primary);">Tudo Certo</h5>
                <p class="mb-0" style="color: var(--ui-text-secondary);">Nenhuma divergência ou ajuste registrado para este período e filtros.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Codigo { get; set; }
    [Parameter] public RelatorioDefinicaoDTO Definicao { get; set; }

    private RelatorioFiltro208DTO filtro = new() { DataInicio = DateTime.Now.AddDays(-7), DataFim = DateTime.Now };
    private List<Relatorio208DTO>? listaDados;
    
    private bool loading = false;
    private bool dadosVazios = false;

    // Dropdown de Tipos
    private List<TipoMovimentoOutputDTO> listaTipos = new();

    // === DEFINIÇÃO DAS COLUNAS ===
    private List<RelatorioTabelaDinamica<Relatorio208DTO>.ConfigColuna> colunas208 = new() {
        new() { Titulo = "Data/Hora", Propriedade = "DataAjuste", Formato = "dd/MM/yyyy HH:mm" },
        new() { Titulo = "Produto", Propriedade = "NomeProduto" },
        new() { Titulo = "Qtd Ajuste", Propriedade = "QuantidadeAjustada", Formato = "N2" },
        new() { Titulo = "Impacto (R$)", Propriedade = "ImpactoFinanceiro", Formato = "C2" },
        new() { Titulo = "Obs", Propriedade = "Observacao" }
    };

    protected override async Task OnInitializedAsync()
    {
        // Popula o <select> da tela buscando os Tipos de Movimento na API
        listaTipos = await RelService.GetTiposMovimentoAsync() ?? new();
    }

    private async Task ExecutarBusca()
    {
        loading = true; dadosVazios = false; StateHasChanged();
        
        listaDados = await RelService.GetDadosRelatorio208Async(filtro);
        dadosVazios = listaDados == null || !listaDados.Any();
        
        loading = false; StateHasChanged();
    }

    private void Limpar()
    {
        listaDados = null;
        filtro = new() { DataInicio = DateTime.Now.AddDays(-7), DataFim = DateTime.Now };
        dadosVazios = false; StateHasChanged();
    }

    private async Task Exportar(string f)
    {
        loading = true; StateHasChanged();
        try
        {
            await RelService.DownloadPdfAsync(Codigo, Definicao.Nome, filtro);
        }
        finally
        {
            loading = false; StateHasChanged();
        }
    }
}
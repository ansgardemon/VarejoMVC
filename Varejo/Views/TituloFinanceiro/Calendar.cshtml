@{
    ViewData["Title"] = "Calendário de Títulos";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <div class="d-flex align-items-center">
                <i class="fa-regular fa-calendar-days fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Index" class="btn-glass text-decoration-none">
                <i class="fa-solid fa-list me-1"></i> Lista de Títulos
            </a>
        </div>

        <div class="p-3 bg-white rounded-4" style="opacity: 0.95;">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('calendar');

        if (calendarEl) {
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'pt-br',
                selectable: true,
                editable: false,
                events: '/TituloFinanceiro/GetEventos',
                eventClick: function(info) {
                    info.jsEvent.preventDefault();
                    var id = info.event.id;
                    if (id) {
                        window.location.href = '/TituloFinanceiro/Details/' + id;
                    }
                }
            });
            calendar.render();
        }
    });
</script>
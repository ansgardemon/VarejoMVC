@model IEnumerable<Varejo.ViewModels.TituloFinanceiroViewModel>

@{
    ViewData["Title"] = "Títulos Financeiros";

    var grupos = Model
        .GroupBy(x => string.IsNullOrEmpty(x.NomePessoa) ? "Sem pessoa" : x.NomePessoa)
        .OrderBy(g => g.Key);
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@ViewData["Title"]</h5>

            <div>
                <a asp-action="Create" class="btn btn-light btn-sm">Novo</a>
                <a asp-action="Calendar" class="btn btn-outline-light btn-sm ms-2">📅 Calendário</a>
            </div>
        </div>

        <div class="card-body">

            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger">@TempData["Erro"]</div>
            }

            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success">@TempData["Sucesso"]</div>
            }

            <!-- 🔍 FILTROS -->
            <form method="get" class="mb-4">
                <div class="row g-2">

                    <div class="col-md-2">
                        <input type="text" name="documento" class="form-control" placeholder="Documento"
                               value="@Context.Request.Query["documento"]" />
                    </div>

                    <div class="col-md-2">
                        <input type="text" name="pessoa" class="form-control" placeholder="Pessoa"
                               value="@Context.Request.Query["pessoa"]" />
                    </div>

                    <div class="col-md-2">
                        <select name="status" class="form-control">
                            <option value="aberto" selected="@(Context.Request.Query["status"] == "aberto")">Em aberto</option>
                            <option value="quitado" selected="@(Context.Request.Query["status"] == "quitado")">Quitado</option>
                            <option value="todos" selected="@(Context.Request.Query["status"] == "todos")">Todos</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <input type="date" name="dataInicio" class="form-control"
                               value="@Context.Request.Query["dataInicio"]" />
                    </div>

                    <div class="col-md-2">
                        <input type="date" name="dataFim" class="form-control"
                               value="@Context.Request.Query["dataFim"]" />
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                        <a asp-action="Index" class="btn btn-secondary w-100">Limpar</a>
                    </div>

                </div>
            </form>

            <!-- 📦 CARDS POR PESSOA -->
            @foreach (var grupo in grupos)
            {
                var total = grupo.Sum(x => x.Valor);
                var pago = grupo.Sum(x => x.ValorPago ?? 0);
                var aberto = grupo.Sum(x => x.ValorAberto);

                <div class="card shadow-sm mb-4 border-0">

                    <!-- 👤 HEADER -->
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@grupo.Key</strong>
                        </div>

                        <div class="text-end">
                            <small>Total: @total.ToString("C")</small> |
                            <small>Pago: @pago.ToString("C")</small> |
                            <small>Saldo: @aberto.ToString("C")</small>
                        </div>
                    </div>

                    <!-- 📊 TABELA -->
                    <div class="card-body p-0">

                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Documento</th>
                                    <th>Parcela</th>
                                    <th>Vencimento</th>
                                    <th>Valor</th>
                                    <th>Pago</th>
                                    <th>Saldo</th>
                                    <th>Tipo</th>
                                    <th>Status</th>
                                    <th style="width: 180px;">Ações</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in grupo)
                                {
                                    <tr>
                                        <td>@item.Documento</td>
                                        <td>@item.Parcela</td>
                                        <td>@item.DataVencimento.ToShortDateString()</td>
                                        <td>@item.Valor.ToString("C")</td>
                                        <td>@(item.ValorPago?.ToString("C") ?? "R$ 0,00")</td>
                                        <td>@item.ValorAberto.ToString("C")</td>
                                        <td>
                                            @if (item.EspecieDescricao?.ToLower().Contains("obrig") == true)
                                            {
                                                <span class="badge bg-danger">Obrigação</span>
                                            }
                                            else if (item.EspecieDescricao?.ToLower().Contains("direit") == true)
                                            {
                                                <span class="badge bg-success">Direito</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Outro</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.Quitado)
                                            {
                                                <span class="badge bg-success">Quitado</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Aberto</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="Edit" asp-route-id="@item.IdTituloFinanceiro" class="btn btn-sm btn-warning">Editar</a>
                                            <a asp-action="Details" asp-route-id="@item.IdTituloFinanceiro" class="btn btn-sm btn-success">Detalhes</a>
                                            <a asp-action="Delete" asp-route-id="@item.IdTituloFinanceiro" class="btn btn-sm btn-danger">Excluir</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>

                    </div>
                </div>
            }

        </div>

    </div>

</div>
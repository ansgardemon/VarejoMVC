@model Varejo.ViewModels.InventarioViewModel

@{
    ViewData["Title"] = "Editar Inventário";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">@ViewData["Title"] #@Model.Id</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="DataCriacao" class="form-label">Data de Abertura</label>
                    <input asp-for="DataCriacao" class="form-control" type="datetime-local" />
                    <span asp-validation-for="DataCriacao" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Observacao" class="form-label">Observação / Título</label>
                    <textarea asp-for="Observacao" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Observacao" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-chevron-left"></i> Voltar
                    </a>
                    <button type="submit" class="btn btn-warning">
                        <i class="fa-solid fa-pen-to-square"></i> Atualizar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model Varejo.ViewModels.InventarioViewModel

@{
    ViewData["Title"] = "Novo Inventário";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Novo Inventário</h5>
        </div>

        <!-- BODY -->
        <div class="card-body">

            <!-- ALERTAS -->
            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Erro"]
                </div>
            }

            <!-- FORM -->
            <form asp-action="Create" method="post">

                @Html.AntiForgeryToken()

                <div class="row mb-3">

                    <div class="col-md-6">
                        <label class="form-label">Data</label>
                        <input type="datetime-local"
                               name="DataCriacao"
                               class="form-control"
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                </div>

                <div class="row mb-3">

                    <div class="col-md-12">
                        <label class="form-label">Observação</label>
                        <textarea name="observacao" class="form-control" rows="3" placeholder="Ex: Inventário mensal de bebidas..."></textarea>
                    </div>

                </div>

                <!-- BOTÕES -->
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        💾 Criar Inventário
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>

    </div>

</div>
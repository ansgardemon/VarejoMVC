@model Varejo.ViewModels.InventarioViewModel




<div class="container mt-4">
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-1">Inventário #@Model.Id</h4>
                <a asp-action="Imprimir" asp-route-id="@Model.Id" target="_blank" class="btn btn-outline-secondary shadow-sm">
                    🖨️ Imprimir Lista
                </a>
                <p class="text-muted mb-0">
                    <span class="badge @(Model.Finalizado ? "bg-success" : "bg-warning text-dark")">
                        @(Model.Finalizado ? "Finalizado" : "Em Aberto")
                    </span>
                    | 📅 @Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")
                </p>
                @if (!string.IsNullOrEmpty(Model.Observacao))
                {
                    <small class="text-muted">📝 @Model.Observacao</small>
                }
            </div>
            @* Adicione logo abaixo do cabeçalho *@
            @if (Model.Finalizado)
            {
                <div class="alert alert-info shadow-sm d-flex align-items-center" role="alert">
                    <span class="me-3 fs-4">🔒</span>
                    <div>
                        <strong>Este inventário está finalizado.</strong>
                        Os itens abaixo estão bloqueados para alteração e o estoque já foi ajustado.
                    </div>
                    <a asp-action="Index" class="btn btn-sm btn-outline-primary ms-auto">Voltar para a Lista</a>
                </div>
            }


            @if (!Model.Finalizado)
            {
                <form asp-action="Finalizar" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Deseja realmente finalizar? Isso ajustará o estoque real no sistema!')">
                    <button type="submit" class="btn btn-success shadow-sm">
                        ✅ Finalizar e Ajustar Estoque
                    </button>
                </form>
            }


        </div>
    </div>

    @if (!Model.Finalizado)
    {
        <div class="card mb-4 border-primary shadow-sm">
            <div class="card-body">
                <h5 class="card-title text-primary">🔍 Adicionar Itens à Contagem</h5>
                <input type="text" id="produtoSearch" class="form-control form-control-lg mb-3" placeholder="Digite o nome do produto para pesquisar..." autocomplete="off" />
                <div id="produtoCards" class="row"></div>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">Itens no Inventário</h6>
            @if (!Model.Finalizado)
            {
                <small class="text-info">💡 A contagem é salva automaticamente ao sair do campo.</small>
            }
        </div>
        <div class="table-responsive" id="areaImpressao">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Produto</th>
                        <th>Embalagem</th>
                        <th class="text-center">Qtd. Sistema</th>
                        <th class="text-center" style="width: 180px;">Contagem Real</th>
                        <th class="text-center">Diferença (Un)</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Itens != null && Model.Itens.Any())
                    {
                        foreach (var item in Model.Itens)
                        {
                            <tr>
                                <td><strong>@item.NomeProduto</strong></td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @item.DescricaoEmbalagem
                                    </span>
                                </td>
                                <td class="text-center text-muted">@item.QuantidadeSistema</td>
                                <td class="text-center">
                                    <div class="input-group input-group-sm">
                                        @* IMPORTANTE: data-prodid E data-embid para identificar a linha única *@
                                        <input type="number"
                                               class="form-control text-center fw-bold input-qtd-tabela"
                                               data-prodid="@item.ProdutoId"
                                               data-embid="@item.ProdutoEmbalagemId"
                                               value="@((item.QuantidadeContada / (item.Multiplicador > 0 ? item.Multiplicador : 1)).ToString().Replace(",", "."))"
                                        @(Model.Finalizado ? "disabled" : "") />
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold @(item.Diferenca < 0 ? "text-danger" : (item.Diferenca > 0 ? "text-success" : "text-muted"))">
                                        @(item.Diferenca > 0 ? "+" : "")@item.Diferenca
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (!Model.Finalizado)
                                    {
                                        @* Exclusão agora envia o ProdutoEmbalagemId para não apagar duplicados por erro *@
                                        <form asp-controller="Inventario" asp-action="RemoveItem" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
    
                                            @* O 'name' precisa ser identico ao parametro do Controller: itemId *@
                                            <input type="hidden" name="itemId" value="@item.Id" />
    
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0"
                                                    onclick="return confirm('Deseja remover este item?')">
                                                🗑️ Excluir
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted italic">Nenhum item contado ainda.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    @@media print {
        /* 1. ESCONDE O QUE NÃO É DOCUMENTO POR ID E CLASSE ESPECÍFICA */
        nav, footer, .navbar, .btn, .alert, form,
        #produtoSearch, #produtoCards, .card-header,
        .text-info, .text-muted.italic {
            display: none !important;
        }
        /* 2. CONFIGURAÇÃO DA PÁGINA */
        @@page {
            size: A4;
            margin: 1cm;
        }
        
        body {
            background-color: white !important;
            color: black !important;
            font-family: sans-serif;
        }
        /* 3. FORÇA A EXIBIÇÃO DO CONTAINER E DOS CARDS QUE CONTÊM A TABELA */
        .container, .card, .card-body, .table-responsive, .table {
            display: block !important;
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            box-shadow: none !important;
        }
            /* 4. CABEÇALHO PERSONALIZADO NO TOPO DA CARD-BODY */
            .card-body:first-child::before {
                content: "RELATÓRIO DE CONFERÊNCIA DE INVENTÁRIO";
                display: block;
                text-align: center;
                font-size: 18pt;
                font-weight: bold;
                margin-bottom: 10px;
                border-bottom: 2px solid #000;
            }
        /* 5. FORMATAÇÃO DA TABELA DE ITENS */
        .table {
            display: table !important;
            border-collapse: collapse !important;
            margin-top: 20px !important;
        }

            .table th, .table td {
                border: 1px solid #000 !important;
                padding: 8px !important;
                color: black !important;
                background-color: transparent !important;
            }
                /* Esconde colunas: Qtd Sistema (3), Diferença (5) e Ações (6) */
                .table th:nth-child(3), .table td:nth-child(3),
                .table th:nth-child(5), .table td:nth-child(5),
                .table th:nth-child(6), .table td:nth-child(6) {
                    display: none !important;
                }
        /* Transforma o input em uma linha de escrita _____ */
        .input-qtd-tabela {
            border: none !important;
            border-bottom: 1px solid #000 !important;
            background: transparent !important;
            width: 100px !important;
            /* Esconde o valor atual para a pessoa não "colar" */
            color: white !important;
        }
        /* 6. RODAPÉ DE ASSINATURA */
        .table::after {
            content: "\A\A\A __________________________________________\A Assinatura do Conferente";
            white-space: pre;
            display: block;
            text-align: center;
            margin-top: 30px;
        }
    }
</style>

@section Scripts {




    <script>

        const estaFinalizado = @Model.Finalizado.ToString().ToLower();
        if (estaFinalizado) {
            console.log("Inventário finalizado. Scripts de edição desativados.");
        }

        const produtoSearch = document.getElementById('produtoSearch');
        const produtoCards = document.getElementById('produtoCards');
        let debounceTimer;






        // 1. BUSCA DE PRODUTOS VIA AJAX
        produtoSearch.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(async () => {
                const termo = produtoSearch.value.trim();
                if (termo.length < 2) { produtoCards.innerHTML = ''; return; }

                try {
                    const response = await fetch(`@Url.Action("SearchProduto", "Produto")?query=${termo}`);
                    const produtos = await response.json();
                    produtoCards.innerHTML = '';

                    if (!produtos || produtos.length === 0) {
                        produtoCards.innerHTML = '<div class="col-12 text-muted p-2">Nenhum produto encontrado.</div>';
                        return;
                    }

                    produtos.forEach(p => {
                        const id = p.idProduto || p.IdProduto;
                        const nome = p.nomeProduto || p.NomeProduto;
                        const embalagens = p.embalagens || p.Embalagens || [];

                        const div = document.createElement('div');
                        div.className = 'col-md-3 mb-3';
                        div.innerHTML = `
                            <div class="card h-100 shadow-sm border-0 bg-light text-center p-2">
                                <h6 style="font-size:0.8rem; height:2rem; overflow:hidden;">${nome}</h6>
                                <select class="form-select form-select-sm mb-2 embalagem-select">
                                    ${embalagens.map(e => `<option value="${e.idProdutoEmbalagem || e.IdProdutoEmbalagem}">${e.TipoEmbalagemDescricao || 'Unidade'}</option>`).join('')}
                                </select>
                                <button type="button" class="btn btn-primary btn-sm btnAdd" data-id="${id}">➕ Adicionar</button>
                            </div>`;
                        
                        div.querySelector('.btnAdd').addEventListener('click', function() {
                            const embId = div.querySelector('.embalagem-select').value;
                            enviarItem(id, embId);
                        });
                        produtoCards.appendChild(div);
                    });
                } catch (err) { console.error("Erro na busca:", err); }
            }, 400);
        });

        // 2. ADICIONAR ITEM (Inicia com zero)
        async function enviarItem(prodId, embId) {
            const fd = new FormData();
            fd.append('InventarioId', '@Model.Id');
            fd.append('ProdutoId', prodId);
            fd.append('ProdutoEmbalagemId', embId);
            fd.append('QuantidadeContada', '0');

            const resp = await fetch('@Url.Action("AddItem", "Inventario")', { method: 'POST', body: fd });
            if (resp.ok) location.reload();
            else alert("Erro ao adicionar item ao inventário.");
        }

        // 3. ATUALIZAÇÃO AUTOMÁTICA AO DIGITAR NA TABELA
        document.querySelectorAll('.input-qtd-tabela').forEach(input => {
            input.addEventListener('change', async function() {
                const prodId = this.dataset.prodid;
                const embId = this.dataset.embid; // Captura o ID da embalagem da linha
                const valor = this.value;

                const fd = new FormData();
                fd.append('inventarioId', '@Model.Id');
                fd.append('produtoId', prodId);
                fd.append('produtoEmbalagemId', embId); // Envia o ID da embalagem para o Controller
                fd.append('quantidade', valor);

                this.classList.add('is-invalid'); // Feedback visual de carregamento

                try {
                    const resp = await fetch('@Url.Action("UpdateItemQuantity", "Inventario")', {
                        method: 'POST',
                        body: fd
                    });

                    if (resp.ok) {
                        location.reload(); // Recarrega para processar multiplicadores e diferenças no C#
                    } else {
                        const msg = await resp.text();
                        alert('Erro ao salvar: ' + msg);
                        this.classList.remove('is-invalid');
                    }
                } catch (err) {
                    alert('Erro de conexão ao salvar.');
                }
            });
        });






    </script>
}
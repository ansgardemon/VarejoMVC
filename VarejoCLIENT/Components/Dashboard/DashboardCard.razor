<div class="col-xl-3 col-md-6 mb-4">
    <div class="card border-left-@Color shadow h-100 py-2 border-0 border-start border-4">
        <div class="card-body">
            <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-@Color text-uppercase mb-1" style="font-size: 0.8rem;">
                        @Title
                    </div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Value</div>
                </div>
                <div class="col-auto">
                    <i class="bi @Icon fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string Color { get; set; } = "primary";
    [Parameter] public string Icon { get; set; } = "";
}
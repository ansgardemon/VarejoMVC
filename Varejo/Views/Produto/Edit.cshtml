@model Varejo.ViewModels.ProdutoViewModel

@{
    ViewData["Title"] = "Editar Produto";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 900px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-warning border-opacity-25">
            <i class="fa-solid fa-pen-to-square fs-3 me-3 text-warning"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form id="produto-form" asp-action="Edit" enctype="multipart/form-data" method="post">
            <input type="hidden" asp-for="IdProduto" />
            <input type="hidden" asp-for="FamiliaId" />

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold opacity-75">Família</label>
                    <input class="form-control form-control-lg" value="@Model.Familia?.NomeFamilia" disabled style="background: rgba(0,0,0,0.05)!important;" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Complemento" class="form-label fw-bold opacity-75"></label>
                    <input asp-for="Complemento" class="form-control form-control-lg" />
                </div>
                
                <div class="col-md-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.UrlImagem))
                    {
                        <div class="p-2 rounded-4 border border-secondary border-opacity-25 mb-2" style="background: rgba(255,255,255,0.03)">
                            <img src="@Url.Content(Model.UrlImagem)" style="max-height: 100px; object-fit:contain;" />
                        </div>
                        <small class="opacity-50 fw-bold">Imagem Atual</small>
                    }
                </div>

                <div class="col-md-4">
                    <label asp-for="ImagemUpload" class="form-label fw-bold opacity-75">Trocar Imagem</label>
                    <input asp-for="ImagemUpload" class="form-control" type="file" />
                </div>

                <div class="col-md-4">
                    <label class="btn-check-glass toggle-ativo w-100 mt-4">
                        <input asp-for="Ativo" type="checkbox" />
                        <div class="check-content">
                            <span class="if-checked"><i class="fa-solid fa-circle-check me-2"></i>Ativo</span>
                            <span class="if-not-checked"><i class="fa-solid fa-circle-xmark me-2"></i>Inativo</span>
                        </div>
                    </label>
                </div>
            </div>

            <div class="d-flex align-items-center mb-3">
                <h5 class="fw-bold mb-0">Embalagens / Preços</h5>
                <button type="button" id="adicionar-embalagem" class="btn btn-sm btn-glass border-0 ms-3" style="background: rgba(0,0,0,0.05);">
                    <i class="fa-solid fa-plus me-1"></i> Nova Embalagem
                </button>
            </div>

            <div id="embalagens-container" class="row g-3 mb-5">
                @for (int i = 0; i < Model.Embalagens.Count; i++)
                {
                    <div class="col-12 embalagem-item">
                        <div class="p-4 rounded-4 position-relative" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 mt-3 me-3 remover-embalagem rounded-circle shadow-sm">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold opacity-75">Tipo</label>
                                    <select name="Embalagens[@i].TipoEmbalagemId" class="form-select">
                                        @foreach (var t in Model.Embalagens[i].TiposEmbalagem)
                                        {
                                            <option value="@t.Value" selected="@(t.Value == Model.Embalagens[i].TipoEmbalagemId.ToString())">@t.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold opacity-75">Preço</label>
                                    <input name="Embalagens[@i].Preco" class="form-control" value="@Model.Embalagens[i].Preco" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold opacity-75">Código EAN</label>
                                    <input name="Embalagens[@i].Ean" class="form-control" value="@Model.Embalagens[i].Ean" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center pt-4 border-top border-secondary border-opacity-25">
                <a asp-action="Details" asp-controller="Familia" asp-route-id="@Model.FamiliaId" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-warning border-0 text-dark">
                    <i class="fa-solid fa-floppy-disk"></i> Atualizar Produto
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var container = document.getElementById('embalagens-container');
            
            // Serializa os tipos de embalagem para usar no JS
            var tipos = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                            (Model.Embalagens != null && Model.Embalagens.Any() && Model.Embalagens[0].TiposEmbalagem != null)
                                    ? Model.Embalagens[0].TiposEmbalagem
                                    : new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>()
                    ));

            // Função para Adicionar
            document.getElementById('adicionar-embalagem').addEventListener('click', function () {
                // Conta quantos itens já existem para definir o índice [i]
                var index = container.querySelectorAll('.embalagem-item').length;
                var options = tipos.map(t => `<option value="${t.Value}">${t.Text}</option>`).join('');

                var html = `
                    <div class="col-12 embalagem-item">
                        <div class="p-4 rounded-4 position-relative" style="background: rgba(0,0,0,0.02); border: 1px solid rgba(255,255,255,0.1);">
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 mt-3 me-3 remover-embalagem rounded-circle shadow-sm">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold opacity-75">Tipo</label>
                                    <select name="Embalagens[${index}].TipoEmbalagemId" class="form-select">${options}</select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold opacity-75">Preço</label>
                                    <input name="Embalagens[${index}].Preco" class="form-control" placeholder="0,00" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold opacity-75">Código EAN</label>
                                    <input name="Embalagens[${index}].Ean" class="form-control" placeholder="789..." />
                                </div>
                            </div>
                        </div>
                    </div>`;

                container.insertAdjacentHTML('beforeend', html);
            });

            // Função para Remover (Delegada ao container)
            container.addEventListener('click', function (e) {
                // Verifica se clicou no botão ou no ícone dentro do botão
                if (e.target.classList.contains('remover-embalagem') || e.target.closest('.remover-embalagem')) {
                    var item = e.target.closest('.embalagem-item');
                    item.style.opacity = '0';
                    item.style.transform = 'scale(0.9)';
                    item.style.transition = '0.2s';
                    
                    setTimeout(() => {
                        item.remove();
                        // Reindexar os inputs para o ASP.NET não se perder no POST
                        reindexarEmbalagens();
                    }, 200);
                }
            });

            function reindexarEmbalagens() {
                container.querySelectorAll('.embalagem-item').forEach((item, idx) => {
                    item.querySelectorAll('select, input').forEach(input => {
                        let name = input.getAttribute('name');
                        if (name) {
                            input.setAttribute('name', name.replace(/\[\d+\]/, `[${idx}]`));
                        }
                    });
                });
            }
        });
    </script>
}
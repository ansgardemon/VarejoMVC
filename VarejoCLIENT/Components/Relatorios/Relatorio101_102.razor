@using VarejoSHARED.DTO
@using VarejoSHARED.DTO.Relatorios
@using VarejoCLIENT.Services
@inject RelatorioService RelService

<RelatorioFiltro OnSearch="ExecutarBusca" OnClear="Limpar" OnExport="Exportar">
    <ChildContent>
        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <label class="form-label">Situação</label>
                @* CORREÇÃO: Usando 'filtroProdutos' ao invés de 'filtro' *@
                <select class="form-select"
                        value="@(filtroProdutos.Ativo == null ? "" : filtroProdutos.Ativo.Value.ToString().ToLower())"
                        @onchange="@(e => filtroProdutos.Ativo = string.IsNullOrEmpty(e.Value?.ToString()) ? null : bool.Parse(e.Value.ToString()!))">
                    <option value="true">Ativos</option>
                    <option value="false">Inativos</option>
                    <option value="">Todos</option>
                </select>
            </div>
        </div>
    </ChildContent>

    <BarraPesquisa>
        <div class="row g-3">
            <div class="col-md-6 col-lg-3">
                <RelatorioFiltroMultiSelect TItem="ProdutoDTO" Titulo="Produtos" IconeClass="fa-solid fa-box" Itens="listaTodosProdutos" GetId="p => p.IdProduto.ToString()" GetNome="p => p.NomeProduto" Selecionados="selecionadosProdutos101" SelecionadosChanged="v => selecionadosProdutos101 = v" />
            </div>
            <div class="col-md-6 col-lg-3">
                <RelatorioFiltroMultiSelect TItem="CategoriaOutputDTO" Titulo="Categorias" IconeClass="fa-solid fa-tags" Itens="listaCategorias" GetId="c => c.IdCategoria.ToString()" GetNome="c => c.DescricaoCategoria" Selecionados="selecionadosCategorias" SelecionadosChanged="v => selecionadosCategorias = v" />
            </div>
            <div class="col-md-6 col-lg-3">
                <RelatorioFiltroMultiSelect TItem="MarcaOutputDTO" Titulo="Marcas" IconeClass="fa-solid fa-copyright" Itens="listaMarcas" GetId="m => m.IdMarca.ToString()" GetNome="m => m.NomeMarca" Selecionados="selecionadosMarcas" SelecionadosChanged="v => selecionadosMarcas = v" />
            </div>
            <div class="col-md-6 col-lg-3">
                <RelatorioFiltroMultiSelect TItem="FamiliaOutputDTO" Titulo="Famílias" IconeClass="fa-solid fa-users" Itens="listaFamilias" GetId="f => f.IdFamilia.ToString()" GetNome="f => f.NomeFamilia" Selecionados="selecionadosFamilias" SelecionadosChanged="v => selecionadosFamilias = v" />
            </div>
        </div>
    </BarraPesquisa>
</RelatorioFiltro>

<div class="mt-4">
    @if (loading)
    {
        <div class="text-center p-5 glass-card">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 fw-bold text-primary">Processando dados...</p>
        </div>
    }
    else
    {
        @if (Codigo == 101 && listaProdutos != null && listaProdutos.Any())
        {
            <div class="glass-card overflow-hidden">
                <RelatorioTabelaDinamica TItem="ProdutoDTO" Dados="listaProdutos" Colunas="colunasProdutos" />
            </div>
        }
        else if (Codigo == 102 && lista102 != null && lista102.Any())
        {
            <div class="glass-card overflow-hidden">
                <RelatorioTabelaDinamica TItem="Relatorio102DTO" Dados="lista102" Colunas="colunas102" />
            </div>
        }
        else if (dadosVazios)
        {
            <div class="p-5 text-center glass-card">
                <i class="fa-solid fa-folder-open fa-2x mb-3 text-muted opacity-50"></i>
                <h5 class="fw-bold" style="color: var(--ui-text-primary);">Nenhum registro encontrado</h5>
                <p class="mb-0" style="color: var(--ui-text-secondary);">Tente ajustar os filtros informados para obter resultados.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Codigo { get; set; }
    [Parameter] public RelatorioDefinicaoDTO Definicao { get; set; }

    private bool loading = false;
    private bool dadosVazios = false;

    private RelatorioFiltroProdutosDTO filtroProdutos = new();
    private List<ProdutoDTO>? listaProdutos;
    private List<Relatorio102DTO>? lista102;
    private List<ProdutoDTO> listaTodosProdutos = new();
    private List<CategoriaOutputDTO> listaCategorias = new();
    private List<MarcaOutputDTO> listaMarcas = new();
    private List<FamiliaOutputDTO> listaFamilias = new();

    private List<string> selecionadosCategorias = new();
    private List<string> selecionadosMarcas = new();
    private List<string> selecionadosFamilias = new();
    private List<string> selecionadosProdutos101 = new();

    private List<RelatorioTabelaDinamica<ProdutoDTO>.ConfigColuna> colunasProdutos = new() {
        new() { Titulo = "ID", Propriedade = "IdProduto" },
        new() { Titulo = "Produto", Propriedade = "NomeProduto" },
        new() { Titulo = "Categoria", Propriedade = "DescricaoCategoria" },
        new() { Titulo = "Marca", Propriedade = "NomeMarca" },
        new() { Titulo = "Estoque", Propriedade = "EstoqueAtual", Formato = "N2" },
        new() { Titulo = "Custo", Propriedade = "CustoMedio", Formato = "C2" }
    };

    private List<RelatorioTabelaDinamica<Relatorio102DTO>.ConfigColuna> colunas102 = new() {
        new() { Titulo = "ID", Propriedade = "IdProduto" },
        new() { Titulo = "Produto", Propriedade = "NomeProduto" },
        new() { Titulo = "Emb.", Propriedade = "Embalagem" },
        new() { Titulo = "Custo Médio", Propriedade = "CustoMedio", Formato = "C2" },
        new() { Titulo = "Preço Venda", Propriedade = "PrecoVenda", Formato = "C2" },
        new() { Titulo = "Margem (%)", Propriedade = "MargemBruta", Formato = "N2" },
        new() { Titulo = "Markup (%)", Propriedade = "Markup", Formato = "N2" }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            listaCategorias = await RelService.GetCategoriasAsync() ?? new();
            listaMarcas = await RelService.GetMarcasAsync() ?? new();
            listaFamilias = await RelService.GetFamiliasAsync() ?? new();
            listaTodosProdutos = await RelService.GetDadosRelatorio101Async(new RelatorioFiltroProdutosDTO()) ?? new();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task ExecutarBusca()
    {
        loading = true; dadosVazios = false; StateHasChanged();
        try
        {
            filtroProdutos.CategoriasIds = selecionadosCategorias.Select(int.Parse).ToList();
            filtroProdutos.MarcasIds = selecionadosMarcas.Select(int.Parse).ToList();
            filtroProdutos.FamiliasIds = selecionadosFamilias.Select(int.Parse).ToList();
            filtroProdutos.ProdutosIds = selecionadosProdutos101.Select(int.Parse).ToList();

            if (Codigo == 101)
            {
                listaProdutos = await RelService.GetDadosRelatorio101Async(filtroProdutos);
                dadosVazios = listaProdutos == null || !listaProdutos.Any();
            }
            else if (Codigo == 102)
            {
                lista102 = await RelService.GetDadosRelatorio102Async(filtroProdutos);
                dadosVazios = lista102 == null || !lista102.Any();
            }
        }
        finally { loading = false; StateHasChanged(); }
    }

    private void Limpar()
    {
        listaProdutos = null; lista102 = null; filtroProdutos = new();
        selecionadosCategorias.Clear(); selecionadosMarcas.Clear();
        selecionadosFamilias.Clear(); selecionadosProdutos101.Clear();
        dadosVazios = false; StateHasChanged();
    }

    private async Task Exportar(string formato)
    {
        loading = true; StateHasChanged();
        try
        {
            filtroProdutos.CategoriasIds = selecionadosCategorias.Select(int.Parse).ToList();
            filtroProdutos.MarcasIds = selecionadosMarcas.Select(int.Parse).ToList();
            filtroProdutos.FamiliasIds = selecionadosFamilias.Select(int.Parse).ToList();
            filtroProdutos.ProdutosIds = selecionadosProdutos101.Select(int.Parse).ToList();

            await RelService.DownloadPdfAsync(Codigo, Definicao.Nome, filtroProdutos);
        }
        finally { loading = false; StateHasChanged(); }
    }
}
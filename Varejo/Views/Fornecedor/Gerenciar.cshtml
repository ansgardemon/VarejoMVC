@model IEnumerable<Varejo.Models.Familia>
@{
    var fornecedor = (Varejo.Models.Pessoa)ViewBag.Fornecedor;
    ViewData["Title"] = "Gerenciar Famílias";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Fornecedores</a></li>
            <li class="breadcrumb-item active text-uppercase fw-bold">@fornecedor.NomeRazao</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="fas fa-search-plus me-2"></i>Vincular Nova Família</h6>
                </div>
                <div class="card-body">
                    <div class="position-relative">
                        <label class="small fw-bold text-muted mb-2 text-uppercase">Pesquisar Categoria/Família</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-layer-group text-primary"></i></span>
                            <input type="text" id="buscaFamilia" class="form-control border-start-0 shadow-none"
                                   placeholder="Ex: Cervejas, Vinhos..." autocomplete="off" />
                        </div>

                        <div id="containerResultadosFamilia" class="position-absolute w-100 shadow-lg d-none mt-1"
                             style="z-index: 1050; max-height: 300px; overflow-y: auto; background: white; border: 1px solid #dee2e6; border-radius: 8px;">
                        </div>
                    </div>
                    
                    <form id="formVincular" asp-action="VincularFamilia" method="post">
                        <input type="hidden" name="pessoaId" value="@fornecedor.IdPessoa" />
                        <input type="hidden" id="inputFamiliaId" name="familiaId" />
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <h5 class="fw-bold text-secondary mb-3 text-uppercase" style="font-size: 0.9rem;">Famílias Vinculadas a este Fornecedor</h5>
            @if (!Model.Any())
            {
                <div class="alert alert-light border text-center py-4">
                    <i class="fas fa-info-circle text-muted mb-2"></i>
                    <p class="mb-0 text-muted">Nenhuma família vinculada. Use a busca ao lado para adicionar.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="card mb-2 border-0 shadow-sm border-start border-4 border-primary">
                        <div class="card-body py-2 px-3">
                            <div class="row align-items-center">
                                <div class="col">
                                    <h6 class="mb-0 fw-bold">@item.NomeFamilia</h6>
                                    <span class="badge bg-light text-secondary border small" style="font-size: 0.7rem;">
                                        ID: @item.IdFamilia
                                    </span>
                                </div>
                                <div class="col-auto">
                                    <a asp-action="ConfigurarGrade" asp-route-pessoaId="@fornecedor.IdPessoa" asp-route-familiaId="@item.IdFamilia"
                                           class="btn btn-sm btn-outline-primary border-0" title="Configurar De-Para">
                                        <i class="fas fa-th"></i>
                                    </a>
                                    <form asp-action="RemoverFamilia" method="post" class="d-inline">
                                        <input type="hidden" name="pessoaId" value="@fornecedor.IdPessoa" />
                                        <input type="hidden" name="familiaId" value="@item.IdFamilia" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('Desvincular?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('buscaFamilia').addEventListener('input', function(e) {
            const termo = e.target.value;
            const container = document.getElementById('containerResultadosFamilia');
        
            if (termo.length < 2) {
                container.classList.add('d-none');
                return;
            }

            fetch('/Fornecedor/BuscarFamilias?termo=' + encodeURIComponent(termo))
                .then(res => res.json())
                .then(data => {
                    container.innerHTML = '';
                    if (!data || data.length === 0) {
                        container.innerHTML = '<div class="p-3 text-center small text-muted">Nenhuma família encontrada.</div>';
                        container.classList.remove('d-none');
                        return;
                    }

                    data.forEach(f => {
                        const div = document.createElement('div');
                        div.className = 'p-2 border-bottom border-primary-hover';
                        div.style.cursor = 'pointer';
                        div.innerHTML = `
                            <div class="d-flex justify-content-between align-items-center px-2">
                                <div>
                                    <div class="fw-bold text-dark" style="font-size: 0.85rem;">${f.nomeFamilia}</div>
                                    <div class="text-muted small">${f.categoria}</div>
                                </div>
                                <i class="fas fa-plus text-primary small"></i>
                            </div>`;
                        
                        div.onclick = () => {
                            document.getElementById('inputFamiliaId').value = f.idFamilia;
                            document.getElementById('formVincular').submit();
                        };
                        container.appendChild(div);
                    });
                    container.classList.remove('d-none');
                });
        });

        // Clique fora para fechar
        document.addEventListener('click', function(e) {
            if (!document.getElementById('buscaFamilia').contains(e.target)) {
                document.getElementById('containerResultadosFamilia').classList.add('d-none');
            }
        });
    </script>
}
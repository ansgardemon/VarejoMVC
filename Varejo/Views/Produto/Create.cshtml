@model Varejo.ViewModels.ProdutoViewModel

@{
    ViewData["Title"] = "Adicionar Produto";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 900px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-box-archive fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form id="produto-form" asp-action="Create" enctype="multipart/form-data" method="post">
            <input type="hidden" asp-for="FamiliaId" />
            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold opacity-75">Família</label>
                    <input class="form-control form-control-lg" value="@ViewBag.NomeFamilia" disabled style="background: rgba(0,0,0,0.05)!important;" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Complemento" class="form-label fw-bold opacity-75"></label>
                    <input asp-for="Complemento" class="form-control form-control-lg" placeholder="Ex: Sabor Uva, 500ml, Edição Limitada..." />
                    <span asp-validation-for="Complemento" class="text-danger small fw-semibold"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="ImagemUpload" class="form-label fw-bold opacity-75">Imagem do Produto</label>
                    <input asp-for="ImagemUpload" class="form-control" type="file" />
                </div>
                <div class="col-md-4">
                    <label class="btn-check-glass toggle-ativo w-100 mt-4">
                        <input asp-for="Ativo" type="checkbox" checked />
                        <div class="check-content">
                            <span class="if-checked"><i class="fa-solid fa-circle-check me-2"></i>Produto Ativo</span>
                            <span class="if-not-checked"><i class="fa-solid fa-circle-xmark me-2"></i>Produto Inativo</span>
                        </div>
                    </label>
                </div>
            </div>

            <div class="d-flex align-items-center mb-3">
                <i class="fa-solid fa-layer-group fs-4 me-2 text-primary"></i>
                <h5 class="fw-bold mb-0">Embalagens / Preços</h5>
                <button type="button" id="adicionar-embalagem" class="btn btn-sm btn-glass border-0 ms-3" style="background: rgba(0,0,0,0.05);">
                    <i class="fa-solid fa-plus me-1"></i> Nova Embalagem
                </button>
            </div>

            <div id="embalagens-container" class="row g-3 mb-4">
                @if (Model.Embalagens != null && Model.Embalagens.Any())
                {
                    @for (int i = 0; i < Model.Embalagens.Count; i++)
                    {
                        <div class="col-12 embalagem-item animate__animated animate__fadeIn">
                            <div class="p-4 rounded-4 position-relative" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 mt-3 me-3 remover-embalagem rounded-circle shadow-sm">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold opacity-75">Tipo</label>
                                        <select name="Embalagens[@i].TipoEmbalagemId" class="form-select">
                                            @foreach (var t in Model.Embalagens[i].TiposEmbalagem)
                                            {
                                                <option value="@t.Value" selected="@t.Selected">@t.Text</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold opacity-75">Preço</label>
                                        <input name="Embalagens[@i].Preco" class="form-control" value="@Model.Embalagens[i].Preco" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold opacity-75">Código EAN</label>
                                        <input name="Embalagens[@i].Ean" class="form-control" value="@Model.Embalagens[i].Ean" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top border-secondary border-opacity-25">
                <a asp-action="Details" asp-controller="Familia" asp-route-id="@Model.FamiliaId" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk"></i> Salvar Produto
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var container = document.getElementById('embalagens-container');
            var tipos = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                            (Model.Embalagens != null && Model.Embalagens.Any()) ? Model.Embalagens[0].TiposEmbalagem : new List<SelectListItem>()
                    ));

            document.getElementById('adicionar-embalagem').addEventListener('click', function () {
                var index = container.querySelectorAll('.embalagem-item').length;
                var options = tipos.map(t => `<option value="${t.Value}">${t.Text}</option>`).join('');
                var html = `
                <div class="col-12 embalagem-item animate__animated animate__fadeIn">
                    <div class="p-4 rounded-4 position-relative" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 mt-3 me-3 remover-embalagem rounded-circle shadow-sm"><i class="fa-solid fa-xmark"></i></button>
                        <div class="row g-3">
                            <div class="col-md-4"><label class="form-label small fw-bold opacity-75">Tipo</label><select name="Embalagens[${index}].TipoEmbalagemId" class="form-select">${options}</select></div>
                            <div class="col-md-4"><label class="form-label small fw-bold opacity-75">Preço</label><input name="Embalagens[${index}].Preco" class="form-control" /></div>
                            <div class="col-md-4"><label class="form-label small fw-bold opacity-75">Código EAN</label><input name="Embalagens[${index}].Ean" class="form-control" /></div>
                        </div>
                    </div>
                </div>`;
                container.insertAdjacentHTML('beforeend', html);
            });

            container.addEventListener('click', function (e) {
                if (e.target.closest('.remover-embalagem')) { e.target.closest('.embalagem-item').remove(); }
            });
        });
    </script>
}
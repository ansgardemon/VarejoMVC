@model Varejo.ViewModels.TituloFinanceiroViewModel

@{
    ViewData["Title"] = "Editar Título";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 800px;">

        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-warning border-opacity-25">
            <i class="fa-solid fa-pen-to-square fs-3 me-3 text-warning"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="IdTituloFinanceiro" />

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Documento" class="form-label fw-bold opacity-75">Documento</label>
                    <input asp-for="Documento" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Parcela" class="form-label fw-bold opacity-75">Parcela</label>
                    <input asp-for="Parcela" class="form-control form-control-lg" />
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Valor" class="form-label fw-bold opacity-75">Valor Total</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0">R$</span>
                    <input asp-for="Valor" class="form-control form-control-lg border-start-0 ps-0 text-success fw-bold" />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="DataEmissao" class="form-label fw-bold opacity-75">Data Emissão</label>
                    <input asp-for="DataEmissao" type="date" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DataVencimento" class="form-label fw-bold opacity-75 text-danger">Data Vencimento</label>
                    <input asp-for="DataVencimento" type="date" class="form-control form-control-lg" />
                </div>
            </div>

            <div class="mb-5">
                <label asp-for="Observacao" class="form-label fw-bold opacity-75">Observação</label>
                <textarea asp-for="Observacao" class="form-control form-control-lg" rows="3"></textarea>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-warning border-0 text-dark">
                    <i class="fa-solid fa-floppy-disk"></i> Atualizar Dados
                </button>
            </div>

        </form>
    </div>
</div>
@model IEnumerable<Varejo.Models.Venda>

@{
    ViewData["Title"] = "Gestão de Vendas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-secondary">
        <i class="fas fa-cash-register me-2"></i>Movimentação de Vendas
    </h2>
    <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
        <i class="fas fa-plus-circle me-1"></i> Nova Venda (Balcão)
    </a>
</div>

<div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-uppercase">Período</label>
                <div class="input-group input-group-sm">
                    <input type="date" name="inicio" class="form-control" value="@Context.Request.Query["inicio"]">
                    <span class="input-group-text">até</span>
                    <input type="date" name="fim" class="form-control" value="@Context.Request.Query["fim"]">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-uppercase">Cliente / ID</label>
                <input type="text" name="busca" class="form-control form-control-sm" placeholder="Nome ou número da venda..." value="@Context.Request.Query["busca"]">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold text-uppercase">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="faturada">Faturada</option>
                    <option value="aberta">Aberta</option>
                </select>
            </div>
            <div class="col-md-4 text-end">
                <button type="submit" class="btn btn-primary btn-sm px-4">
                    <i class="fas fa-filter me-1"></i> Filtrar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">
                    <i class="fas fa-eraser me-1"></i> Limpar
                </a>
            </div>
        </form>
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3"># ID</th>
                    <th>Data / Hora</th>
                    <th>Cliente</th>
                    <th class="text-end">Valor Bruto</th>
                    <th class="text-end text-danger">Desconto</th>
                    <th class="text-end pe-3">Total Líquido</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3"><span class="badge bg-secondary">@item.IdVenda.ToString("D5")</span></td>
                        <td>
                            <div class="d-flex flex-column">
                                <span class="fw-bold">@item.DataVenda.ToShortDateString()</span>
                                <small class="text-muted">@item.DataVenda.ToShortTimeString()</small>
                            </div>
                        </td>
                        <td>
                            <i class="fas fa-user-circle text-muted me-1"></i>
                            @(item.Pessoa?.NomeRazao ?? "Consumidor Final")
                        </td>
                        <td class="text-end text-muted">@item.ValorSubtotal.ToString("C2")</td>
                        <td class="text-end text-danger small">- @item.DescontoTotal.ToString("C2")</td>
                        <td class="text-end pe-3 fw-bold text-primary">@item.ValorFinal.ToString("C2")</td>
                        <td class="text-center">
                            @if (item.Finalizada)
                            {
                                <span class="badge rounded-pill bg-success-subtle text-success border border-success">
                                    <i class="fas fa-file-invoice-dollar me-1"></i> Faturada
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning">
                                    <i class="fas fa-hourglass-half me-1"></i> Aberta
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.IdVenda" class="btn btn-sm btn-outline-info" title="Visualizar">
                                    <i class="fas fa-search"></i>
                                </a>
                                <a asp-action="Print" asp-route-id="@item.IdVenda" target="_blank" class="btn btn-sm btn-outline-dark" title="Imprimir Cupom">
                                    <i class="fas fa-print"></i>
                                </a>
                                @if (!item.Finalizada)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Cancelar Pedido">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
        <p class="text-muted fs-5">Nenhuma venda encontrada para os filtros aplicados.</p>
    </div>
}
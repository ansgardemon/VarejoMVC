@model Varejo.ViewModels.TipoEmbalagemViewModel

@{
    ViewData["Title"] = "Novo Tipo de Embalagem";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-box-open fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="mb-4">
                <label asp-for="DescricaoTipoEmbalagem" class="form-label fw-bold opacity-75"></label>
                <input asp-for="DescricaoTipoEmbalagem" class="form-control form-control-lg" placeholder="Ex: Fardo, Caixa, Unidade..." />
                <span asp-validation-for="DescricaoTipoEmbalagem" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Multiplicador" class="form-label fw-bold opacity-75"></label>
                <input asp-for="Multiplicador" class="form-control form-control-lg" placeholder="Quantidade de itens base (Ex: 12)" />
                <span asp-validation-for="Multiplicador" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk"></i> Salvar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
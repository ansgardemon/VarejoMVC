@page "/relatorio/{Codigo:int}"
@using VarejoSHARED.DTO
@using VarejoSHARED.DTO.Relatorios
@using VarejoCLIENT.Services
@using VarejoCLIENT.Components.Relatorios
@inject RelatorioService RelService
@inject NavigationManager Nav

<main class="container-fluid py-4">
    @if (definicao != null)
    {
        @* HEADER (Fica na página pai, pois é igual para todos) *@
        <div class="card p-3 mb-4 border-0 shadow-sm" style="background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); border: 1px solid var(--glass-border) !important;">
            <div class="d-flex align-items-center">
                <button class="btn btn-sm me-3" style="background: rgba(255,255,255,0.2); border: 1px solid var(--glass-border);" @onclick='() => Nav.NavigateTo("/relatorios")'>
                    <i class="fa-solid fa-chevron-left" style="color: var(--sys-primary);"></i>
                </button>
                <h3 class="mb-0 fw-bold" style="color: var(--sys-primary);">
                    <span class="badge" style="background: var(--sys-primary); color: white; margin-right: 0.5rem;">#@definicao.Codigo</span> @definicao.Nome
                </h3>
            </div>
        </div>

        @* ROTEADOR DINÂMICO (Chama o componente certo baseado no código) *@
        @if (ObterComponenteDoRelatorio() != null)
        {
            <DynamicComponent Type="@ObterComponenteDoRelatorio()" Parameters="@componentParameters" />
        }
        else
        {
            <div class="alert alert-warning">Relatório não implementado ou em desenvolvimento.</div>
        }
    }
</main>

@code {
    [Parameter] public int Codigo { get; set; }
    private RelatorioDefinicaoDTO? definicao;
    private Dictionary<string, object> componentParameters = new();

    protected override async Task OnParametersSetAsync()
    {
        definicao = await RelService.GetDefinicaoAsync(Codigo);
        
        // Passa os dados para o componente filho que for renderizado
        componentParameters = new Dictionary<string, object>
        {
            { "Codigo", Codigo },
            { "Definicao", definicao }
        };
    }

    // A MÁGICA ACONTECE AQUI: Devolve o componente correto para renderizar
    private Type? ObterComponenteDoRelatorio()
    {
        return Codigo switch
        {
            101 or 102 => typeof(Relatorio101_102),
            103 => typeof(Relatorio103),
            104 => typeof(Relatorio104),
            105 => typeof(Relatorio105),
            106 => typeof(Relatorio106),
            107 => typeof(Relatorio107),
            201 => typeof(Relatorio201),
            202 => typeof(Relatorio202),
            203 => typeof(Relatorio203),
            204 => typeof(Relatorio204),
            205 => typeof(Relatorio205),
            206 => typeof(Relatorio206),
            207 => typeof(Relatorio207),
            208 => typeof(Relatorio208),
            301 => typeof(Relatorio301),
            _ => null
        };
    }
}
@model Varejo.ViewModels.VendaViewModel

<div class="container-fluid mt-4">

    <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold shadow-sm mb-4">
        <i class="fa-solid fa-triangle-exclamation me-2"></i> <strong>Atenção:</strong> Verifique os erros abaixo.
    </div>

    <form asp-action="Create" id="formVenda" method="post">
        <div class="row g-4">
            
            <div class="col-lg-9">
                
                <div class="glass-card mb-4 p-4 position-relative" style="border-left: 4px solid var(--sys-primary-light); z-index: 1050;">
                    <h6 class="fw-bold mb-3 text-uppercase opacity-75"><i class="fa-solid fa-id-card me-2"></i>1. Identificação da Venda</h6>
                    <div class="row g-3">
                        
                        <div class="col-md-6 position-relative">
                            <label class="form-label fw-bold small opacity-75">CLIENTE</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-user"></i></span>
                                <input type="text" id="buscaCliente" class="form-control form-control-lg border-start-0 ps-0" placeholder="Pesquisar cliente (ou deixe em branco)...">
                            </div>
                            <input type="hidden" asp-for="PessoaId" id="PessoaId">
                            
                                <div id="containerCardsCliente" class="position-absolute w-100 mt-1 d-none rounded-4 p-2 shadow-lg" style="background: var(--glass-bg); backdrop-filter: blur(40px); border: 1px solid var(--glass-border); z-index: 9999; max-height: 300px; overflow-y: auto;"></div>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="FormaPagamentoId" class="form-label small fw-bold opacity-75">PAGAMENTO</label>
                                <select asp-for="FormaPagamentoId" class="form-select form-control-lg" asp-items="ViewBag.FormasPagamento"></select>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="PrazoPagamentoId" class="form-label small fw-bold opacity-75">PRAZO</label>
                                <select asp-for="PrazoPagamentoId" class="form-select form-control-lg" asp-items="ViewBag.PrazosPagamento"></select>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card mb-4 p-4 position-relative" style="z-index: 1040;">
                        <h6 class="fw-bold mb-3 text-uppercase text-primary"><i class="fa-solid fa-barcode me-2"></i>2. Lançar Produtos</h6>
                        <div class="input-group mb-3">
                            <span class="input-group-text bg-primary text-white border-primary"><i class="fa-solid fa-magnifying-glass"></i></span>
                            <input type="text" id="produtoSearch" class="form-control form-control-lg border-primary" placeholder="Digite o nome ou código do produto..." style="background: rgba(var(--sys-primary-rgb, 79, 172, 254), 0.05);" />
                        </div>
                        <div class="row g-3" id="produtoCards"></div>
                    </div>

                    <div class="glass-card p-0 overflow-hidden">
                        <div class="p-3 bg-dark bg-opacity-10 border-bottom border-secondary border-opacity-25">
                            <h6 class="mb-0 fw-bold"><i class="fa-solid fa-basket-shopping me-2"></i>Itens do Pedido</h6>
                        </div>
                        <div class="table-responsive" style="min-height: 250px;">
                            <table class="table-glass align-middle mb-0" id="tabelaItens">
                                <thead class="opacity-75">
                                    <tr>
                                        <th class="ps-4">Produto</th>
                                        <th>Embalagem</th>
                                        <th class="text-center">Qtd</th>
                                        <th class="text-end">Unitário</th>
                                        <th class="text-end">Desc. Tot.</th>
                                        <th class="text-end">Subtotal</th>
                                        <th class="pe-4"></th>
                                    </tr>
                                </thead>
                                <tbody id="produtosSelecionadosBody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3">
                    <div class="glass-card sticky-top text-center" style="top: 20px; border: 2px solid var(--sys-primary-light);">
                        <h6 class="text-uppercase opacity-75 fw-bold mb-3">Total a Pagar</h6>
                        <h1 class="display-5 fw-bold text-success mb-4" id="resumoTotal" style="text-shadow: 0 0 20px rgba(40,167,69,0.3);">R$ 0,00</h1>
                    
                        <div class="p-3 rounded-4 mb-4 text-start" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                            <div class="d-flex justify-content-between small fw-bold mb-2">
                                <span class="opacity-75">Subtotal Bruto:</span> <span id="resumoSubtotal">R$ 0,00</span>
                            </div>
                            <div class="d-flex justify-content-between small fw-bold text-danger">
                                <span class="opacity-75">Descontos:</span> <span id="resumoDesconto">R$ 0,00</span>
                            </div>
                        </div>
                    
                        <input type="hidden" asp-for="DescontoTotal" id="inputDescontoTotalFinal">

                            <button type="submit" class="btn-glass btn-success w-100 py-3 fs-5 fw-bold text-white border-0 shadow-lg">
                                <i class="fa-solid fa-circle-check me-2"></i> FINALIZAR
                            </button>
                    
                            <a asp-action="Index" class="btn btn-link text-decoration-none mt-3 text-muted w-100 fw-bold">Cancelar Operação</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        @section Scripts {
            <script>
                const containerProdutosBody = document.getElementById('produtosSelecionadosBody');
                const containerProdutoCards = document.getElementById('produtoCards');
                const produtoSearch = document.getElementById('produtoSearch');
                let itensVenda = [];
                let debounceTimer;

                // --- BUSCA DE PRODUTOS ---
                produtoSearch.addEventListener('input', function () {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(async () => {
                        const termo = produtoSearch.value.trim();
                        if (termo.length < 2) {
                            containerProdutoCards.innerHTML = '';
                            return;
                        }

                        try {
                            const response = await fetch('@Url.Action("BuscarProdutos", "Venda")?termo=' + encodeURIComponent(termo));
                            const produtos = await response.json();
                            containerProdutoCards.innerHTML = '';

                            produtos.forEach(produto => {
                                const imagem = produto.UrlImagem || '/imagens/default.png';
                                const col = document.createElement('div');
                                col.className = 'col-xl-4 col-md-6 mb-3 animate__animated animate__fadeIn';
                        
                                col.innerHTML = `
                                    <div class="p-3 rounded-4 h-100 d-flex flex-column" style="background: var(--glass-bg); border: 1px solid var(--glass-border); transition: 0.2s;">
                                        <div class="text-center mb-3">
                                            <img src="${imagem}" class="rounded-3" style="height:90px; object-fit:contain; mix-blend-mode: multiply;" onerror="this.src='/imagens/default.png'">
                                        </div>
                                        <h6 class="fw-bold mb-3 text-truncate" title="${produto.NomeProduto}">${produto.NomeProduto}</h6>
                                
                                        <div class="mb-2">
                                            <label class="small fw-bold opacity-75">Embalagem</label>
                                            <select class="form-select form-select-sm sel-emb bg-transparent">
                                                ${produto.Embalagens.map(e => `
                                                    <option value="${e.IdProdutoEmbalagem}" data-preco="${e.Preco}">
                                                        ${e.TipoEmbalagemDescricao ?? 'Unid'} - R$ ${Number(e.Preco).toFixed(2)}
                                                    </option>
                                                `).join('')}
                                            </select>
                                        </div>
                                
                                        <div class="row g-2 mb-3">
                                            <div class="col-6">
                                                <label class="small fw-bold opacity-75">Qtd</label>
                                                <input type="number" class="form-control form-control-sm inp-qtd bg-transparent fw-bold text-center" value="1" min="0.001">
                                            </div>
                                            <div class="col-6">
                                                <label class="small fw-bold text-danger">Desc. R$</label>
                                                <input type="number" class="form-control form-control-sm inp-desc bg-transparent text-danger fw-bold text-center" value="0.00">
                                            </div>
                                        </div>
                                
                                        <button type="button" class="btn btn-sm btn-primary w-100 fw-bold mt-auto btn-add rounded-pill">Adicionar</button>
                                    </div>`;
                        
                                containerProdutoCards.appendChild(col);

                                // Evento Adicionar
                                col.querySelector('.btn-add').addEventListener('click', function() {
                                    const selEmb = col.querySelector('.sel-emb');
                                    const optEmb = selEmb.options[selEmb.selectedIndex];
                                    const qtd = parseFloat(col.querySelector('.inp-qtd').value);
                                    const descUnit = parseFloat(col.querySelector('.inp-desc').value) || 0;
                                    const preco = parseFloat(optEmb.dataset.preco);

                                    const item = {
                                        ProdutoId: produto.IdProduto,
                                        NomeProduto: produto.NomeProduto,
                                        ProdutoEmbalagemId: parseInt(selEmb.value),
                                        NomeEmbalagem: optEmb.text.split('-')[0].trim(),
                                        Quantidade: qtd,
                                        ValorUnitario: preco,
                                        DescontoUnitario: descUnit,
                                        Subtotal: (preco - descUnit) * qtd
                                    };

                                    itensVenda.push(item);
                                    atualizarTabela();
                                    produtoSearch.value = '';
                                    containerProdutoCards.innerHTML = '';
                                    produtoSearch.focus();
                                });
                            });
                        } catch (err) { console.error(err); }
                    }, 300);
                });

                function atualizarTabela() {
                    containerProdutosBody.innerHTML = '';
                    let tBruto = 0; let tDesc = 0;

                    if (itensVenda.length === 0) {
                        containerProdutosBody.innerHTML = `<tr><td colspan="7" class="text-center py-4 opacity-50">Nenhum item adicionado.</td></tr>`;
                    }

                    itensVenda.forEach((item, i) => {
                        const totalDesc = item.DescontoUnitario * item.Quantidade;
                        const subtotalItem = item.Subtotal;
        
                        tBruto += (item.ValorUnitario * item.Quantidade);
                        tDesc += totalDesc;

                        containerProdutosBody.innerHTML += `
                            <tr class="animate__animated animate__fadeIn">
                                <td class="ps-4 fw-bold">
                                    ${item.NomeProduto}
                                    <input type="hidden" name="Itens[${i}].ProdutoId" value="${item.ProdutoId}">
                                    <input type="hidden" name="Itens[${i}].NomeProduto" value="${item.NomeProduto}">
                                </td>
                                <td>
                                    <span class="badge bg-secondary bg-opacity-10 text-dark border border-secondary border-opacity-25">${item.NomeEmbalagem}</span>
                                    <input type="hidden" name="Itens[${i}].ProdutoEmbalagemId" value="${item.ProdutoEmbalagemId}">
                                    <input type="hidden" name="Itens[${i}].NomeEmbalagem" value="${item.NomeEmbalagem}">
                                </td>
                                <td class="text-center fw-bold">
                                    <input type="hidden" name="Itens[${i}].Quantidade" value="${item.Quantidade.toString().replace('.',',')}">
                                    ${item.Quantidade}
                                </td>
                                <td class="text-end opacity-75">
                                    <input type="hidden" name="Itens[${i}].ValorUnitario" value="${item.ValorUnitario.toFixed(2).replace('.',',')}">
                                    R$ ${item.ValorUnitario.toFixed(2)}
                                </td>
                                <td class="text-end text-danger fw-semibold">
                                    <input type="hidden" name="Itens[${i}].DescontoUnitario" value="${item.DescontoUnitario.toFixed(2).replace('.',',')}">
                                    - R$ ${totalDesc.toFixed(2)}
                                </td>
                                <td class="text-end fw-bold text-primary">
                                    <input type="hidden" name="Itens[${i}].Subtotal" value="${subtotalItem.toFixed(2).replace('.',',')}">
                                    R$ ${subtotalItem.toFixed(2)}
                                </td>
                                <td class="pe-4 text-end">
                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-circle" onclick="removerItem(${i})" title="Remover"><i class="fa-solid fa-xmark"></i></button>
                                </td>
                            </tr>`;
                    });

                    const totalFinal = tBruto - tDesc;
                    document.getElementById('resumoSubtotal').innerText = 'R$ ' + tBruto.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    document.getElementById('resumoDesconto').innerText = '- R$ ' + tDesc.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    document.getElementById('resumoTotal').innerText = 'R$ ' + totalFinal.toLocaleString('pt-BR', {minimumFractionDigits: 2});
    
                    const inputDescTotal = document.getElementById('inputDescontoTotalFinal');
                    if(inputDescTotal) inputDescTotal.value = tDesc.toFixed(2).replace('.',',');
                }

                function removerItem(i) {
                    itensVenda.splice(i, 1);
                    atualizarTabela();
                }

                // --- BUSCA DE CLIENTES ---
                document.getElementById('buscaCliente').addEventListener('input', function(e) {
                    const termo = e.target.value;
                    const container = document.getElementById('containerCardsCliente');
    
                    if (termo.length < 2) {
                        container.classList.add('d-none');
                        container.innerHTML = '';
                        return;
                    }

                    fetch('/Venda/BuscarClientes?termo=' + encodeURIComponent(termo))
                        .then(res => res.json())
                        .then(data => {
                            container.innerHTML = '';
                            if (!data || data.length === 0) {
                                container.innerHTML = '<div class="p-2 text-center opacity-50">Nenhum cliente encontrado.</div>';
                                container.classList.remove('d-none');
                                return;
                            }

                            data.forEach(c => {
                                const id = c.IdPessoa || c.idPessoa;
                                const nome = c.NomeRazao || c.nomeRazao;
                                const doc = c.CpfCnpj || c.cpfCnpj || 'S/ Doc';

                                const col = document.createElement('div');
                                col.className = 'col-12 mb-2';
        
                                // AJUSTE AQUI: Removido a classe 'text-dark' para que a cor da letra siga o Dark/Light Mode.
                                col.innerHTML = `
                                    <div class="p-2 rounded-3 item-hover" style="cursor:pointer; transition: 0.2s;">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                                <i class="fa-solid fa-user text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">${nome}</h6>
                                                <small class="opacity-75"><i class="fa-solid fa-id-card me-1"></i> ${doc}</small>
                                            </div>
                                        </div>
                                    </div>`;
        
                                col.onclick = () => {
                                    document.getElementById('PessoaId').value = id;
                                    document.getElementById('buscaCliente').value = nome;
                                    container.classList.add('d-none');
                                    container.innerHTML = '';
                                    document.getElementById('produtoSearch').focus();
                                };
        
                                col.firstElementChild.addEventListener('mouseenter', function(){ this.style.background = 'rgba(79, 172, 254, 0.1)'; });
                                col.firstElementChild.addEventListener('mouseleave', function(){ this.style.background = 'transparent'; });

                                container.appendChild(col);
                            });
                            container.classList.remove('d-none');
                        });
                });
        
                // Esconde drop de clientes ao clicar fora
                document.addEventListener('click', function(e) {
                    const container = document.getElementById('containerCardsCliente');
                    if(!document.getElementById('buscaCliente').contains(e.target) && !container.contains(e.target)){
                        container.classList.add('d-none');
                    }
                });
        
                atualizarTabela(); // Init table state
            </script>
        }
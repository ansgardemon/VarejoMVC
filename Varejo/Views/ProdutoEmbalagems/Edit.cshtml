@model Varejo.Models.ProdutoEmbalagem

@{
    ViewData["Title"] = "Editar Embalagem";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-warning border-opacity-25">
            <i class="fa-solid fa-pen-to-square fs-3 me-3 text-warning"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form asp-action="Edit">
            <input type="hidden" asp-for="IdProdutoEmbalagem" />
            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="mb-3">
                <label asp-for="ProdutoId" class="form-label fw-bold opacity-75">Produto</label>
                <select asp-for="ProdutoId" class="form-select form-control-lg" asp-items="ViewBag.ProdutoId" disabled></select>
                <input type="hidden" asp-for="ProdutoId" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-7">
                    <label asp-for="TipoEmbalagemId" class="form-label fw-bold opacity-75">Tipo</label>
                    <select asp-for="TipoEmbalagemId" class="form-select form-control-lg" asp-items="ViewBag.TipoEmbalagemId"></select>
                </div>
                <div class="col-md-5">
                    <label asp-for="Preco" class="form-label fw-bold opacity-75"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--glass-border);">R$</span>
                        <input asp-for="Preco" class="form-control form-control-lg border-start-0 ps-0" />
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Ean" class="form-label fw-bold opacity-75">EAN</label>
                <input asp-for="Ean" class="form-control form-control-lg" />
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-warning border-0 text-dark">
                    <i class="fa-solid fa-floppy-disk"></i> Atualizar Dados
                </button>
            </div>
        </form>
    </div>
</div>
<div class="col-xl-3 col-md-6 mb-4">
    <div class="glass-card h-100 py-3 px-4 d-flex flex-column justify-content-center" style="border-left: 5px solid @Color !important;">
        <div class="row g-0 align-items-center">
            <div class="col me-2">
                <div class="text-uppercase fw-bold mb-1" style="font-size: 0.75rem; color: var(--ui-text-secondary); letter-spacing: 0.5px;">
                    @Title
                </div>
                <div class="h4 mb-0 fw-bold" style="color: var(--ui-text-primary);">@Value</div>
            </div>
            <div class="col-auto">
                <div class="dashboard-icon-container" style="background-color: @Color;">
                    <i class="@Icon text-white fs-4"></i>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string Color { get; set; } = "var(--sys-primary)";
    [Parameter] public string Icon { get; set; } = "";
}
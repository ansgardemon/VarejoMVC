@model IEnumerable<Varejo.ViewModels.FormaPagamentoViewModel>

@{
    ViewData["Title"] = "Formas de Pagamento";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-credit-card fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Create" class="btn-glass btn-success text-decoration-none border-0 text-white">
                <i class="fa-solid fa-plus"></i>
                <span class="d-none d-sm-inline ms-1">Nova Forma</span>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer; user-select: none;">
                            <div class="d-flex justify-content-between align-items-center">
                                # <i class="fa-solid fa-sort opacity-50 ms-2"></i>
                            </div>
                        </th>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer; user-select: none;">
                            <div class="d-flex justify-content-between align-items-center">
                                Descrição <i class="fa-solid fa-sort opacity-50 ms-2"></i>
                            </div>
                        </th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="#">@item.IdFormaPagamento</td>
                                <td data-label="Descrição" class="fw-semibold">@item.DescricaoFormaPagamento</td>
                                <td data-label="Ações">
                                    <div class="d-flex justify-content-end justify-content-md-center gap-2">
                                        <a asp-action="Delete" asp-route-id="@item.IdFormaPagamento" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Excluir">
                                            <i class="fa-solid fa-trash-can"></i> <span class="d-none d-xl-inline ms-1">Excluir</span>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IdFormaPagamento" class="btn btn-sm btn-warning text-dark rounded-pill px-3" title="Editar">
                                            <i class="fa-solid fa-pen-to-square"></i> <span class="d-none d-xl-inline ms-1">Editar</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center p-4">
                                <i class="fa-solid fa-credit-card fs-1 opacity-25 d-block mb-3"></i>
                                <span class="opacity-75 fw-semibold">Nenhuma forma de pagamento cadastrada.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
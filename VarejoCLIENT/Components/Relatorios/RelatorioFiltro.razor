@* Utilizamos a classe global glass-card e removemos os styles inline *@
<div class="glass-card mb-4 p-4">
    
    <div class="row g-3">
        @ChildContent
    </div>

    @if (BarraPesquisa != null)
    {
        <div class="row mt-3">
            <div class="col-12">
                @BarraPesquisa
            </div>
        </div>
    }

    @* ==========================================
       BARRA DE BOTÕES RESPONSIVA (MOBILE & PC)
       ========================================== *@
    <div class="d-flex flex-column flex-md-row justify-content-md-end gap-3 mt-4 pt-4 border-top" style="border-color: var(--ui-glass-border) !important;">
        
        @* Bloco Secundário (Limpar e Exportar)
           order-2 no mobile (fica embaixo), order-1 no PC (fica à esquerda do Pesquisar) *@
        <div class="d-flex gap-3 flex-grow-1 flex-md-grow-0 order-2 order-md-1">
            
            <button class="btn-glass flex-grow-1" @onclick="OnClear">
                <i class="fa-solid fa-eraser me-1"></i> Limpar
            </button>

            <button class="btn-glass flex-grow-1" @onclick="@(() => BotaoExportarClicado("pdf"))">
                <i class="fa-solid fa-file-pdf me-1"></i> Exportar PDF
            </button>
            
        </div>

        @* Botão Principal (Pesquisar)
           order-1 no mobile (fica no topo), order-2 no PC (fica na extrema direita) *@
        <button class="btn-glass btn-glass-primary flex-grow-1 flex-md-grow-0 order-1 order-md-2" @onclick="OnSearch">
            <i class="fa-solid fa-magnifying-glass me-2"></i> Pesquisar
        </button>

    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? BarraPesquisa { get; set; }
    [Parameter] public EventCallback OnSearch { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }
    [Parameter] public EventCallback<string> OnExport { get; set; }

    private async Task BotaoExportarClicado(string formato)
    {
        await OnExport.InvokeAsync(formato);
    }
}
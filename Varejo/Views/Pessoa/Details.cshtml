@model Varejo.ViewModels.PessoaViewModel

@{
    ViewData["Title"] = "Detalhes da Pessoa";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 1000px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-address-card fs-3 me-3" style="color: var(--sys-primary-light);"></i>
            <h4 class="mb-0 fw-bold">@Model.NomeRazao</h4>
            <div class="ms-auto">
                @if (Model.Ativo)
                {
                    <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25 py-2 mb-0">ATIVO</span>
                }
                else
                {
                    <span class="report-id-badge bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 py-2 mb-0">INATIVO</span>
                }
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <span class="report-id-badge mb-0 @(Model.EhJuridico ? "bg-primary text-white border-primary" : "opacity-50")">
                <i class="fa-solid @(Model.EhJuridico ? "fa-building" : "fa-user") me-2"></i>
                @(Model.EhJuridico ? "PESSOA JURÍDICA" : "PESSOA FÍSICA")
            </span>
            
            <span class="report-id-badge mb-0 @(Model.EhCliente ? "bg-success text-white border-success" : "opacity-25")">
                <i class="fa-solid fa-cart-shopping me-2"></i>CLIENTE
            </span>
            
            <span class="report-id-badge mb-0 @(Model.EhFornecedor ? "bg-warning text-dark border-warning" : "opacity-25")">
                <i class="fa-solid fa-truck me-2"></i>FORNECEDOR
            </span>
            
            <span class="report-id-badge mb-0 @(Model.EhUsuario ? "bg-info text-white border-info" : "opacity-25")">
                <i class="fa-solid fa-user-gear me-2"></i>USUÁRIO DO SISTEMA
            </span>
        </div>

        <div class="row g-3 mb-5">
            <div class="col-md-4">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Documento Principal</small>
                    <span class="fw-bold fs-5">@Model.CpfCnpj</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Contato Telefônico</small>
                    <span class="fw-bold fs-5">(@Model.Ddd) @Model.Telefone</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
                    <small class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Endereço de E-mail</small>
                    <span class="fw-bold fs-5 text-truncate d-block">@Model.Email</span>
                </div>
            </div>
        </div>

        <h5 class="fw-bold mb-3 opacity-75"><i class="fa-solid fa-map-pin me-2"></i>Endereços Cadastrados</h5>
        <div class="table-responsive mb-5">
            <table class="table-glass table-responsive-stack">
                <thead>
                    <tr>
                        <th>Logradouro, Nº</th>
                        <th>Bairro</th>
                        <th>CEP</th>
                        <th>Cidade / UF</th>
                        <th>Complemento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var end in Model.Enderecos)
                    {
                        <tr>
                            <td data-label="Endereço" class="fw-bold">@end.Logradouro, @end.Numero</td>
                            <td data-label="Bairro">@end.Bairro</td>
                            <td data-label="CEP">@end.Cep</td>
                            <td data-label="Localidade">@end.Cidade - @end.Uf</td>
                            <td data-label="Complemento" class="opacity-75">@(string.IsNullOrEmpty(end.Complemento) ? "-" : end.Complemento)</td>
                        </tr>
                    }
                    @if (!Model.Enderecos.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 opacity-50 fw-bold">Nenhum endereço cadastrado para esta pessoa.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
            <a asp-action="Index" class="btn-glass text-decoration-none">
                <i class="fa-solid fa-chevron-left"></i> Voltar
            </a>
            <a asp-action="Edit" asp-route-id="@Model.IdPessoa" class="btn-glass btn-warning text-dark border-0">
                <i class="fa-solid fa-pen-to-square"></i> Editar Cadastro
            </a>
        </div>
    </div>
</div>
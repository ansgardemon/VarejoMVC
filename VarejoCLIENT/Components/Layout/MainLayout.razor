@inherits LayoutComponentBase
@inject NavigationManager Nav
@using VarejoCLIENT.Services
@inject AuthService AuthService

<div class="page @(isDarkMode ? "dark-theme" : "")" data-theme="@(isDarkMode ? "dark" : "light")">
    @if (Nav.Uri.ToLower().EndsWith("/login") || !AuthService.IsAutenticado)
    {
        @* LOGIN: Centralizado, sem colunas ou imagens extras *@
        <div class="login-centered-container">
            @Body
        </div>
    }
    else
    {
        @* BOTÃO FLUTUANTE: Inferior Direito (Mobile) *@
        <button class="menu-fab-btn" @onclick="ToggleMenu">
            <i class="fa-solid @(collapseNavMenu ? "fa-bars-staggered" : "fa-xmark")"></i>
        </button>

        <div class="sidebar-overlay @(collapseNavMenu ? "" : "show")" @onclick="ToggleMenu"></div>

        @* SIDEBAR: Esquerda (PC) / Direita (Mobile) *@
        <aside class="sidebar-varejo @(collapseNavMenu ? "collapsed" : "")">
            <div class="sidebar-header">
                <div class="brand-text">VAREJO <span>GESTOR</span></div>
                <button class="theme-switch" @onclick="ToggleDarkMode">
                    <i class="fa-solid @(isDarkMode ? "fa-sun" : "fa-moon")"></i>
                </button>
            </div>
            <NavMenu OnMenuItemClicked="ToggleMenu" />
        </aside>

        <main class="main-content">
            @Body
        </main>
    }
</div>

@code {
    private bool collapseNavMenu = true;
    private bool isDarkMode = false;
    private void ToggleMenu() => collapseNavMenu = !collapseNavMenu;
    private void ToggleDarkMode() => isDarkMode = !isDarkMode;

    protected override void OnInitialized()
    {
        if (!AuthService.IsAutenticado && !Nav.Uri.ToLower().Contains("/login"))
            Nav.NavigateTo("login");
    }
}
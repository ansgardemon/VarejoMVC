@typeparam TItem

<div class="glass-card mb-4 overflow-hidden">
    @* Cabeçalho da Tabela *@
    <div class="card-header py-3 bg-transparent border-0 border-bottom" style="border-color: var(--ui-glass-border) !important;">
        <h6 class="m-0 fw-bold" style="color: var(--ui-text-primary);">
            <i class="fa-solid fa-table me-2 opacity-75"></i>@Title
        </h6>
    </div>
    
    @* O Corpo usando nosso Motor de Tabela Glass *@
    <div class="glass-table-container">
        <table class="glass-table">
            <thead>
                <tr>
                    @HeaderTemplate
                </tr>
            </thead>
            <tbody>
                @if (Items != null && Items.Any())
                {
                    @foreach (var item in Items)
                    {
                        <tr>@RowTemplate(item)</tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="100%" class="text-center py-4" style="color: var(--ui-text-secondary);">
                            Nenhum dado para exibir no momento.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();
    [Parameter] public RenderFragment HeaderTemplate { get; set; } = default!;
    [Parameter] public RenderFragment<TItem> RowTemplate { get; set; } = default!;
}
@model Varejo.Models.Venda
@{
    ViewData["Title"] = "Confirmar Cancelamento";
}

<div class="container-fluid mt-5">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-danger border-opacity-25">
            <i class="fa-solid fa-triangle-exclamation fs-3 me-3 text-danger"></i>
            <h4 class="mb-0 fw-bold text-danger text-uppercase">Atenção!</h4>
        </div>

        <div class="text-center mb-5">
            <h5 class="fw-bold mb-3">Deseja realmente cancelar e excluir o <strong>Pedido #@Model.IdVenda.ToString("D5")</strong>?</h5>
            <p class="opacity-75 small mb-4">Esta ação é irreversível e removerá todos os itens e o rascunho da venda do sistema.</p>
            
            <div class="p-4 rounded-4 text-start mx-auto" style="background: rgba(220, 53, 69, 0.05); border: 1px dashed rgba(220, 53, 69, 0.3); max-width: 80%;">
                <div class="mb-3">
                    <small class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Cliente Vinculado</small>
                    <span class="fs-5 fw-bold">@(Model.Pessoa?.NomeRazao ?? "Consumidor Final")</span>
                </div>
                <div>
                    <small class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Valor Total da Venda</small>
                    <span class="fs-4 fw-bold text-danger">@Model.ValorSubtotal.ToString("C")</span>
                </div>
            </div>
        </div>

        <form asp-action="Cancelar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.IdVenda" />
            
            <div class="d-flex flex-column gap-3">
                <button type="submit" class="btn-glass btn-danger border-0 w-100 py-3 fs-5 fw-bold text-uppercase">
                    <i class="fa-solid fa-trash-can me-2"></i> Confirmar Exclusão
                </button>
                <a asp-action="Details" asp-route-id="@Model.IdVenda" class="btn-glass text-decoration-none w-100 justify-content-center">
                    Voltar para os detalhes
                </a>
            </div>
        </form>
    </div>
</div>
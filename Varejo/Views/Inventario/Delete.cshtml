@model Varejo.ViewModels.InventarioViewModel

@{
    ViewData["Title"] = "Excluir Inventário";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">@ViewData["Title"]</h5>
        </div>
        <div class="card-body">
            @if (ViewData["DeleteError"] != null)
            {
                <div class="alert alert-danger mt-2">
                    @ViewData["DeleteError"]
                </div>
            }

            <h5>Você tem certeza que deseja excluir este inventário?</h5>
            <p class="text-muted">Apenas inventários sem itens lançados podem ser removidos.</p>
            <hr />
            
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Data</dt>
                <dd class="col-sm-9">@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Observação</dt>
                <dd class="col-sm-9">@Model.Observacao</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-chevron-left"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-trash"></i> Excluir Definitivamente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
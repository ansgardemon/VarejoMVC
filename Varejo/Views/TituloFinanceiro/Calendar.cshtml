@{
    ViewData["Title"] = "Calendário de Títulos";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">📅 Calendário</h5>
        </div>

        <div class="card-body">
            <div id="calendar"></div>
        </div>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('calendar');

        // Certifique-se que o objeto FullCalendar existe
        if (calendarEl) {
            var calendar = new FullCalendar.Calendar(calendarEl, {
                // Na v6, é recomendado usar esse mapeamento de plugins se não estiver usando o bundle global
                initialView: 'dayGridMonth',
                locale: 'pt-br',
                selectable: true,
                editable: false,
                
                // Verifique se essa URL retorna o JSON corretamente (abra no navegador para testar)
                events: '/TituloFinanceiro/GetEventos',

                eventClick: function(info) {
                    info.jsEvent.preventDefault(); // Evita comportamentos estranhos do browser
                    var id = info.event.id;
                    if (id) {
                        window.location.href = '/TituloFinanceiro/Details/' + id;
                    }
                }
            });

            calendar.render();
        }
    });
</script>
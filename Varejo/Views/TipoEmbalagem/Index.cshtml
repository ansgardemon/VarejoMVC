@model IEnumerable<Varejo.ViewModels.TipoEmbalagemViewModel>

@{
    ViewData["Title"] = "Tipos de Embalagem";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-boxes-stacked fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Create" class="btn-glass btn-success text-white text-decoration-none border-0">
                <i class="fa-solid fa-plus"></i>
                <span class="d-none d-sm-inline ms-1">Nova Embalagem</span>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer;" class="ps-md-4">
                            <div class="d-flex justify-content-between align-items-center"># <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center">Descrição <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer;" class="text-md-center">
                            <div class="d-flex justify-content-between align-items-center justify-content-md-center">Multiplicador <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th class="text-center pe-md-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var tipo in Model)
                        {
                            <tr>
                                <td data-label="ID" class="ps-md-4 fw-bold opacity-50">@tipo.IdTipoEmbalagem</td>
                                <td data-label="Descrição" class="fw-semibold">@tipo.DescricaoTipoEmbalagem</td>
                                <td data-label="Multiplicador" class="text-md-center">
                                    <span class="report-id-badge" style="background: rgba(0,0,0,0.05); border-color: transparent;">x @tipo.Multiplicador</span>
                                </td>
                                <td data-label="Ações" class="pe-md-4">
                                    <div class="d-flex justify-content-end justify-content-md-center gap-2">
                                        <a asp-action="Delete" asp-route-id="@tipo.IdTipoEmbalagem" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Excluir">
                                            <i class="fa-solid fa-trash-can"></i> <span class="d-none d-xl-inline ms-1">Excluir</span>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@tipo.IdTipoEmbalagem" class="btn btn-sm btn-warning text-dark rounded-pill px-3" title="Editar">
                                            <i class="fa-solid fa-pen-to-square"></i> <span class="d-none d-xl-inline ms-1">Editar</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center p-5 opacity-50 fw-semibold">
                                <i class="fa-solid fa-box-open d-block fs-1 mb-3"></i>
                                Nenhum tipo de embalagem cadastrado.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
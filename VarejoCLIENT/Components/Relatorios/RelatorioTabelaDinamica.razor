@typeparam TItem
@using System.Reflection

<div class="glass-table-container table-responsive">
    <table class="glass-table">
        <thead>
            <tr>
                @foreach (var coluna in Colunas)
                {
                    <th @onclick="() => OrdenarPor(coluna.Propriedade)"
                        title="Clique para ordenar por @coluna.Titulo">
                        
                        <div class="d-flex align-items-center justify-content-between">
                            <span>@coluna.Titulo</span>
                            
                            @if (colunaOrdenacaoAtual == coluna.Propriedade)
                            {
                                <i class="@(ordemCrescente ? "fa-solid fa-arrow-up" : "fa-solid fa-arrow-down") ms-2 opacity-75"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-sort ms-2 opacity-25"></i>
                            }
                        </div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @if (DadosOrdenados != null && DadosOrdenados.Any())
            {
                @foreach (var item in DadosOrdenados)
                {
                    <tr>
                        @foreach (var coluna in Colunas)
                        {
                            @* O ATRIBUTO data-label É OBRIGATÓRIO AQUI PARA O MOBILE FUNCIONAR *@
                            <td data-label="@coluna.Titulo">
                                @ObterValor(item, coluna.Propriedade, coluna.Formato)
                            </td>
                        }
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="@Colunas.Count" class="text-center py-4" style="opacity: 0.6;">
                        Nenhum registro encontrado.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public List<TItem> Dados { get; set; } = new();
    [Parameter] public List<ConfigColuna> Colunas { get; set; } = new();

    private string colunaOrdenacaoAtual = "";
    private bool ordemCrescente = true;

    // Classe auxiliar para definir as colunas
    public class ConfigColuna
    {
        public string Titulo { get; set; } = "";
        public string Propriedade { get; set; } = "";
        public string Formato { get; set; } = ""; // Ex: "C2" para moeda, "N2" para número, "dd/MM/yyyy" para data
    }

    private IEnumerable<TItem> DadosOrdenados
    {
        get
        {
            if (string.IsNullOrEmpty(colunaOrdenacaoAtual) || !Dados.Any())
                return Dados;

            var propInfo = typeof(TItem).GetProperty(colunaOrdenacaoAtual);
            if (propInfo == null) return Dados;

            return ordemCrescente
                ? Dados.OrderBy(x => propInfo.GetValue(x, null))
                : Dados.OrderByDescending(x => propInfo.GetValue(x, null));
        }
    }

    private void OrdenarPor(string propriedade)
    {
        if (colunaOrdenacaoAtual == propriedade)
        {
            ordemCrescente = !ordemCrescente; // Inverte A-Z para Z-A
        }
        else
        {
            colunaOrdenacaoAtual = propriedade;
            ordemCrescente = true;
        }
    }

    private string ObterValor(TItem item, string propriedade, string formato)
    {
        var propInfo = typeof(TItem).GetProperty(propriedade);
        if (propInfo == null) return "";

        var valor = propInfo.GetValue(item, null);
        if (valor == null) return "-";

        // Se tiver formatação (ex: Moeda), aplica aqui
        if (!string.IsNullOrEmpty(formato) && valor is IFormattable formattable)
        {
            return formattable.ToString(formato, System.Globalization.CultureInfo.CurrentCulture);
        }

        return valor.ToString() ?? "";
    }
}
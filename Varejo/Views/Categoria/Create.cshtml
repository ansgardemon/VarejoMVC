@model Varejo.ViewModels.CategoriaViewModel

@{
    ViewData["Title"] = "Nova Categoria";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-folder-plus fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="mb-4">
                <label asp-for="DescricaoCategoria" class="form-label fw-bold opacity-75"></label>
                <input asp-for="DescricaoCategoria" class="form-control form-control-lg" placeholder="Digite o nome da categoria..." />
                <span asp-validation-for="DescricaoCategoria" class="text-danger small mt-1 d-block fw-semibold"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-check"></i> Salvar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
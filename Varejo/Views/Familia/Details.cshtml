@model Varejo.ViewModels.FamiliaViewModel

@{
    ViewData["Title"] = "Detalhes da Família";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 1200px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-circle-info fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <div class="row g-3 mb-5">
            <div class="col-md-2 col-6">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                    <span class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.75rem;">ID</span>
                    <span class="fs-6 fw-semibold">@Model.IdFamilia</span>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                    <span class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.75rem;">Nome da Família</span>
                    <span class="fs-6 fw-semibold">@Model.NomeFamilia</span>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                    <span class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.75rem;">Marca</span>
                    <span class="fs-6 fw-semibold">@(!string.IsNullOrEmpty(Model.Marca?.NomeMarca) ? Model.Marca.NomeMarca : "N/A")</span>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-3 rounded-4 h-100" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                    <span class="d-block opacity-75 fw-bold text-uppercase mb-1" style="font-size: 0.75rem;">Categoria / Status</span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="fs-6 fw-semibold text-truncate">@(!string.IsNullOrEmpty(Model.Categoria?.DescricaoCategoria) ? Model.Categoria.DescricaoCategoria : "N/A")</span>
                        @if (Model.Ativo)
                        {
                            <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25 ms-auto py-1"><i class="fa-solid fa-check"></i></span>
                        }
                        else
                        {

                            <span class="report-id-badge bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 ms-auto py-1"><i class="fa-solid fa-xmark"></i></span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <hr class="border-secondary border-opacity-25 my-4" />

        <div class="d-flex align-items-center mb-4">
            <i class="fa-solid fa-boxes-stacked fs-4 me-2" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h5 class="fw-bold mb-0">Produtos da Família</h5>
        </div>

        @if (Model.FamiliaDetails != null && Model.FamiliaDetails.Any())
        {
            <div class="row g-4">
                @foreach (var produto in Model.FamiliaDetails)
                {
                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                        <div class="glass-card h-100 d-flex flex-column p-3">
                            <a asp-controller="Produto" asp-action="Details" asp-route-id="@produto.IdProduto" class="text-decoration-none text-dark d-block mb-3 flex-grow-1">
                                <div class="d-flex justify-content-center align-items-center rounded-4 mb-3 p-2" style="height: 180px; background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border); overflow:hidden;">
                                    <img src="@produto.UrlImagem" alt="@(!string.IsNullOrEmpty(produto.NomeProduto) ? produto.NomeProduto : "Produto")" style="max-height:100%; max-width:100%; object-fit:contain; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.1));" />
                                </div>
                                <div class="text-center">
                                    <h6 class="fw-bold mb-2 text-truncate" style="color: var(--text);">@produto.NomeProduto</h6>
                                    @if (produto.Ativo)
                                    {
                                        <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25"><i class="fa-solid fa-check me-1"></i> Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="report-id-badge bg-danger bg-opacity-10 text-danger border-danger border-opacity-25"><i class="fa-solid fa-xmark me-1"></i> Inativo</span>
                                    }
                                </div>
                            </a>

                            <div class="d-flex justify-content-between gap-2 mt-auto pt-3 border-top border-secondary border-opacity-25">
                                <a asp-controller="Produto" asp-action="Delete" asp-route-id="@produto.IdProduto" class="btn btn-sm btn-outline-danger w-50 rounded-pill" title="Deletar">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                                <a asp-controller="Produto" asp-action="Edit" asp-route-id="@produto.IdProduto" class="btn btn-sm btn-warning text-dark w-50 rounded-pill" title="Editar">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-4 text-center rounded-4 mb-4" style="background: rgba(0,0,0,0.02); border: 1px dashed var(--glass-border);">
                <i class="fa-regular fa-folder-open fs-1 opacity-25 mb-3 d-block"></i>
                <p class="mb-0 opacity-75 fw-semibold">Nenhum produto cadastrado nesta família.</p>
            </div>
        }

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-5 pt-3 border-top border-secondary border-opacity-25 gap-3">
            <a asp-action="Index" class="btn-glass text-decoration-none">
                <i class="fa-solid fa-chevron-left"></i> Voltar
            </a>
            
            <div class="d-flex gap-2 w-100 w-md-auto justify-content-end">
                <a asp-action="Edit" asp-route-id="@Model.IdFamilia" class="btn-glass btn-warning text-dark border-0">
                    <i class="fa-solid fa-pen-to-square"></i> <span class="d-none d-sm-inline ms-1">Editar Família</span>
                </a>
                <a asp-controller="Produto" asp-action="Create" asp-route-familiaId="@Model.IdFamilia" class="btn-glass btn-success text-white border-0">
                    <i class="fa-solid fa-circle-plus"></i> <span class="d-none d-sm-inline ms-1">Add Produto</span>
                </a>
            </div>
        </div>
    </div>
</div>
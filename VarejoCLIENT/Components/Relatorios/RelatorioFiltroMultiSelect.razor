@typeparam TItem

@* 1. O GATILHO (Fica inalterado) *@
<div class="form-control d-flex align-items-center justify-content-between"
     @onclick="AbrirModal" @onclick:stopPropagation
     style="cursor: pointer; user-select: none;">
    
    <div class="d-flex align-items-center gap-2 text-truncate">
        <i class="@IconeClass" style="opacity: 0.8;"></i>
        @if (Selecionados != null && Selecionados.Any())
        {
            <span class="badge" style="background: var(--sys-primary); color: white; border-radius: 8px; font-weight: 600;">
                @Selecionados.Count item(s) selecionados
            </span>
        }
        else
        {
            <span style="opacity: 0.7;">@Titulo...</span>
        }
    </div>

    <i class="fa-solid fa-chevron-down" style="font-size: 0.8rem; opacity: 0.5;"></i>
</div>

@* 2. MODAL LIQUID GLASS *@
@if (ExibirModal)
{
    <div class="modal fade show d-block" style="backdrop-filter: blur(5px); z-index: 2050;" tabindex="-1" @onclick="FecharModal">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation>
            
            @* AQUI: Usamos a nova classe modal-varejo *@
            <div class="modal-content modal-varejo border-0">
                
                @* AQUI: justify-content-between para afastar o X do título *@
                <div class="modal-header border-0 pb-0 d-flex justify-content-between align-items-center w-100">
                    <h5 class="modal-title fw-bold m-0" style="color: var(--ui-text-primary);">
                        <i class="@IconeClass me-2"></i> @Titulo
                    </h5>
                    <button type="button" class="btn" style="color: var(--ui-text-primary);" @onclick="FecharModal">
                        <i class="fa-solid fa-xmark fs-4"></i>
                    </button>
                </div>
                
                <div class="modal-body">
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Buscar..." @bind="termo" @bind:event="oninput" />
                    </div>
                    
                    <div class="list-group list-group-flush overflow-auto" style="max-height: 350px; border-radius: 14px; border: 1px solid var(--ui-glass-border); background: transparent;">
                        @if (ItensFiltrados != null)
                        {
                            @foreach (var item in ItensFiltrados)
                            {
                                var id = GetId(item);
                                var isChecked = Selecionados != null && Selecionados.Contains(id);
            
                                <label class="list-group-item d-flex align-items-center gap-3"
                                       style="cursor: pointer; background: transparent; border-color: var(--ui-glass-border) !important; color: var(--ui-text-secondary); padding: 14px 20px;">
                
                                    <input class="form-check-input flex-shrink-0 m-0" type="checkbox"
                                           checked="@isChecked"
                                           style="width: 22px; height: 22px; border-color: var(--sys-primary);"
                                           @onchange="@((e) => Toggle(id, (bool)(e.Value ?? false)))" />
                       
                                    <span class="flex-grow-1 @(isChecked ? "fw-bold" : "")"
                                          style="color: @(isChecked ? "var(--sys-primary)" : "inherit"); line-height: 1.3;">
                                        @GetNome(item)
                                    </span>
                                </label>
                            }
                        }
                    </div>
                </div>
                
                <div class="modal-footer border-0 pt-0">
                    <button class="btn-glass btn-glass-primary w-100" @onclick="FecharModal">
                        Confirmar Seleção
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Titulo { get; set; } = "Pesquisar...";
    [Parameter] public string IconeClass { get; set; } = "fa-solid fa-magnifying-glass";
    [Parameter] public List<TItem> Itens { get; set; } = new();
    [Parameter] public List<string> Selecionados { get; set; } = new();
    [Parameter] public EventCallback<List<string>> SelecionadosChanged { get; set; }
    [Parameter] public Func<TItem, string> GetId { get; set; } = default!;
    [Parameter] public Func<TItem, string> GetNome { get; set; } = default!;

    private bool ExibirModal = false;
    private string termo = "";

    private void AbrirModal() { ExibirModal = true; StateHasChanged(); }
    private void FecharModal() { ExibirModal = false; termo = ""; StateHasChanged(); }

    private IEnumerable<TItem> ItensFiltrados =>
        (Itens ?? new()).Where(i => GetNome(i)?.Contains(termo, StringComparison.OrdinalIgnoreCase) == true);

    private async Task Toggle(string id, bool check)
    {
        Selecionados ??= new();
        if (check) { if (!Selecionados.Contains(id)) Selecionados.Add(id); }
        else { Selecionados.Remove(id); }
        await SelecionadosChanged.InvokeAsync(Selecionados);
    }
}
@model Varejo.ViewModels.TipoMovimentoViewModel

@{
    ViewData["Title"] = "Novo Tipo de Movimento";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-right-left fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
        </div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="mb-4">
                <label asp-for="DescricaoTipoMovimento" class="form-label fw-bold opacity-75"></label>
                <input asp-for="DescricaoTipoMovimento" class="form-control form-control-lg" placeholder="Ex: Entrada por Compra, Saída por Avaria..." />
                <span asp-validation-for="DescricaoTipoMovimento" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <div class="mb-5">
                <label asp-for="IdEspecieMovimento" class="form-label fw-bold opacity-75">Espécie de Movimento</label>
                <select asp-for="IdEspecieMovimento" class="form-select form-control-lg"
                        asp-items="@(ViewBag.Especies != null ? new SelectList(ViewBag.Especies, "IdEspecieMovimento", "DescricaoEspecieMovimento") : null)">
                    <option value="">-- Selecione a Espécie --</option>
                </select>
                <span asp-validation-for="IdEspecieMovimento" class="text-danger small fw-semibold mt-1 d-block"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk"></i> Salvar Tipo
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
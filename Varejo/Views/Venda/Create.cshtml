@model Varejo.ViewModels.VendaViewModel

<div class="container-fluid">
    <form asp-action="Create" id="formVenda" method="post">
        <div class="row">
            <div class="col-md-9">
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-dark text-white fw-bold">Identificação da Venda</div>
                    <div class="card-body bg-light">
                        <div class="row">
                            <div class="col-md-6 mb-3 position-relative">
                                <label class="form-label fw-bold small">CLIENTE</label>
                                <input type="text" id="buscaCliente" class="form-control" placeholder="Pesquisar cliente...">
                                <input type="hidden" asp-for="PessoaId" id="PessoaId">
                                    <div id="containerCardsCliente" class="row mt-2 d-none"></div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label asp-for="FormaPagamentoId" class="form-label small fw-bold">PAGAMENTO</label>
                                    <select asp-for="FormaPagamentoId" class="form-select" asp-items="ViewBag.FormasPagamento"></select>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label asp-for="PrazoPagamentoId" class="form-label small fw-bold">PRAZO</label>
                                    <select asp-for="PrazoPagamentoId" class="form-select" asp-items="ViewBag.PrazosPagamento"></select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-3 border-primary">
                        <div class="card-body">
                            <label class="form-label fw-bold text-primary">PESQUISAR PRODUTOS</label>
                            <input type="text" id="produtoSearch" class="form-control form-control-lg" placeholder="Digite o nome do produto..." />
                        
                            <div class="row mt-3" id="produtoCards"></div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-header fw-bold">Itens da Venda</div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="tabelaItens">
                                <thead class="table-light">
                                    <tr>
                                        <th>Produto</th>
                                        <th>Embalagem</th>
                                        <th class="text-center">Qtd</th>
                                        <th class="text-end">Unitário</th>
                                        <th class="text-end">Desc. Tot.</th>
                                        <th class="text-end">Subtotal</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="produtosSelecionadosBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card shadow-sm bg-light text-white sticky-top" style="top: 20px;">
                        <div class="card-body text-center">
                            <h5 class="text-uppercase opacity-75">Total a Pagar</h5>
                            <h1 class="display-6 fw-bold text-success" id="resumoTotal">R$ 0,00</h1>
                        
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Bruto:</span> <span id="resumoSubtotal">R$ 0,00</span>
                            </div>
                            <div class="d-flex justify-content-between small text-danger mb-3">
                                <span>Descontos:</span> <span id="resumoDesconto">R$ 0,00</span>
                            </div>
                            <input type="hidden" asp-for="DescontoTotal" id="inputDescontoTotalFinal">

                                <button type="submit" class="btn btn-success btn-lg w-100 py-3 fw-bold">
                                    <i class="fas fa-check me-2"></i>FINALIZAR
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        @section Scripts {
            <script>
                const containerProdutosBody = document.getElementById('produtosSelecionadosBody');
                const containerProdutoCards = document.getElementById('produtoCards');
                const produtoSearch = document.getElementById('produtoSearch');
                let itensVenda = [];
                let debounceTimer;

                // --- BUSCA DE PRODUTOS (ESTILO MOVIMENTO) ---
                produtoSearch.addEventListener('input', function () {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(async () => {
                        const termo = produtoSearch.value.trim();
                        if (termo.length < 2) {
                            containerProdutoCards.innerHTML = '';
                            return;
                        }

                        try {
                            const response = await fetch('@Url.Action("BuscarProdutos", "Venda")?termo=' + encodeURIComponent(termo));
                            const produtos = await response.json();
                            containerProdutoCards.innerHTML = '';

                            produtos.forEach(produto => {
                                const imagem = produto.UrlImagem || '/imagens/default.png';
                                const col = document.createElement('div');
                                col.className = 'col-md-4 mb-3';
                                col.innerHTML = `
                                    <div class="card h-100 shadow-sm border-0">
                                        <img src="${imagem}" class="card-img-top p-2" style="height:120px; object-fit:contain;">
                                        <div class="card-body p-2">
                                            <h6 class="fw-bold mb-1 text-truncate">${produto.NomeProduto}</h6>
                                            <div class="mb-2">
                                                <label class="small fw-bold">Embalagem</label>
                                                <select class="form-select form-select-sm sel-emb">
                                                    ${produto.Embalagens.map(e => `
                                                        <option value="${e.IdProdutoEmbalagem}" data-preco="${e.Preco}">
                                                            ${e.TipoEmbalagemDescricao ?? 'Unid'} - R$ ${Number(e.Preco).toFixed(2)}
                                                        </option>
                                                    `).join('')}
                                                </select>
                                            </div>
                                            <div class="row g-1 mb-2">
                                                <div class="col-6">
                                                    <label class="small fw-bold">Qtd</label>
                                                    <input type="number" class="form-control form-control-sm inp-qtd" value="1" min="0.001">
                                                </div>
                                                <div class="col-6">
                                                    <label class="small fw-bold text-danger">Desc.R$</label>
                                                    <input type="number" class="form-control form-control-sm inp-desc" value="0.00">
                                                </div>
                                            </div>
                                            <button type="button" class="btn btn-primary btn-sm w-100 btn-add">Adicionar</button>
                                        </div>
                                    </div>`;
                        
                                containerProdutoCards.appendChild(col);

                                // Evento Adicionar
                                col.querySelector('.btn-add').addEventListener('click', function() {
                                    const selEmb = col.querySelector('.sel-emb');
                                    const optEmb = selEmb.options[selEmb.selectedIndex];
                                    const qtd = parseFloat(col.querySelector('.inp-qtd').value);
                                    const descUnit = parseFloat(col.querySelector('.inp-desc').value) || 0;
                                    const preco = parseFloat(optEmb.dataset.preco);

                                    const item = {
                                        ProdutoId: produto.IdProduto,
                                        NomeProduto: produto.NomeProduto,
                                        ProdutoEmbalagemId: parseInt(selEmb.value),
                                        NomeEmbalagem: optEmb.text.split('-')[0].trim(),
                                        Quantidade: qtd,
                                        ValorUnitario: preco,
                                        DescontoUnitario: descUnit,
                                        Subtotal: (preco - descUnit) * qtd
                                    };

                                    itensVenda.push(item);
                                    atualizarTabela();
                                    produtoSearch.value = '';
                                    containerProdutoCards.innerHTML = '';
                                    produtoSearch.focus();
                                });
                            });
                        } catch (err) { console.error(err); }
                    }, 300);
                });

                       function atualizarTabela() {
                    containerProdutosBody.innerHTML = '';
                    let tBruto = 0; let tDesc = 0;

                    itensVenda.forEach((item, i) => {
                        const totalDesc = item.DescontoUnitario * item.Quantidade;
                        const subtotalItem = item.Subtotal;
        
                        tBruto += (item.ValorUnitario * item.Quantidade);
                        tDesc += totalDesc;

                        containerProdutosBody.innerHTML += `
                            <tr>
                                <td class="small fw-bold">
                                    ${item.NomeProduto}
                                    <input type="hidden" name="Itens[${i}].ProdutoId" value="${item.ProdutoId}">
                                    <input type="hidden" name="Itens[${i}].NomeProduto" value="${item.NomeProduto}">
                                </td>
                                <td class="small">
                                    ${item.NomeEmbalagem}
                                    <input type="hidden" name="Itens[${i}].ProdutoEmbalagemId" value="${item.ProdutoEmbalagemId}">
                                    <input type="hidden" name="Itens[${i}].NomeEmbalagem" value="${item.NomeEmbalagem}">
                                </td>
                                <td class="text-center">
                                    <input type="hidden" name="Itens[${i}].Quantidade" value="${item.Quantidade.toString().replace('.',',')}">
                                    ${item.Quantidade}
                                </td>
                                <td class="text-end">
                                    <input type="hidden" name="Itens[${i}].ValorUnitario" value="${item.ValorUnitario.toFixed(2).replace('.',',')}">
                                    R$ ${item.ValorUnitario.toFixed(2)}
                                </td>
                                <td class="text-end text-danger">
                                    <input type="hidden" name="Itens[${i}].DescontoUnitario" value="${item.DescontoUnitario.toFixed(2).replace('.',',')}">
                                    R$ ${totalDesc.toFixed(2)}
                                </td>
                                <td class="text-end fw-bold">
                                    <input type="hidden" name="Itens[${i}].Subtotal" value="${subtotalItem.toFixed(2).replace('.',',')}">
                                    R$ ${subtotalItem.toFixed(2)}
                                </td>
                                <td>
                                    <button type="button" class="btn btn-link text-danger p-0" onclick="removerItem(${i})">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>`;
                    });

                    // Atualiza os totais do rodapé/lateral
                    const totalFinal = tBruto - tDesc;
                    document.getElementById('resumoSubtotal').innerText = 'R$ ' + tBruto.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    document.getElementById('resumoDesconto').innerText = 'R$ ' + tDesc.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                    document.getElementById('resumoTotal').innerText = 'R$ ' + totalFinal.toLocaleString('pt-BR', {minimumFractionDigits: 2});
    
                    // Hidden do Total de Desconto da Venda (se sua ViewModel principal pedir)
                    const inputDescTotal = document.getElementById('inputDescontoTotalFinal');
                    if(inputDescTotal) inputDescTotal.value = tDesc.toFixed(2).replace('.',',');
                }

                function removerItem(i) {
                    itensVenda.splice(i, 1);
                    atualizarTabela();
                }

                               // --- BUSCA DE CLIENTES (CARD EXPANDIDO) ---
                document.getElementById('buscaCliente').addEventListener('input', function(e) {
                    const termo = e.target.value;
                    const container = document.getElementById('containerCardsCliente');
    
                    if (termo.length < 2) {
                        container.classList.add('d-none');
                        container.innerHTML = '';
                        return;
                    }

                    fetch('/Venda/BuscarClientes?termo=' + encodeURIComponent(termo))
                        .then(res => res.json())
                        .then(data => {
                            container.innerHTML = '';
                            if (!data || data.length === 0) {
                                container.classList.add('d-none');
                                return;
                            }

                            data.forEach(c => {
                                const id = c.IdPessoa || c.idPessoa;
                                const nome = c.NomeRazao || c.nomeRazao;
                                const doc = c.CpfCnpj || c.cpfCnpj || 'Sem Documento';

                                const col = document.createElement('div');
                                // Mudamos para col-12 para ocupar toda a largura da div pai
                                col.className = 'col-12 mb-2';
                
                                col.innerHTML = `
                                    <div class="card shadow-sm border-primary-hover" style="cursor:pointer; border: 1px solid #dee2e6; transition: 0.2s;">
                                        <div class="card-body p-3">
                                            <div class="row align-items-center">
                                                <div class="col-auto">
                                                    <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                                                        <i class="fas fa-user text-primary fa-lg"></i>
                                                    </div>
                                                </div>
                                                <div class="col">
                                                    <h5 class="mb-1 fw-bold text-dark text-uppercase" style="letter-spacing: 0.5px;">${nome}</h5>
                                                    <div class="d-flex gap-3">
                                                        <span class="badge bg-light text-secondary border">
                                                            <i class="fas fa-id-card me-1"></i> ${doc}
                                                        </span>
                                                        <span class="badge bg-light text-secondary border">
                                                            <i class="fas fa-tag me-1"></i> ID: ${id}
                                                        </span>
                                                    </div>
                                                </div>
                    
                                            </div>
                                        </div>
                                    </div>`;
                
                                col.onclick = () => {
                                    document.getElementById('PessoaId').value = id;
                                    document.getElementById('buscaCliente').value = nome;
                                    container.classList.add('d-none');
                                    container.innerHTML = '';
                                    document.getElementById('produtoSearch').focus();
                                };
                                container.appendChild(col);
                            });
                            container.classList.remove('d-none');
                        });
                });
            </script>
        }
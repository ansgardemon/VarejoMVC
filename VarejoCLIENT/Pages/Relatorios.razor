@page "/relatorios"

@using Varejo.Client.Models.UI
@using VarejoSHARED.DTO

<RelatorioTabela TItem="ProdutoOutputDTO"
                 Dados="vendas"
                 Colunas="colunas"
                 ItensPorPagina="5" />

@code {
    private List<ProdutoOutputDTO> vendas = new()
    {
        new() { IdProduto = 1, NomeProduto = "Chocolate", Preco = 50, UrlImagem = "" },
        new() { IdProduto = 2, NomeProduto = "Bala", Preco = 10, UrlImagem = "" }
    };

    private List<RelatorioColuna<ProdutoOutputDTO>> colunas = new()
    {
        new() { Titulo = "ID", Campo = "id", Selector = x => x.IdProduto },
        new() { Titulo = "Produto", Campo = "nome", Selector = x => x.NomeProduto },
        new() { Titulo = "Preço", Campo = "preco", Selector = x => x.Preco }
    };
}
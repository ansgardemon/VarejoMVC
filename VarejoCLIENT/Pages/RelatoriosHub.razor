@page "/relatorios"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using VarejoSHARED.DTO
@using VarejoSHARED.DTO.Relatorios
@using VarejoCLIENT.Services
@attribute [Authorize]
@inject RelatorioService RelService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<main class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <div class="me-3" style="width: 8px; height: 32px; background: var(--sys-primary); border-radius: 4px;"></div>
        <h2 class="fw-bold mb-0" style="color: var(--ui-text-primary);">Central de Relatórios</h2>
    </div>

    @* BARRA DE PESQUISA E FAVORITOS (TOTALMENTE INTEGRADA E RESPONSIVA) *@
    <div class="row g-3 mb-4">
        
        @* Barra de Pesquisa Integrada *@
        <div class="col-12 col-md-7 col-lg-8">
            <div class="search-bar-glass">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" class="form-control" placeholder="Buscar por código ou nome..."
                       @bind="termoBusca" @bind:event="oninput" />
            </div>
        </div>

        @* Botões Responsivos (Esticam no mobile, alinham à direita no PC) *@
        <div class="col-12 col-md-5 col-lg-4">
            <div class="d-flex gap-2 w-100">
                <button class="btn-glass flex-grow-1 @(mostrarApenasFavoritos ? "btn-glass-primary" : "")"
                        @onclick="() => mostrarApenasFavoritos = !mostrarApenasFavoritos">
                    <i class="@(mostrarApenasFavoritos ? "fa-solid fa-star text-warning" : "fa-regular fa-star")"></i> Favoritos
                </button>
                <button class="btn-glass flex-grow-1 @(!mostrarApenasFavoritos ? "btn-glass-primary" : "")"
                        @onclick="() => mostrarApenasFavoritos = false">
                    Todos
                </button>
            </div>
        </div>
    </div>

    @* GAVETAS DOS RELATÓRIOS (USANDO GLASS-CARD) *@
    <div class="accordion glass-card p-0 overflow-hidden">
        @foreach (var grupo in RelatoriosFiltrados.GroupBy(x => x.Categoria))
        {
            var isSearching = !string.IsNullOrWhiteSpace(termoBusca);
            var isOpen = isSearching || gavetasAbertas.Contains(grupo.Key);

            var btnClass = isOpen ? "accordion-button fw-bold" : "accordion-button collapsed fw-bold";
            var collapseClass = isOpen ? "accordion-collapse collapse show" : "accordion-collapse collapse";

            <div class="accordion-item border-0 bg-transparent">
                <h2 class="accordion-header">
                    <button class="@btnClass" type="button" @onclick="() => ToggleGaveta(grupo.Key)"
                            style="background: transparent; color: var(--ui-text-primary); border-bottom: 1px solid var(--ui-glass-border); box-shadow: none;">
                        <i class="fa-solid fa-folder-open me-2 opacity-75"></i> @grupo.Key.ToUpper()
                        <span class="badge rounded-pill ms-3" style="background: var(--sys-primary); font-size: 0.75rem; color: white;">@grupo.Count()</span>
                    </button>
                </h2>
                
                <div class="@collapseClass">
                    <div class="accordion-body" style="background: rgba(0,0,0,0.02);">
                        <div class="row g-4">
                            @foreach (var rel in grupo)
                            {
                                <div class="col-md-4 col-lg-3">
                                    <div class="glass-card h-100 p-3" style="cursor: pointer;"
                                         @onclick='() => Navegar(rel.Codigo)'
                                         onmouseover="this.style.transform='translateY(-3px)'"
                                         onmouseout="this.style.transform='translateY(0)'">
                                        
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <span class="report-id-badge">
                                                <i class="fa-solid fa-file-lines me-1"></i> @rel.Codigo
                                            </span>
                                            <button class="btn btn-link p-0 border-0 text-decoration-none"
                                                    style="color: @(rel.IsFavorito ? "var(--state-warning)" : "var(--ui-text-secondary)"); opacity: @(rel.IsFavorito ? "1" : "0.3");"
                                                    @onclick:stopPropagation
                                                    @onclick="() => AlternarFavorito(rel)">
                                                <i class="fa-solid fa-star fs-5"></i>
                                            </button>
                                        </div>
                                        <h6 class="fw-bold mb-1" style="color: var(--ui-text-primary);">@rel.Nome</h6>
                                        <small style="color: var(--ui-text-secondary); opacity: 0.6;">Módulo Gerencial</small>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    
    @if (!RelatoriosFiltrados.Any())
    {
        <div class="text-center p-5 mt-4 glass-card">
            <i class="fa-solid fa-magnifying-glass fa-2x mb-3 text-muted opacity-50"></i>
            <h5 class="fw-bold" style="color: var(--ui-text-primary);">Nenhum relatório encontrado</h5>
            <p class="mb-0" style="color: var(--ui-text-secondary); opacity: 0.7;">Tente buscar por outro nome, código ou remova o filtro de favoritos.</p>
        </div>
    }
</main>

@code {
    private string termoBusca = "";
    private bool mostrarApenasFavoritos = false;
    private List<RelatorioDefinicaoDTO> todosRelatorios = new();
    private HashSet<string> gavetasAbertas = new();
    
    // Variável para guardar o ID de quem está logado
    private int usuarioIdLogado = 0;

    protected override async Task OnInitializedAsync()
    {
        // 1. Pega os dados da sessão atual
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // 2. Extrai o UsuarioId (exatamente como fizemos no NavMenu)
        var idClaim = user.FindFirst("UsuarioId")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        int.TryParse(idClaim, out usuarioIdLogado);

        // 3. Chama o serviço passando o ID para ele preencher as estrelas que já estão no banco
        todosRelatorios = await RelService.GetMenuRelatoriosAsync(usuarioIdLogado);
        
        if (todosRelatorios.Any()) gavetasAbertas.Add("");
    }

    private async Task AlternarFavorito(RelatorioDefinicaoDTO rel)
    {
        if (usuarioIdLogado <= 0) return; // Trava de segurança

        // Toggle visual imediato para parecer super rápido pro usuário
        rel.IsFavorito = !rel.IsFavorito;

        var dto = new RelatorioFavoritoDTO
        {
            IdUsuario = usuarioIdLogado,
            CodigoRelatorio = rel.Codigo
        };

        try
        {
            // Vai lá na API e salva a mudança no banco
            bool statusBanco = await RelService.ToggleFavoritoAsync(dto);
            
            // Sincroniza o visual com a verdade absoluta que veio do banco
            rel.IsFavorito = statusBanco;
        }
        catch (Exception)
        {
            // Se der erro de conexão, desfaz o toggle visual
            rel.IsFavorito = !rel.IsFavorito;
        }
        
        StateHasChanged();
    }

    private void ToggleGaveta(string categoria)
    {
        if (gavetasAbertas.Contains(categoria)) gavetasAbertas.Remove(categoria);
        else { gavetasAbertas.Clear(); gavetasAbertas.Add(categoria); }
    }

    private IEnumerable<RelatorioDefinicaoDTO> RelatoriosFiltrados =>
        todosRelatorios
            .Where(r => (!mostrarApenasFavoritos || r.IsFavorito) &&
                        (string.IsNullOrEmpty(termoBusca) ||
                         r.Nome.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ||
                         r.Codigo.ToString().Contains(termoBusca)))
            .OrderBy(r => r.Codigo);

    private void Navegar(int cod) => Nav.NavigateTo($"/relatorio/{cod}");
}
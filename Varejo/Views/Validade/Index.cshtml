@model IEnumerable<Varejo.ViewModels.ValidadeViewModel>

@{
    ViewData["Title"] = "Controle de Validades";
    string aba = ViewBag.AbaAtual ?? "estoque";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25 gap-3">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-calendar-check fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>
            <a asp-action="Create" class="btn-glass btn-primary text-white border-0 text-decoration-none">
                <i class="fa-solid fa-plus me-1"></i> Nova Validade
            </a>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="@Url.Action("Index", new { aba = "estoque" })"
                   class="btn-glass text-decoration-none @(aba == "estoque" ? "btn-success border-0 text-white" : "border-secondary border-opacity-25 opacity-75")">
                <i class="fa-solid fa-box-open me-2"></i> Em Estoque
            </a>
            <a href="@Url.Action("Index", new { aba = "esgotados" })"
                   class="btn-glass text-decoration-none @(aba == "esgotados" ? "btn-danger border-0 text-white" : "border-secondary border-opacity-25 opacity-75")">
                <i class="fa-solid fa-ban me-2"></i> Esgotados
            </a>
        </div>

        <div class="p-3 rounded-4 mb-4" style="background: rgba(0,0,0,0.02); border: 1px solid var(--glass-border);">
            <form method="get">
                <input type="hidden" name="aba" value="@aba" />
                <div class="row g-2 align-items-end">
                    <div class="col-md-3 col-sm-6">
                        <label class="small fw-bold opacity-75 mb-1">Data Inicial</label>
                        <input type="date" name="dataInicial" class="form-control form-control-sm" value="@(ViewBag.FiltroDataInicial?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <label class="small fw-bold opacity-75 mb-1">Data Final</label>
                        <input type="date" name="dataFinal" class="form-control form-control-sm" value="@(ViewBag.FiltroDataFinal?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-md-4 col-sm-12">
                        <label class="small fw-bold opacity-75 mb-1">Produto</label>
                        <input type="text" name="produtoNome" class="form-control form-control-sm" placeholder="Buscar por nome..." value="@(ViewBag.FiltroProdutoNome ?? "")" />
                    </div>
                    <div class="col-md-2 col-sm-12 d-flex gap-2">
                        <button type="submit" class="btn btn-sm btn-primary w-100" title="Filtrar"><i class="fa-solid fa-filter me-1"></i> Filtrar</button>
                        <a href="@Url.Action("Index", new { aba = aba })" class="btn btn-sm btn-outline-secondary w-100" title="Limpar"><i class="fa-solid fa-eraser"></i></a>
                    </div>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="number" class="ps-md-4">ID</th>
                        <th data-sortable="true" data-sort-type="string">Data de Validade</th>
                        <th data-sortable="true" data-sort-type="string">Produto</th>
                        <th class="text-md-center">@(aba == "estoque" ? "Status Estoque" : "Status")</th>
                        <th class="text-center pe-md-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var v in Model)
                        {
                            <tr class="@(!v.EmEstoque ? "opacity-75" : "")">
                                <td data-label="ID" class="ps-md-4 fw-bold opacity-50">@v.IdValidade</td>
                                <td data-label="Validade" class="fw-bold @(v.EmEstoque && v.DataValidade <= DateTime.Today.AddDays(7) ? "text-danger" : "")">
                                    @v.DataValidade.ToString("dd/MM/yyyy")
                                </td>
                                <td data-label="Produto" class="fw-semibold">@v.ProdutoNome</td>
                                <td data-label="Status" class="text-md-center">
                                    @if (v.EmEstoque)
                                    {
                                        <span class="report-id-badge bg-success bg-opacity-10 text-success border-success border-opacity-25 py-1 px-2">Em Estoque</span>
                                    }
                                    else
                                    {
                                        <span class="report-id-badge bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 py-1 px-2">Esgotado</span>
                                    }
                                </td>
                                <td data-label="Ações" class="pe-md-4">
                                    <div class="d-flex justify-content-end justify-content-md-center">
                                        @if (v.EmEstoque)
                                        {
                                            <a asp-action="Delete" asp-route-id="@v.IdValidade" class="btn btn-sm btn-danger text-white rounded-pill px-3" title="Marcar como Esgotado">
                                                <i class="fa-solid fa-hourglass-end me-1"></i> Esgotar
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small opacity-50"><i class="fa-solid fa-minus"></i></span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center p-5 opacity-50 fw-semibold">
                                <i class="fa-solid fa-calendar-xmark d-block fs-1 mb-3"></i>
                                Nenhum registro encontrado para esta aba/filtro.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@model Varejo.ViewModels.CategoriaViewModel

@{
    ViewData["Title"] = "Excluir Categoria";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 600px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-danger border-opacity-25">
            <i class="fa-solid fa-triangle-exclamation fs-3 me-3 text-danger"></i>
            <h4 class="mb-0 fw-bold text-danger">@ViewData["Title"]</h4>
        </div>

        @if (ViewData["DeleteError"] != null)
        {
            <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold d-flex align-items-center" role="alert">
                <i class="fa-solid fa-circle-exclamation fs-5 me-3"></i>
                <div>
                    @ViewData["DeleteError"]
                </div>
            </div>
        }

        <h5 class="fw-bold mb-4">Você tem certeza que deseja excluir esta categoria?</h5>
        
        <div class="p-3 mb-4 rounded-4" style="background: rgba(0, 0, 0, 0.03); border: 1px solid var(--glass-border);">
            <p class="mb-1 opacity-75 fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                @Html.DisplayNameFor(model => model.DescricaoCategoria)
            </p>
            <p class="mb-0 fs-5 fw-semibold">
                @Html.DisplayFor(model => model.DescricaoCategoria)
            </p>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IdCategoria" />
            
            <div class="d-flex justify-content-between align-items-center mt-5">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Cancelar
                </a>
                <button type="submit" class="btn-glass btn-danger border-0">
                    <i class="fa-solid fa-trash-can"></i> Confirmar Exclusão
                </button>
            </div>
        </form>
    </div>
</div>
@model IEnumerable<Varejo.ViewModels.HistoricoProdutoViewModel>
@{
    Layout = null; // Mantemos null para não puxar o menu do sistema
    var produto = ViewBag.Produto as Varejo.Models.Produto;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <title>Impressão - Extrato @produto.NomeProduto</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <style>
        /* Estilo da Tela (Visualizador de Documento) */
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #e2e8f0; /* Fundo cinza moderno */
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
        }

        .document-wrapper {
            max-width: 850px;
            margin: 40px auto;
            background: #ffffff;
            padding: 50px;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .header-print { 
            border-bottom: 3px solid #0f172a; 
            margin-bottom: 30px; 
            padding-bottom: 20px; 
        }

        /* Tabela Limpa e Profissional */
        .table th { 
            background-color: rgba(0,0,0,0.03) !important; 
            color: #475569;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #cbd5e1;
            -webkit-print-color-adjust: exact; 
        }
        
        .table td {
            font-size: 0.85rem;
            vertical-align: middle;
            border-color: #e2e8f0;
        }

        .op-badge {
            background: rgba(0,0,0,0.04);
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* === O SEGREDO: REGRAS RESTRITAS PARA IMPRESSORA === */
        @@media print {
            body { 
                background-color: white !important; 
                margin: 0; 
            }
            .document-wrapper {
                margin: 0; 
                padding: 0; 
                box-shadow: none; /* Tira a sombra para não gastar tinta preta */
                border-radius: 0; 
                max-width: 100%;
            }
            .text-success { color: #15803d !important; -webkit-print-color-adjust: exact; }
            .text-danger { color: #b91c1c !important; -webkit-print-color-adjust: exact; }
            
            /* Remove botões ou links indesejados caso existam */
            .no-print { display: none !important; }
            
            @@page { margin: 1cm; }
        }
    </style>
</head>
<body onload="window.print();"> 
    
    <div class="document-wrapper">
        <div class="header-print d-flex justify-content-between align-items-end">
            <div>
                <h3 class="mb-3 fw-bold" style="letter-spacing: -0.5px;">EXTRATO DE MOVIMENTAÇÃO</h3>
                <p class="mb-1" style="font-size: 0.9rem;">
                    <span class="opacity-75 text-uppercase fw-bold" style="font-size: 0.7rem;">Produto</span><br />
                    <strong>@produto.IdProduto</strong> - @produto.NomeProduto
                </p>
                <p class="mb-0" style="font-size: 0.9rem;">
                    <span class="opacity-75 text-uppercase fw-bold" style="font-size: 0.7rem;">Família</span><br />
                    @produto.Familia?.NomeFamilia
                </p>
            </div>
            <div class="text-end">
                <p class="mb-3 text-muted" style="font-size: 0.8rem;">
                    Impresso em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                </p>
                <div class="p-3 rounded-3" style="background: rgba(0,0,0,0.03); border: 1px solid #e2e8f0;">
                    <p class="mb-0 text-uppercase fw-bold opacity-75" style="font-size: 0.7rem; letter-spacing: 0.5px;">Saldo Atual</p>
                    <h4 class="mb-0 fw-bold">@produto.EstoqueAtual.ToString("N2")</h4>
                </div>
            </div>
        </div>

        <table class="table table-borderless table-hover mt-4">
            <thead>
                <tr>
                    <th>Data/Hora</th>
                    <th>Operação</th>
                    <th class="text-end">Anterior</th>
                    <th class="text-center">Movimento</th>
                    <th class="text-end">Posterior</th>
                    <th>Obs.</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td class="fw-semibold text-muted">@item.Data.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="op-badge">@item.TipoMovimento</span></td>
                            <td class="text-end text-muted">@item.EstoqueAntes.ToString("N2")</td>
                            <td class="text-center fw-bold">
                                @if (item.QuantidadeMovimento > 0) 
                                { 
                                    <span class="text-success">+@item.QuantidadeMovimento.ToString("N2")</span> 
                                }
                                else if (item.QuantidadeMovimento < 0) 
                                { 
                                    <span class="text-danger">@item.QuantidadeMovimento.ToString("N2")</span> 
                                }
                                else
                                {
                                    <span class="text-muted">@item.QuantidadeMovimento.ToString("N2")</span>
                                }
                            </td>
                            <td class="text-end fw-bold text-dark">@item.EstoqueDepois.ToString("N2")</td>
                            <td class="text-muted" style="font-size: 0.75rem; max-width: 200px;">
                                @(string.IsNullOrEmpty(item.Observacao) ? "-" : item.Observacao)
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            Nenhuma movimentação registrada para este produto.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        <div class="mt-5 text-center text-muted" style="font-size: 0.7rem; border-top: 1px solid #e2e8f0; padding-top: 15px;">
            Documento gerado pelo sistema Varejo - VITRIN.O
        </div>
    </div>
    
</body>
</html>
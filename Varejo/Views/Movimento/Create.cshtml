@model Varejo.ViewModels.MovimentoViewModel

@{
    ViewData["Title"] = "Novo Movimento";
}

<div class="container-fluid mt-4">
    <form asp-action="Create" method="post">
        
        <div class="glass-card mb-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
                <i class="fa-solid fa-file-invoice fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            </div>

            <div class="row g-4 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold opacity-75">Número do Documento</label>
                    <input asp-for="Documento" class="form-control form-control-lg" placeholder="Ex: NF 123456" />
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-bold opacity-75">Tipo de Movimento</label>
                    <select asp-for="TipoMovimentoId" class="form-select form-control-lg">
                        <option value="">Selecione o tipo...</option>
                        @foreach (var tipo in ViewBag.TiposMovimento)
                        {
                            <option value="@tipo.IdTipoMovimento">@tipo.DescricaoTipoMovimento</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold opacity-75">Cliente/Fornecedor</label>
                    <select asp-for="PessoaId" class="form-select form-control-lg">
                        <option value="">Selecione a pessoa...</option>
                        @foreach (var pessoa in ViewBag.Pessoas)
                        {
                            <option value="@pessoa.IdPessoa">@pessoa.NomeRazao</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold opacity-75">Observação</label>
                    <textarea asp-for="Observacao" class="form-control" rows="2" placeholder="Informações adicionais..."></textarea>
                </div>
            </div>
        </div>

        <div class="glass-card mb-4" style="border-left: 4px solid var(--sys-primary-light, #4facfe);">
            <div class="d-flex align-items-center mb-3">
                <i class="fa-solid fa-magnifying-glass fs-4 me-2" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h5 class="fw-bold mb-0">Pesquisar Produtos</h5>
            </div>
            
            <input type="text" id="produtoSearch" class="form-control form-control-lg mb-4" placeholder="Digite o nome do produto para adicionar..." autocomplete="off" />
            
            <div class="row g-3" id="produtoCards"></div>
        </div>

        <div class="glass-card mb-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
                <i class="fa-solid fa-cart-flatbed fs-4 me-2" style="color: var(--sys-primary-light, #4facfe);"></i>
                <h5 class="fw-bold mb-0">Produtos Selecionados</h5>
            </div>
            
            <div id="produtosSelecionados" class="row g-3 mb-4">
                <div class="col-12 text-center py-4 opacity-50 placeholder-vazio">
                    <i class="fa-solid fa-box-open fs-2 mb-2 d-block"></i>
                    <span>Nenhum produto adicionado ao movimento.</span>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" asp-controller="Movimento" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Voltar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk"></i> Salvar Movimento
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const produtosSelecionados = document.getElementById('produtosSelecionados');
        const produtoCards = document.getElementById('produtoCards');
        const produtoSearch = document.getElementById('produtoSearch');
        let debounceTimer;

        produtoSearch.addEventListener('input', function () {
            clearTimeout(debounceTimer);

            debounceTimer = setTimeout(async () => {
                const termo = produtoSearch.value.trim();

                if (termo.length < 2) {
                    produtoCards.innerHTML = '';
                    return;
                }

                try {
                    const url = '@Url.Action("SearchProduto", "Movimento")?query=' + encodeURIComponent(termo);
                    const response = await fetch(url);
                    const produtos = await response.json();

                    produtoCards.innerHTML = '';

                    produtos.forEach(produto => {
                        const div = document.createElement('div');
                        div.classList.add('col-12', 'col-sm-6', 'col-md-4', 'col-lg-3', 'produto-card');
                        div.dataset.id = produto.IdProduto;
                        div.dataset.nome = (produto.NomeProduto || '').toLowerCase();

                        const imagem = produto.UrlImagem || '/img/sem-foto.png';

                        // Card da Busca (Visual Glass)
                        div.innerHTML = `
                            <div class="glass-card h-100 p-3 text-center d-flex flex-column" style="background: rgba(0,0,0,0.02);">
                                <div class="d-flex justify-content-center align-items-center rounded-3 mb-3 p-2" style="height: 100px; background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border); overflow:hidden;">
                                    <img src="${imagem}" class="img-fluid" alt="${produto.NomeProduto}" style="max-height:100%; object-fit:contain;">
                                </div>
                                <h6 class="fw-bold mb-3 opacity-75 text-truncate" title="${produto.NomeProduto}">${produto.NomeProduto}</h6>
                                <div class="mt-auto">
                                    <input type="number" min="0" class="form-control form-control-sm mb-2 quantidade border-0 text-center" style="background: rgba(0,0,0,0.05); color: var(--text);" placeholder="Qtd">
                                    <select class="form-select form-select-sm mb-3 embalagem border-0" style="background: rgba(0,0,0,0.05); color: var(--text);">
                                        ${produto.Embalagens.map(e => `
                                            <option value="${e.IdProdutoEmbalagem}">
                                                R$${Number(e.Preco).toFixed(2).replace('.',',')} - ${e.TipoEmbalagemDescricao ?? ('Tipo ' + e.TipoEmbalagemId)}
                                            </option>
                                        `).join('')}
                                    </select>
                                    <button type="button" class="btn-glass btn-success text-white border-0 w-100 justify-content-center py-1 addProdutoBtn">
                                        <i class="fa-solid fa-plus me-1"></i> Adicionar
                                    </button>
                                </div>
                            </div>
                        `;
                        produtoCards.appendChild(div);

                        // Evento Adicionar
                        div.querySelector('.addProdutoBtn').addEventListener('click', function () {
                            const card = this.closest('.produto-card');
                            const nome = card.querySelector('h6').innerText;
                            const quantidade = card.querySelector('.quantidade').value;
                            const embalagemSelect = card.querySelector('.embalagem');
                            const embalagemId = embalagemSelect.value;
                            const embalagemText = embalagemSelect.options[embalagemSelect.selectedIndex].text;
                            const imagemSelecionado = card.querySelector('img').src;

                            if (!quantidade || quantidade <= 0) {
                                alert('Informe uma quantidade válida.');
                                return;
                            }

                            // Remove o placeholder vazio se existir
                            const placeholder = produtosSelecionados.querySelector('.placeholder-vazio');
                            if(placeholder) placeholder.remove();

                            const idx = produtosSelecionados.children.length;

                            const divSel = document.createElement('div');
                            divSel.classList.add('col-12', 'col-sm-6', 'col-md-4', 'col-lg-3');
                            
                            // Card do Produto Selecionado (Visual Glass destacado)
                            divSel.innerHTML = `
                                <div class="glass-card h-100 p-3 text-center d-flex flex-column" style="border-top: 3px solid var(--sys-primary-light, #4facfe);">
                                    <img src="${imagemSelecionado}" style="height: 70px; object-fit:contain;" class="mb-3 mx-auto drop-shadow">
                                    <h6 class="fw-bold mb-2 opacity-75 text-truncate" style="font-size: 0.85rem;" title="${nome}">${nome}</h6>
                                    
                                    <div class="p-2 mb-3 rounded-3 text-start" style="background: rgba(0,0,0,0.03);">
                                        <p class="mb-1 small fw-semibold"><i class="fa-solid fa-hashtag me-1 opacity-50"></i> Qtd: <span class="text-primary fs-6">${quantidade}</span></p>
                                        <p class="mb-0 small text-muted text-truncate" title="${embalagemText}"><i class="fa-solid fa-box me-1 opacity-50"></i> ${embalagemText}</p>
                                    </div>
                                    
                                    <input type="hidden" name="Produtos[${idx}].ProdutoId" value="${card.dataset.id}" />
                                    <input type="hidden" name="Produtos[${idx}].ProdutoEmbalagemId" value="${embalagemId}" />
                                    <input type="hidden" name="Produtos[${idx}].Quantidade" value="${quantidade}" />
                                    
                                    <button type="button" class="btn-glass btn-danger border-0 w-100 justify-content-center mt-auto py-1 removeProdutoBtn">
                                        <i class="fa-solid fa-trash-can me-1"></i> Remover
                                    </button>
                                </div>
                            `;
                            produtosSelecionados.appendChild(divSel);

                            // Evento de remover
                            divSel.querySelector('.removeProdutoBtn').addEventListener('click', () => {
                                divSel.remove();
                                // Volta o placeholder se zerar
                                if(produtosSelecionados.children.length === 0) {
                                    produtosSelecionados.innerHTML = `
                                        <div class="col-12 text-center py-4 opacity-50 placeholder-vazio">
                                            <i class="fa-solid fa-box-open fs-2 mb-2 d-block"></i>
                                            <span>Nenhum produto adicionado ao movimento.</span>
                                        </div>
                                    `;
                                }
                            });

                            // Reseta o card da pesquisa
                            card.querySelector('.quantidade').value = '';
                            card.querySelector('.embalagem').selectedIndex = 0;
                        });
                    });

                } catch (err) {
                    console.error('Erro ao buscar produtos:', err);
                }
            }, 300);
        });
    </script>
}
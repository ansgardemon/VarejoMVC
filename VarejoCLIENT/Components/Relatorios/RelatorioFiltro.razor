<div class="card shadow-sm mb-4 border-0" style="background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); border: 1px solid var(--glass-border) !important;">
    <div class="card-body p-4">
        
        <div class="row g-3">
            @ChildContent
        </div>

        @if (BarraPesquisa != null)
        {
            <div class="row mt-3">
                <div class="col-12">
                    @BarraPesquisa
                </div>
            </div>
        }
        
        <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top" style="border-color: var(--glass-border) !important;">
            <button class="btn px-4" style="background: rgba(255, 255, 255, 0.2); border: 1px solid var(--glass-border); color: var(--sys-primary); font-weight: 600;" @onclick="OnClear">
                Limpar
            </button>
            <button class="btn px-4 shadow-sm" style="background: var(--sys-primary); color: white; font-weight: 600;" @onclick="OnSearch">
                <i class="fa-solid fa-magnifying-glass me-2"></i> Pesquisar
            </button>
            <div class="btn-group">
                <button class="btn shadow-sm" style="background: rgba(22, 56, 137, 0.85); color: white; font-weight: 600;" @onclick="@(() => BotaoExportarClicado("pdf"))">
                    <i class="fa-solid fa-file-pdf me-2"></i> Exportar PDF
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? BarraPesquisa { get; set; }
    [Parameter] public EventCallback OnSearch { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }
    [Parameter] public EventCallback<string> OnExport { get; set; }

    private async Task BotaoExportarClicado(string formato) => await OnExport.InvokeAsync(formato);
}
@inherits LayoutComponentBase
@inject NavigationManager Nav
@using VarejoCLIENT.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page @(isDarkMode ? "dark-theme" : "") @(IsLoginScreen ? "login-mode" : "")" data-theme="@(isDarkMode ? "dark" : "light")">
    
    @if (IsLoginScreen)
    {
        <div class="login-centered-container">
            @Body
        </div>
    }
    else
    {
        @* BOTÃO FAB e OVERLAY: Mobile *@
        <button class="menu-fab-btn" @onclick="ToggleMenu">
            <i class="fa-solid @(collapseNavMenu ? "fa-bars-staggered" : "fa-xmark")"></i>
        </button>

        <div class="sidebar-overlay @(collapseNavMenu ? "" : "show")" @onclick="ToggleMenu"></div>

        @* O SEGREDO ESTÁ AQUI: Envolver a sidebar e o main num d-flex *@
        <div class="d-flex w-100">
            
            <aside class="sidebar-varejo @(collapseNavMenu ? "collapsed" : "")">
                <NavMenu OnMenuItemClicked="ToggleMenu" OnThemeToggle="ToggleDarkMode" IsDarkMode="isDarkMode" />
            </aside>

            <main class="main-content flex-grow-1">
                @Body
            </main>

        </div>
    }
</div>

@code {
    private bool collapseNavMenu = true;
    private bool isDarkMode = false;
    private bool isUserAutenticado = false; // Nova variável de controle

    // Atualizado para usar a nova variável assíncrona
    private bool IsLoginScreen => Nav.Uri.ToLower().EndsWith("/login") || !isUserAutenticado;

    private void ToggleMenu() => collapseNavMenu = !collapseNavMenu;
    private void ToggleDarkMode() => isDarkMode = !isDarkMode;

    // Trocado para Async para podermos ler o Token do LocalStorage com segurança
    protected override async Task OnInitializedAsync()
    {
        // Pergunta ao nosso "Maestro" se tem alguém logado (Lê o JWT)
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isUserAutenticado = authState.User.Identity?.IsAuthenticated ?? false;

        // Se não estiver logado e não estiver na tela de login, joga pra lá
        if (!isUserAutenticado && !Nav.Uri.ToLower().Contains("/login"))
        {
            Nav.NavigateTo("/login");
        }
    }
}
@model Varejo.ViewModels.EstoqueConfigViewModel

@{
    ViewData["Title"] = "Configuração de Estoque";
}

<div class="container-fluid mt-4">
    <div class="glass-card mx-auto" style="max-width: 700px;">
        
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
            <i class="fa-solid fa-boxes-stacked fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
            <div>
                <h4 class="mb-0 fw-bold">Configurar Limites</h4>
                <p class="mb-0 opacity-75 small fw-semibold text-uppercase" style="letter-spacing: 0.5px;">@Model.NomeProduto</p>
            </div>
        </div>

        <form asp-action="EditConfig" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ProdutoId" />
            <input type="hidden" asp-for="NomeProduto" />

            <div asp-validation-summary="ModelOnly" class="alert bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger fw-semibold" role="alert"></div>

            <div class="row g-4 mb-2">
                <div class="col-md-6">
                    <label asp-for="EstoqueMinimo" class="form-label fw-bold opacity-75">Estoque Mínimo</label>
                    <input asp-for="EstoqueMinimo" class="form-control form-control-lg" type="number" step="0.01" placeholder="Ex: 10,00" />
                    <span class="opacity-50 small mt-2 d-block fw-semibold"><i class="fa-solid fa-circle-arrow-down me-1"></i>Abaixo disso, o produto aparecerá em vermelho no painel.</span>
                    <span asp-validation-for="EstoqueMinimo" class="text-danger small mt-1 d-block fw-semibold"></span>
                </div>
                
                <div class="col-md-6">
                    <label asp-for="EstoqueMaximo" class="form-label fw-bold opacity-75">Estoque Máximo</label>
                    <input asp-for="EstoqueMaximo" class="form-control form-control-lg" type="number" step="0.01" placeholder="Ex: 100,00" />
                    <span class="opacity-50 small mt-2 d-block fw-semibold"><i class="fa-solid fa-circle-arrow-up me-1"></i>Sugestão de teto para evitar excesso de capital imobilizado.</span>
                    <span asp-validation-for="EstoqueMaximo" class="text-danger small mt-1 d-block fw-semibold"></span>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> Cancelar
                </a>
                <button type="submit" class="btn-glass btn-success border-0 text-white">
                    <i class="fa-solid fa-floppy-disk"></i> Salvar Configurações
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model IEnumerable<Varejo.ViewModels.HistoricoProdutoViewModel>
@{
    var produto = ViewBag.Produto as Varejo.Models.Produto;
    ViewData["Title"] = "Extrato de Produto";
}

<div class="container-fluid mt-4">
    <div class="glass-card">
        
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom border-secondary border-opacity-25 gap-3">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-clock-rotate-left fs-3 me-3" style="color: var(--sys-primary-light, #4facfe);"></i>
                <div>
                    <h4 class="mb-0 fw-bold">Histórico do Produto</h4>
                    <p class="mb-0 opacity-75 small fw-semibold">
                        ID: @produto.IdProduto | @produto.NomeProduto (@produto.Familia?.NomeFamilia)
                    </p>
                </div>
            </div>
            
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn-glass text-decoration-none">
                    <i class="fa-solid fa-chevron-left"></i> <span class="d-none d-sm-inline ms-1">Voltar</span>
                </a>
                <a asp-action="PrintDetails" asp-route-id="@produto.IdProduto" target="_blank" class="btn-glass text-white border-0" style="background: var(--sys-primary-light, #4facfe);">
                    <i class="fa-solid fa-print"></i> <span class="d-none d-sm-inline ms-1">Imprimir Extrato</span>
                </a>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="d-flex flex-column justify-content-center align-items-center p-3 rounded-4" style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border);">
                    <h6 class="text-uppercase small fw-bold opacity-75 mb-1" style="letter-spacing: 0.5px;">Estoque Atual</h6>
                    <h3 class="mb-0 fw-bold @(produto.EstoqueAtual < 0 ? "text-danger" : "text-success")">
                        @produto.EstoqueAtual.ToString("N2")
                    </h3>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table-glass table-responsive-stack" id="sortableTable">
                <thead>
                    <tr>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer; user-select: none;">
                            <div class="d-flex justify-content-between align-items-center">Data/Hora <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer; user-select: none;">
                            <div class="d-flex justify-content-between align-items-center">Operação <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer; user-select: none;" class="text-md-end">
                            <div class="d-flex justify-content-between align-items-center">Anterior <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer; user-select: none;" class="text-md-center">
                            <div class="d-flex justify-content-between align-items-center">Movimento <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="number" style="cursor: pointer; user-select: none;" class="text-md-end">
                            <div class="d-flex justify-content-between align-items-center">Posterior <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                        <th data-sortable="true" data-sort-type="string" style="cursor: pointer; user-select: none;">
                            <div class="d-flex justify-content-between align-items-center">Observação <i class="fa-solid fa-sort opacity-50 ms-2"></i></div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Data/Hora" class="fw-semibold">@item.Data.ToString("dd/MM/yyyy HH:mm")</td>
                                <td data-label="Operação">
                                    <span class="report-id-badge" style="background: rgba(0,0,0,0.05); border-color: var(--glass-border);">@item.TipoMovimento</span>
                                </td>
                                <td data-label="Anterior" class="text-md-end opacity-75 fw-semibold">@item.EstoqueAntes.ToString("N2")</td>
                                <td data-label="Movimento" class="text-md-center fw-bold">
                                    @if (item.QuantidadeMovimento > 0)
                                    {
                                        <span class="text-success"><i class="fa-solid fa-arrow-trend-up me-1"></i>+@item.QuantidadeMovimento.ToString("N2")</span>
                                    }
                                    else if (item.QuantidadeMovimento < 0)
                                    {
                                        <span class="text-danger"><i class="fa-solid fa-arrow-trend-down me-1"></i>@item.QuantidadeMovimento.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="opacity-50">@item.QuantidadeMovimento.ToString("N2")</span>
                                    }
                                </td>
                                <td data-label="Posterior" class="text-md-end fw-bold">@item.EstoqueDepois.ToString("N2")</td>
                                <td data-label="Observação" class="opacity-75 small">@(string.IsNullOrEmpty(item.Observacao) ? "-" : item.Observacao)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center p-4">
                                <i class="fa-solid fa-clock-rotate-left fs-1 opacity-25 d-block mb-3"></i>
                                <span class="opacity-75 fw-semibold">Nenhum movimento registrado para este produto.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
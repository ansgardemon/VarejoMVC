@model Varejo.ViewModels.PrazoPagamentoViewModel

@{
    ViewData["Title"] = "Adicionar Prazo de Pagamento";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">@ViewData["Title"]</h5>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label">Descrição</label>
                    <input asp-for="Descricao" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Número de Parcelas</label>
                    <input asp-for="NumeroParcelas" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Intervalo (dias)</label>
                    <input asp-for="IntervaloDias" class="form-control" />
                </div>

                <button type="submit" class="btn btn-success">Salvar</button>
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>

            </form>
        </div>
    </div>
</div>